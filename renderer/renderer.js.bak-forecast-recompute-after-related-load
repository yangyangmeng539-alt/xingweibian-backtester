function getUiMarketEnvironment(nodePredictionAnalysis) {
  const env = nodePredictionAnalysis && nodePredictionAnalysis.marketEnvironment
    ? nodePredictionAnalysis.marketEnvironment
    : null;

  return env && typeof env === 'object' ? env : null;
}

function isUiMarketReady(nodePredictionAnalysis) {
  const env = getUiMarketEnvironment(nodePredictionAnalysis);
  return Boolean(env && env.ok);
}

function getUiMarketRegime(nodePredictionAnalysis) {
  const env = getUiMarketEnvironment(nodePredictionAnalysis);
  return String(env && env.regime ? env.regime : '');
}

function getUiMarketBias(nodePredictionAnalysis) {
  const env = getUiMarketEnvironment(nodePredictionAnalysis);
  return String(env && env.bias ? env.bias : '');
}

function isUiHostileMarket(nodePredictionAnalysis) {
  const regime = getUiMarketRegime(nodePredictionAnalysis);
  const bias = getUiMarketBias(nodePredictionAnalysis);

  return bias === 'hostile'
    || regime === 'BEAR'
    || regime === 'REBOUND_RISK'
    || regime === 'TOP_CROWDING';
}

function getUiMarketLabel(nodePredictionAnalysis) {
  const env = getUiMarketEnvironment(nodePredictionAnalysis);

  if (!env || !env.ok) {
    return '市场态未生成';
  }

  return `${env.title || env.regime || '-'} / ${env.regime || '-'}`;
}

function getUiPredictionKindLabel(kind) {
  const value = String(kind || '');

  const map = {
    TARGET_CATCHUP: '外部强，目标待确认',
    CHAIN_PREHEAT: '结构预热观察',
    EXTEND_UP: '趋势延续观察',
    LOW_REPAIR: '低位修复',
    RISK_WARNING: '风险观察',
    RISK_PULLBACK: '回撤风险观察',
    RISK_REVERSAL: '系统退潮风险',
    SHORT_WINDOW_RISK: '短窗风险',
    MIXED: '混合分歧',
    UNKNOWN: '未知'
  };

  return map[value] || value || '-';
}

function isUiRiskPredictionKind(kind) {
  const value = String(kind || '');

  return value === 'RISK_WARNING'
    || value === 'RISK_PULLBACK'
    || value === 'RISK_REVERSAL'
    || value === 'SHORT_WINDOW_RISK';
}

function getUiProjectionLayerLabel(nodePredictionAnalysis, marketProjection) {
  const marketEnvironment = getUiMarketEnvironment(nodePredictionAnalysis);

  if (marketEnvironment && marketEnvironment.ok) {
    return 'C层';
  }

  if (marketProjection && marketProjection.ok) {
    return '结构';
