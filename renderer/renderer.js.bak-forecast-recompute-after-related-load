function formatDuration(ms) {
  const value = Number(ms);

  if (!Number.isFinite(value) || value <= 0) {
    return '-';
  }

  const totalSeconds = Math.floor(value / 1000);
  const hours = Math.floor(totalSeconds / 3600);
  const minutes = Math.floor((totalSeconds % 3600) / 60);
  const seconds = totalSeconds % 60;

  if (hours > 0) {
    return `${hours}时${String(minutes).padStart(2, '0')}分${String(seconds).padStart(2, '0')}秒`;
  }

  if (minutes > 0) {
    return `${minutes}分${String(seconds).padStart(2, '0')}秒`;
  }

  return `${seconds}秒`;
}

function readSyncNumber(input, fallback, min) {
  const value = Number(input && input.value);

  if (!Number.isFinite(value)) {
    return fallback;
  }

  return Math.max(min, Math.floor(value));
}

function readFullMarketSyncOptions() {
  const selectedMode = syncModeSelect ? syncModeSelect.value : 'current';
  const options = {
    mode: 'full',
    currentSymbol: symbolInput.value.trim(),
    symbols: [],
    markets: [],
    startDate: (syncStartDateInput && syncStartDateInput.value.trim()) || '20180101',
    batchSize: readSyncNumber(syncBatchSizeInput, 20, 1),
    force: Boolean(syncForceInput && syncForceInput.checked),
    retryFailed: !syncRetryFailedInput || syncRetryFailedInput.checked,
    maxCount: readSyncNumber(syncMaxCountInput, 0, 0),
    throttleMs: readSyncNumber(syncThrottleMsInput, 800, 0),
    batchPauseMs: readSyncNumber(syncBatchPauseMsInput, 3000, 0),
    failPauseMs: readSyncNumber(syncFailPauseMsInput, 5000, 0),
    maxRetriesPerSymbol: 5,
    fullChunkYears: 30,
    concurrency: Math.min(3, readSyncNumber(syncConcurrencyInput, 1, 1))
  };

  if (selectedMode === 'HK_FULL') {
    options.mode = 'hk_full';
    options.market = 'HK';
    options.markets = ['HK'];

    if (options.startDate === '19900101') {
      options.startDate = '20200101';
    }
  } else if (selectedMode === 'current') {
    options.mode = 'current';
  } else if (selectedMode === 'symbols') {
    options.mode = 'symbols';
    options.symbols = String(syncSymbolsInput && syncSymbolsInput.value || '')
      .split(/[,，\s]+/)
      .map((item) => item.trim())
      .filter(Boolean);
  } else if (selectedMode === 'SH' || selectedMode === 'SZ' || selectedMode === 'BJ') {
    options.mode = 'market';
    options.markets = [selectedMode];
  } else {
    options.mode = 'full';
  }

  return options;
}

function validateFullMarketSyncOptions(options) {
  if (options.mode === 'hk_full') {
    if (!/^\d{8}$/.test(options.startDate)) {
      return '港股同步起始日期必须是 YYYYMMDD。';
    }

    return '';
  }

  if (options.mode === 'current' && !/^\d{6}$/.test(options.currentSymbol)) {
    return '当前股票需要是 6 位 A 股代码。';
  }

  if (options.mode === 'symbols') {
    const invalid = options.symbols.find((symbol) => !/^\d{6}$/.test(symbol));

    if (options.symbols.length === 0) {
      return '请输入至少一个指定股票代码。';
    }

    if (invalid) {
      return `指定股票包含非法代码：${invalid}`;
    }
  }

  if (!/^\d{8}$/.test(options.startDate)) {
    return '同步起始日期必须是 YYYYMMDD。';
  }

  return '';
}

