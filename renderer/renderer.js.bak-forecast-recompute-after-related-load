function getFilteredMarketGraph() {
  const graph = marketGraphState.graph || { nodes: [], edges: [], stats: {} };
  const sourceNodes = Array.isArray(graph.nodes) ? graph.nodes : [];
  let edges = Array.isArray(graph.edges) ? graph.edges : [];
  const searchText = String(marketGraphState.search || '').trim().toLowerCase();

  if (searchText) {
    const nodeMatchesSearch = (node) => {
      const code = String(node.code || '').toLowerCase();
      const label = String(node.label || '').toLowerCase();
      const memberStocks = [
        ...(Array.isArray(node.memberStocksPreview) ? node.memberStocksPreview : []),
        ...(Array.isArray(node.memberStocks) ? node.memberStocks : [])
      ];

      return code.includes(searchText) ||
        label.includes(searchText) ||
        String(node.type || '').toLowerCase().includes(searchText) ||
        memberStocks.some((stock) => (
          String(stock && stock.code || '').toLowerCase().includes(searchText) ||
          String(stock && stock.name || '').toLowerCase().includes(searchText)
        ));
    };
    const matchedNodeIds = new Set(sourceNodes.filter(nodeMatchesSearch).map((node) => node.id));

    edges = edges.filter((edge) => matchedNodeIds.has(edge.source) || matchedNodeIds.has(edge.target));

    const nodeIds = new Set(matchedNodeIds);
    edges.forEach((edge) => {
      nodeIds.add(edge.source);
      nodeIds.add(edge.target);
    });

    return {
      nodes: sourceNodes.filter((node) => nodeIds.has(node.id)),
      edges: edges.filter((edge) => nodeIds.has(edge.source) && nodeIds.has(edge.target)),
      stats: graph.stats || {}
    };
  }

  return {
    nodes: sourceNodes,
    edges,
    stats: graph.stats || {}
  };
}

function enrichMarketGraphWithRelatedStockNodes(graph) {
  const source = graph || { nodes: [], edges: [], stats: {} };

  if (marketGraphState.viewPreset !== 'stockFocus' && marketGraphState.viewPreset !== 'focus') {
    return source;
  }

  const focusCode = normalizeObservationStockCode(
    marketGraphState.focusCode || marketGraphState.expandStockCode || ''
  );

  if (!focusCode) {
    return source;
  }

  const nodes = Array.isArray(source.nodes) ? source.nodes.slice() : [];
  const edges = Array.isArray(source.edges) ? source.edges.slice() : [];
  const stats = source.stats || {};
  const nodeById = new Map(nodes.map((node) => [node.id, node]));

  let currentNode = nodes.find((node) => {
    return node && node.type === 'stock' && normalizeObservationStockCode(node.code || node.stockCode || node.symbol || node.id) === focusCode;
  });

  if (!currentNode) {
    currentNode = {
      id: `stock:${focusCode}`,
      type: 'stock',
      code: focusCode,
      label: focusCode,
      labelPriority: 999,
      source: 'focus_fallback'
    };

    nodes.unshift(currentNode);
    nodeById.set(currentNode.id, currentNode);
  }

  const derived = buildStockStockRelationsForCode(focusCode, {
    nodes,
    edges,
    stats
  });

  const relatedStocks = Array.isArray(derived && derived.stocks)
    ? derived.stocks
    : [];

  const maxRelated = marketGraphState.expandStockCode ? 80 : 36;
  let addedRelatedCount = 0;

  relatedStocks
    .filter((stock) => normalizeObservationStockCode(stock && stock.code) && normalizeObservationStockCode(stock && stock.code) !== focusCode)
    .slice(0, maxRelated)
    .forEach((stock, index) => {
      const code = normalizeObservationStockCode(stock.code);
      const stockId = `stock:${code}`;
      let stockNode = nodeById.get(stockId);

      if (!stockNode) {
        stockNode = {
          id: stockId,
          type: 'stock',
          code,
          label: stock.name || code,
          relationScore: Number(stock.relationScore || 0),
          relationStrength: stock.relationStrength || '',
          relationTypes: Array.isArray(stock.relationTypes) ? stock.relationTypes : [],
          relationLabels: Array.isArray(stock.relationLabels) ? stock.relationLabels : [],
          relatedToFocus: true,
          labelPriority: 700 - index,
          source: 'relation_derived_visible'
        };

        nodes.push(stockNode);
        nodeById.set(stockId, stockNode);
        addedRelatedCount += 1;
      } else {
        stockNode.relatedToFocus = true;
        stockNode.relationScore = Number(stockNode.relationScore || stock.relationScore || 0);
        stockNode.relationStrength = stockNode.relationStrength || stock.relationStrength || '';
        stockNode.labelPriority = Math.max(Number(stockNode.labelPriority || 0), 700 - index);
      }

      const existsEdge = edges.some((edge) => {
        return (
          (edge.source === currentNode.id && edge.target === stockId) ||
          (edge.source === stockId && edge.target === currentNode.id)
        );
      });

      if (!existsEdge) {
        edges.push({
          source: currentNode.id,
          target: stockId,
          relationType: 'stock_relation_derived',
          reason: Array.isArray(stock.relationLabels) && stock.relationLabels.length
            ? stock.relationLabels.slice(0, 3).join(' / ')
            : '共同关系推导',
          weight: Math.max(0.8, Math.min(2.8, Number(stock.relationScore || 1)))
        });
      }
    });

  return {
    ...source,
    nodes,
    edges,
    stats: {
      ...stats,
      relatedStockNodeCount: relatedStocks.length,
      addedRelatedStockNodeCount: addedRelatedCount,
      currentGraphNodeCount: nodes.length,
      currentGraphEdgeCount: edges.length,
      nodeCount: nodes.length,
      edgeCount: edges.length
    }
  };
}

