    const shortDate = dateText ? dateText.slice(5) : '';

    return `
      <line class="forecast-zoom-grid milestone" x1="${x.toFixed(2)}" y1="${plot.top.toFixed(2)}" x2="${x.toFixed(2)}" y2="${plot.bottom.toFixed(2)}"></line>
      <text class="forecast-zoom-axis-label milestone" x="${x.toFixed(2)}" y="${(plot.bottom + 12).toFixed(2)}">T+${day}</text>
      <text class="forecast-zoom-axis-label milestone" x="${x.toFixed(2)}" y="${(plot.bottom + 24).toFixed(2)}">${formatText(shortDate)}</text>

    `;
  }).join('');

  setForecastBoxBasePosition('zoom', insetX, insetY);
  layer.innerHTML = `
    <g class="forecast-zoom-inset forecast-draggable-box" data-forecast-box="zoom" transform="${getForecastBoxTransform('zoom')}">
      <rect class="forecast-zoom-inset-frame" x="${insetX.toFixed(2)}" y="${insetY.toFixed(2)}" width="${insetWidth}" height="${insetHeight}" rx="8"></rect>
      <text class="forecast-zoom-inset-title" x="${(insetX + 12).toFixed(2)}" y="${(insetY + 17).toFixed(2)}">${formatText(compactForecastOverlayText(insetTitle, 18))}</text>
      <g class="forecast-zoom-legend">
        <rect class="forecast-zoom-legend-band" x="${(insetX + 12).toFixed(2)}" y="${(insetY + 31).toFixed(2)}" width="12" height="6" rx="2"></rect>
        <text class="forecast-zoom-legend-text" x="${(insetX + 29).toFixed(2)}" y="${(insetY + 37).toFixed(2)}">区间</text>
        <line class="forecast-zoom-legend-median" x1="${(insetX + 72).toFixed(2)}" y1="${(insetY + 34).toFixed(2)}" x2="${(insetX + 88).toFixed(2)}" y2="${(insetY + 34).toFixed(2)}"></line>
        <text class="forecast-zoom-legend-text" x="${(insetX + 93).toFixed(2)}" y="${(insetY + 37).toFixed(2)}">预判</text>
        ${hasRealActualFuture ? `
                <line class="forecast-zoom-legend-actual" x1="${(insetX + 142).toFixed(2)}" y1="${(insetY + 34).toFixed(2)}" x2="${(insetX + 158).toFixed(2)}" y2="${(insetY + 34).toFixed(2)}"></line>
                <text class="forecast-zoom-legend-text" x="${(insetX + 163).toFixed(2)}" y="${(insetY + 37).toFixed(2)}">真实</text>
              ` : ''}
      </g>
      <line class="forecast-zoom-grid" x1="${plot.left.toFixed(2)}" y1="${plot.top.toFixed(2)}" x2="${plot.right.toFixed(2)}" y2="${plot.top.toFixed(2)}"></line>
      <line class="forecast-zoom-grid" x1="${plot.left.toFixed(2)}" y1="${plot.bottom.toFixed(2)}" x2="${plot.right.toFixed(2)}" y2="${plot.bottom.toFixed(2)}"></line>
      <line class="forecast-zoom-axis" x1="${plot.left.toFixed(2)}" y1="${plot.top.toFixed(2)}" x2="${plot.left.toFixed(2)}" y2="${plot.bottom.toFixed(2)}"></line>
      <line class="forecast-zoom-axis" x1="${plot.left.toFixed(2)}" y1="${plot.bottom.toFixed(2)}" x2="${plot.right.toFixed(2)}" y2="${plot.bottom.toFixed(2)}"></line>
      ${milestoneMarkerHtml}
      <text class="forecast-zoom-axis-label" x="${(insetX + 10).toFixed(2)}" y="${(plot.top + 4).toFixed(2)}">${formatNumber(yMax)}</text>
      <text class="forecast-zoom-axis-label" x="${(insetX + 10).toFixed(2)}" y="${(plot.bottom + 4).toFixed(2)}">${formatNumber(yMin)}</text>
      <text class="forecast-zoom-axis-label" x="${plot.left.toFixed(2)}" y="${(insetY + insetHeight - 20).toFixed(2)}">T0</text>
      <text class="forecast-zoom-axis-label" x="${plot.left.toFixed(2)}" y="${(insetY + insetHeight - 8).toFixed(2)}">${formatText(clickedDate.slice(5))}</text>
      <text class="forecast-zoom-axis-label end" x="${plot.right.toFixed(2)}" y="${(insetY + insetHeight - 20).toFixed(2)}">T+${forecastDays}</text>
      <text class="forecast-zoom-axis-label end" x="${plot.right.toFixed(2)}" y="${(insetY + insetHeight - 8).toFixed(2)}">${formatText((rowByDay.get(forecastDays) && rowByDay.get(forecastDays).date ? normalizeTimelineDate(rowByDay.get(forecastDays).date).slice(5) : ''))}</text>
      <defs>
        <clipPath id="${clipId}">
          <rect x="${plot.left.toFixed(2)}" y="${plot.top.toFixed(2)}" width="${(plot.right - plot.left).toFixed(2)}" height="${(plot.bottom - plot.top).toFixed(2)}"></rect>
        </clipPath>
      </defs>
      <g clip-path="url(#${clipId})">
        ${bandPath ? `<path class="forecast-zoom-band" d="${bandPath}" opacity="${forecastVisualMode.bandOpacity}"></path>` : ''}
        ${medianPath && forecastVisualMode.showMedianLine ? `<path class="forecast-zoom-median" d="${medianPath}" opacity="${forecastVisualMode.lineOpacity || 0.72}" style="stroke:${forecastVisualMode.lineStroke || 'rgba(255, 214, 102, 0.78)'}"></path>` : ''}
        ${actualPath && hasRealActualFuture ? `<path class="forecast-zoom-actual" d="${actualPath}"></path>` : ''}
