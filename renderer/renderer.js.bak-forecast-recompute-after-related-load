  const cacheOnly = !refresh;

  if (!isSupportedInputSymbol(symbol)) {
    statusBox.textContent = getSupportedInputSymbolHint();
    return;
  }

  const parsedParams = readBacktestParams();

  if (parsedParams.error) {
    statusBox.textContent = parsedParams.error;
    return;
  }

  saveParamsToStorage(parsedParams.params, getPresetKeyForParams(parsedParams.params));
  setPresetLabel(getPresetKeyForParams(parsedParams.params));

  runButton.disabled = true;
  statusBox.textContent = refresh
  ? '正在强制重新拉取数据、写入 SQLite，并运行形位变状态识别与机会评级模型...'
  : '正在读取 SQLite 本地缓存，并运行形位变状态识别与机会评级模型...';
  activeNodePredictionDate = '';
  activeNodePredictionAnalysis = null;
  nodePredictionRequestSeq += 1;
  metaBox.innerHTML = '';
  modelChartBox.innerHTML = '';
  interactiveCurveSvg.innerHTML = '';
  interactiveInfoPanel.innerHTML = '移动鼠标查看曲线信息。';
  renderNodePredictionStatusBar(null);
  interactiveCurveState = null;
  resultBody.innerHTML = '';
  opportunityAnalysisBox.innerHTML = '';
  stateAnalysisBox.innerHTML = '';
  tradeBox.innerHTML = '';

  const response = await window.xwbApi.runBacktest({
    symbol,
    startDate,
    endDate,
    refresh,
    cacheOnly,
    sourceMode: cacheOnly ? 'sqlite_cache_only' : '',
    ...parsedParams.params
  });

  runButton.disabled = false;

  if (!response.ok) {
    statusBox.textContent = `失败：${formatDisplayError(response.error)}`;
    return;
  }

  statusBox.textContent = '回测完成。';
  renderResults(response.result);
});
























