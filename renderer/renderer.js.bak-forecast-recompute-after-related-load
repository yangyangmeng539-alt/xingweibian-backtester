  } catch (error) {
    const message = error && error.message ? error.message : String(error || '未知错误');

    console.error(`[${panelName}_RENDER_ERROR]`, error);

    if (statusBox) {
      statusBox.textContent = `渲染异常：${panelName}｜${formatDisplayError(message)}`;
