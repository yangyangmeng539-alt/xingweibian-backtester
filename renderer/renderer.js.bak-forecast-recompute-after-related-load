function amplifyUiForecastPathBend(predicted, options = {}) {
  const source = predicted && typeof predicted === 'object' ? predicted : {};
  const factor = Number.isFinite(Number(options.factor))
    ? Number(options.factor)
    : FORECAST_PATH_BEND_AMPLIFY;
  const maxExtraPct = Number.isFinite(Number(options.maxExtraPct))
    ? Math.abs(Number(options.maxExtraPct))
    : FORECAST_PATH_BEND_MAX_EXTRA_PCT;

  const d20 = Number(source.d20);

  if (!Number.isFinite(d20)) {
    return {
      d3: roundUiForecastPathPct(source.d3),
      d5: roundUiForecastPathPct(source.d5),
      d10: roundUiForecastPathPct(source.d10),
      d20: roundUiForecastPathPct(source.d20)
    };
  }

  const amplifyOne = (key, day) => {
    const value = Number(source[key]);

    if (!Number.isFinite(value)) {
      return roundUiForecastPathPct(value);
    }

    const straightValue = d20 * day / 20;
    const bend = value - straightValue;
    const amplifiedBend = clamp(
      bend * factor,
      -maxExtraPct,
      maxExtraPct
    );

    return roundUiForecastPathPct(straightValue + amplifiedBend);
  };

  return {
    d3: amplifyOne('d3', 3),
    d5: amplifyOne('d5', 5),
    d10: amplifyOne('d10', 10),
    d20: roundUiForecastPathPct(d20)
  };
}

function interpolateUiForecastReturnMap(pointMap, day) {
  const value = Number(day);
  const source = pointMap && typeof pointMap === 'object' ? pointMap : {};
  const points = [
    { day: 0, value: 0 },
    { day: 3, value: Number(source.d3) },
    { day: 5, value: Number(source.d5) },
    { day: 10, value: Number(source.d10) },
    { day: 20, value: Number(source.d20) }
  ].filter((point) => Number.isFinite(point.value));

  if (!Number.isFinite(value) || points.length < 2) {
    return null;
  }

  if (value <= 0) {
    return 0;
  }

  for (let index = 1; index < points.length; index += 1) {
    const left = points[index - 1];
    const right = points[index];

    if (value <= right.day) {
      const span = right.day - left.day;
      const ratio = span <= 0 ? 1 : (value - left.day) / span;
      return roundUiForecastPathPct(left.value + (right.value - left.value) * ratio);
    }
  }

  return roundUiForecastPathPct(points[points.length - 1].value);
}

