function clampMarketStateNumber(value, min, max) {
  const number = Number(value);

  if (!Number.isFinite(number)) {
    return 0;
  }

  return Math.min(max, Math.max(min, number));
}

function mapMarketStateScoreX(score) {
  const safeScore = clampMarketStateNumber(score, -100, 100);
  return 7 + ((safeScore + 100) / 200) * 86;
}

function getMarketStateTrackZoneByRegime(regime, score) {
  const value = String(regime || '').toUpperCase();

  if (value === 'MARKET_PANIC') {
    return 'panic';
  }

  if (value === 'MARKET_BREAKDOWN_RISK') {
    return 'breakdown';
  }

  if (
    value === 'MARKET_WEAK'
    || value === 'MARKET_SIDEWAYS_WEAK'
    || value === 'MARKET_REBOUND_RISK'
  ) {
    return 'weak';
  }

  if (value === 'MARKET_SIDEWAYS') {
    return 'sideways';
  }

  if (
    value === 'MARKET_WARM'
    || value === 'MARKET_REBOUND'
  ) {
    return 'warm';
  }

  if (value === 'MARKET_STRONG_TREND') {
    return 'strong';
  }

  const scoreNumber = Number(score);

  if (!Number.isFinite(scoreNumber)) {
    return 'sideways';
  }

  if (scoreNumber <= -70) return 'panic';
  if (scoreNumber <= -45) return 'breakdown';
  if (scoreNumber <= -20) return 'weak';
  if (scoreNumber < 18) return 'sideways';
  if (scoreNumber < 45) return 'warm';

  return 'strong';
}

function mapMarketStateRegimeX(regime, score) {
  const zone = getMarketStateTrackZoneByRegime(regime, score);

  if (zone === 'panic') return 11.5;
  if (zone === 'breakdown') return 27.5;
  if (zone === 'weak') return 43.5;
  if (zone === 'sideways') return 58.5;
  if (zone === 'warm') return 73.5;
  if (zone === 'strong') return 88.5;

  return mapMarketStateScoreX(score);
}

function getMarketStatePointClass(regime, score) {
  const value = String(regime || '').toUpperCase();

  if (/PANIC|BREAKDOWN|WEAK|RISK/.test(value) || Number(score) <= -20) {
    return 'risk';
  }

  if (/STRONG|WARM|REBOUND/.test(value) || Number(score) >= 18) {
    return 'good';
  }

  return 'neutral';
}

function mapMarketStateActiveWidth(analysis) {
  const liquidity = analysis && analysis.liquidity ? analysis.liquidity : {};
  const active = clampMarketStateNumber(Number(liquidity.activeRatioMedian) || 1, 0.35, 1.8);

