      const dayText = formatNumber(point.day, 0);
      const titleText = `T+${dayText} 个交易日｜${dateText || point.date || ''}｜x=${formatNumber(point.x, 2)}`;

      return `
        <g class="forecast-overlay-milestone" data-forecast-day="${formatText(dayText)}">
          <title>${formatText(titleText)}</title>
          <line class="forecast-overlay-node-line" x1="${point.x.toFixed(2)}" y1="${state.pricePanel.top}" x2="${point.x.toFixed(2)}" y2="${state.pricePanel.bottom}" opacity="0.25"></line>
          <circle class="forecast-overlay-point" cx="${point.x.toFixed(2)}" cy="${point.y.toFixed(2)}" r="3"></circle>
          <text class="chart-axis-text" x="${point.x.toFixed(2)}" y="${(state.pricePanel.bottom + 14).toFixed(2)}">T+${formatText(dayText)} ${formatText(shortDate)}</text>
        </g>
      `;
    })
    .join('');
  const d20Forecast = nodePredictionAnalysis.horizonSummary && nodePredictionAnalysis.horizonSummary.d20
    ? nodePredictionAnalysis.horizonSummary.d20
    : {};
  const d20Actual = nodePredictionAnalysis.actualComparison && nodePredictionAnalysis.actualComparison.d20
    ? nodePredictionAnalysis.actualComparison.d20
    : {};
  const refinement = nodePredictionAnalysis.observationRefinement || null;
  const rawLabelLines = [
    ...buildCompactForecastOverlayLines(
      nodePredictionAnalysis,
      refinement,
      d20Forecast
    ),
    getForecastOverlayVisualModeText(nodePredictionAnalysis, forecastVisualMode)
  ].filter(Boolean);

  const labelLayout = getForecastOverlayLabelLayout(rawLabelLines, state, clickedPoint);
  const labelX = labelLayout.x;
  const labelY = labelLayout.y;
  const labelWidth = labelLayout.width;
  const labelHeight = labelLayout.height;
  const labelLines = labelLayout.lines;

  setForecastBoxBasePosition('label', labelX, labelY);
  rememberForecastOverlayRect('label', {
    x: labelX,
