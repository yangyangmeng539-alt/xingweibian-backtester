function getUiModelPredictionReturnPct(nodePredictionAnalysis, day, rawReturnPct, band = 'median') {
  const path = buildUiModelPredictionPath(nodePredictionAnalysis);

  if (!path || !path.ok) {
    return rawReturnPct;
  }

  const milestonePrediction = interpolateUiModelPredictionReturnPct(path, day);
  const dailyBiasDay = Math.round(Number(day));
  const dailyBiasMap = path.dailyModelBiasByDayPct || {};
  const directDailyModelBiasPct = Number(
    dailyBiasMap[dailyBiasDay]
    ?? dailyBiasMap[String(dailyBiasDay)]
  );

  if (!Number.isFinite(Number(milestonePrediction)) && !Number.isFinite(directDailyModelBiasPct)) {
    return rawReturnPct;
  }

  const tradingDayBendExtraPct = getUiTradingDayBendExtraPct(
    nodePredictionAnalysis,
    path,
    day,
    band
  );

  const hkLiquidityBendExtraPct = getUiHkLiquidityBendExtraPct(
    nodePredictionAnalysis,
    day
  );

  const baselineInterpolation = interpolateUiModelPredictionReturnPct({
    predictedReturnsPct: path.baselineMedianReturnsPct || {}
  }, day);
  const rawDailyMedian = Number(rawReturnPct);
  const dailyMedianBase = Number.isFinite(rawDailyMedian)
    ? rawDailyMedian
    : (
      Number.isFinite(Number(baselineInterpolation))
        ? Number(baselineInterpolation)
        : Number(milestonePrediction)
    );
  const modelBiasPct = Number.isFinite(directDailyModelBiasPct)
    ? directDailyModelBiasPct
    : (
      Number.isFinite(Number(baselineInterpolation)) && Number.isFinite(Number(milestonePrediction))
        ? Number(milestonePrediction) - Number(baselineInterpolation)
        : 0
    );

  const medianPrediction = roundUiForecastPathPct(
    dailyMedianBase + modelBiasPct + tradingDayBendExtraPct + hkLiquidityBendExtraPct
  );

  const bandName = String(band || 'median');
  const milestone = getUiForecastPathMilestone(nodePredictionAnalysis, day);
  const rawFallback = Number(rawReturnPct);
  const rawMedian = Number.isFinite(Number(dailyMedianBase))
    ? Number(dailyMedianBase)
    : (
      Number.isFinite(milestone.median)
        ? milestone.median
        : (Number.isFinite(rawFallback) ? rawFallback : medianPrediction)
    );

  const fallbackSpread = Number.isFinite(rawFallback) && Number.isFinite(rawMedian)
    ? Math.max(0.9, Math.abs(rawFallback - rawMedian))
    : 1.2;
  const lowerSpread = Number.isFinite(milestone.q1) && Number.isFinite(rawMedian)
    ? Math.max(0.9, Math.abs(rawMedian - milestone.q1))
    : fallbackSpread;
  const upperSpread = Number.isFinite(milestone.q3) && Number.isFinite(rawMedian)
    ? Math.max(0.9, Math.abs(milestone.q3 - rawMedian))
    : fallbackSpread;

  if (bandName === 'q1' || bandName === 'lower' || bandName === 'lowerQuartile') {
    return roundUiForecastPathPct(medianPrediction - lowerSpread * 0.72);
  }

  if (bandName === 'q3' || bandName === 'upper' || bandName === 'upperQuartile') {
    return roundUiForecastPathPct(medianPrediction + upperSpread * 0.72);
  }

  return medianPrediction;
}

