      <div class="observation-playback-meta structure-rhythm-playback-meta">
        <span>T${formatNumber(minOffset, 0)}</span>
        <b data-observation-playback-current-meta>当前 T${currentOffset >= 0 ? '+' : ''}${formatNumber(currentOffset, 0)}｜${formatText(currentFrame && currentFrame.date)}</b>
        <span>T+${formatNumber(maxOffset, 0)}</span>
      </div>
    </div>
  `;
}

function getObservationPlaybackControlRoots() {
  const roots = [];

  [
    observationMatrixSummaryBox,
    structureRhythmBox
  ].forEach((root) => {
    if (root && !roots.includes(root)) {
      roots.push(root);
    }
  });

  return roots;
}

function bindObservationPlaybackControls() {
  const roots = getObservationPlaybackControlRoots();

  if (!roots.length) {
    return;
  }

  roots.forEach((root) => {
    root.querySelectorAll('[data-observation-playback]').forEach((button) => {
      button.addEventListener('click', () => {
        const action = button.dataset.observationPlayback || '';

        if (action === 'prev') {
          stopObservationPlayback();
          stepObservationPlayback(-1, {
            renderCard: true,
            paintGraph: true
          });
        } else if (action === 'next') {
          stopObservationPlayback();
          stepObservationPlayback(1, {
            renderCard: true,
            paintGraph: true
          });
        } else if (action === 'toggle') {
          toggleObservationPlayback();
        }
      });
    });

    root.querySelectorAll('[data-observation-playback-range]').forEach((range) => {
      let dragging = false;

      const applyLive = () => {
        stopObservationPlayback();
        setObservationPlaybackOffset(range.value, {
          renderCard: false,
          paintGraph: true
        });
      };

      const commit = () => {
        if (!dragging) {
          return;
        }

        dragging = false;
        setObservationPlaybackOffset(range.value, {
          renderCard: true,
          paintGraph: true
        });
      };

      range.addEventListener('pointerdown', () => {
        dragging = true;
      });

      range.addEventListener('mousedown', () => {
        dragging = true;
      });

      range.addEventListener('touchstart', () => {
        dragging = true;
      }, { passive: true });

      range.addEventListener('input', applyLive);

      range.addEventListener('change', () => {
        dragging = true;
        commit();
      });

      range.addEventListener('pointerup', commit);
      range.addEventListener('mouseup', commit);
      range.addEventListener('touchend', commit);
      range.addEventListener('blur', commit);
    });
  });
}

function getStructureRhythmCurrentFrame(context) {
  if (!context || !Array.isArray(context.playbackFrames) || !context.playbackFrames.length) {
    return null;
  }

  if (context.currentPlaybackFrame) {
    return context.currentPlaybackFrame;
  }

  return getObservationPlaybackFrameByOffset(context, 0) || context.playbackFrames[0] || null;
}

function getStructureRhythmRelationRows(context, frame) {
  const matrix = context && context.related && Array.isArray(context.related.matrix)
    ? context.related.matrix
    : [];
  const offset = Number(frame && frame.offset || 0);

  return matrix
    .filter((row) => {
      const sources = Array.isArray(row && row.sources) ? row.sources : [];
      return sources.some((source) => String(source || '').includes('relation'));
    })
    .map((row) => {
      const point = getObservationMatrixPointAtOffset(row.timeline, offset);
      const t0Point = getObservationMatrixPointAtOffset(row.timeline, 0);
      const strong = isObservationStrongPoint(point);
      const opportunity = isObservationOpportunityPoint(point);
      const t0Strong = isObservationStrongPoint(t0Point);
      const relationScore = Number(row.relationScore || 0);
      const score = relationScore * 20 + (strong ? 100 : 0) + (opportunity ? 30 : 0) + (t0Strong ? 12 : 0);

      return {
        code: normalizeObservationStockCode(row.code),
        name: row.name || '',
        strong,
        opportunity,
        t0Strong,
        score,
        relationScore,
        relationStrength: row.relationStrength || '',
        relationLabels: row.relationLabels || [],
        stateName: point ? point.stateName || point.stateCode || '' : '',
        opportunityGrade: point ? point.opportunityGrade || '' : ''
      };
    })
    .filter((row) => row.code)
    .sort((left, right) => right.score - left.score)
    .slice(0, 10);
}

function getStructureRhythmFallbackRelationRows(context, frame) {
  const matrix = context && context.related && Array.isArray(context.related.matrix)
    ? context.related.matrix
    : [];
  const offset = Number(frame && frame.offset || 0);

  return matrix
    .map((row) => {
      const point = getObservationMatrixPointAtOffset(row.timeline, offset);
      const strong = isObservationStrongPoint(point);
      const opportunity = isObservationOpportunityPoint(point);
      const score = (strong ? 100 : 0) + (opportunity ? 30 : 0);

      return {
        code: normalizeObservationStockCode(row.code),
        name: row.name || '',
        strong,
        opportunity,
        score,
        stateName: point ? point.stateName || point.stateCode || '' : '',
        opportunityGrade: point ? point.opportunityGrade || '' : ''
      };
    })
    .filter((row) => row.code)
    .sort((left, right) => right.score - left.score)
    .slice(0, 8);
}

function getStructureRhythmLayerRows(context, frame) {
  const layerOrder = new Map(SUPPLY_CHAIN_LAYER_DEFS.map((def, index) => [def.key, index]));
  const layers = frame && Array.isArray(frame.layers)
    ? frame.layers
    : (
      context && context.observationSummary && Array.isArray(context.observationSummary.layers)
        ? context.observationSummary.layers
        : []
    );

  return layers
    .map((layer) => {
      const loaded = Number(layer.loadedCount || 0);
      const strong = Number(
        layer.strongCount !== undefined
          ? layer.strongCount
          : layer.t0StrongCount || 0
      );
      const opportunity = Number(
        layer.opportunityCount !== undefined
          ? layer.opportunityCount
          : layer.t0OpportunityCount || 0
      );
      const ratio = loaded > 0 ? strong / loaded : 0;
      const opportunityRatio = loaded > 0 ? opportunity / loaded : 0;

      return {
        layerKey: layer.layerKey || 'unknown',
        layerLabel: layer.layerLabel || layer.layerKey || '未知层级',
        loaded,
        strong,
        opportunity,
        ratio,
        opportunityRatio
      };
    })
    .sort((left, right) => {
      const leftOrder = layerOrder.has(left.layerKey) ? layerOrder.get(left.layerKey) : 99;
      const rightOrder = layerOrder.has(right.layerKey) ? layerOrder.get(right.layerKey) : 99;

      if (leftOrder !== rightOrder) {
        return leftOrder - rightOrder;
      }

      return String(left.layerLabel).localeCompare(String(right.layerLabel), 'zh-Hans-CN');
    });
}

function getStructureRhythmTone(ratio) {
  const value = Number(ratio || 0);

  if (value >= 0.6) {
    return 'strong';
  }

  if (value >= 0.35) {
    return 'middle';
  }

  if (value > 0) {
    return 'weak';
  }

  return 'none';
}

function getStructureRhythmLayerStatus(row, context) {
  const selfLayerKey = context && context.supplyChain && context.supplyChain.self
    ? context.supplyChain.self.layerKey
    : '';

  if (row.layerKey === selfLayerKey && row.ratio >= 0.35) {
    return '当前最强';
  }

  if (row.ratio >= 0.6) {
    return '强响应';
  }

  if (row.ratio >= 0.35) {
    return '扩散中';
  }

  if (row.ratio > 0) {
    return '弱响应';
  }

  return '当前较弱';
}

function renderStructureRhythmRelationNode(row, index, total) {
  const safeTotal = Math.max(1, total);
  const angle = -118 + (236 / Math.max(1, safeTotal - 1)) * index;
  const radius = row.strong ? 158 : (row.opportunity ? 178 : 198);
  const rad = angle * Math.PI / 180;
  const x = 250 + Math.cos(rad) * radius;
  const y = 250 + Math.sin(rad) * radius;
  const tone = row.strong ? 'strong' : (row.opportunity ? 'middle' : 'weak');
  const code = normalizeObservationStockCode(row && row.code);
  const name = String(row && row.name || '').trim();
  const label = name ? `${code} ${name}` : code;

  return `
    <g
      class="structure-rhythm-relation-node ${tone}"
      style="--node-x:${x}px;--node-y:${y}px;"
      data-structure-rhythm-focus-stock="${formatText(code)}"
      data-structure-rhythm-focus-name="${formatText(name)}"
      role="button"
      tabindex="0"
    >
      <path class="structure-rhythm-relation-link" d="M 410 250 Q ${(410 + x) / 2} ${(250 + y) / 2 - 34} ${x} ${y}"></path>
      <circle cx="${x}" cy="${y}" r="${row.strong ? 28 : 23}"></circle>
      <text x="${x}" y="${y - 3}" text-anchor="middle">${formatText(code)}</text>
      <text x="${x}" y="${y + 13}" text-anchor="middle">${formatText(name.slice(0, 4))}</text>
      <title>${formatText(label)}</title>
    </g>
  `;
}

