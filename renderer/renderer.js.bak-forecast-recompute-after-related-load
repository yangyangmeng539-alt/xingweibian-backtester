  }

  const range = state.priceMax - state.priceMin;
  const rawY = range <= 0
    ? (state.pricePanel.top + state.pricePanel.bottom) / 2
    : state.pricePanel.bottom - ((value - state.priceMin) / range) * (state.pricePanel.bottom - state.pricePanel.top);

  return clamp(rawY, state.pricePanel.top, state.pricePanel.bottom);
