    if (!userResponse || !userResponse.ok) {
      setSupplyChainStatus(`用户二级产业链读取失败：${formatDisplayError(userResponse && userResponse.error)}`);
      return false;
    }

    const result = userResponse.result || {};
    supplyChainState.secondaryChains = Array.isArray(result.chains) ? result.chains : [];

    renderSupplyChainSecondaryList();

    const firstSecondary = supplyChainState.secondaryChains[0];
    const firstSecondaryId = firstSecondary ? String(firstSecondary.id || '').trim() : '';

