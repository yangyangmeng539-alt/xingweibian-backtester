function getMarketGraphEdgeClass(edge) {
  const relationType = String(edge && edge.relationType || '');

  if (relationType === 'shared_stock' || relationType === 'theme_member') {
    return 'is-theme';
  }

  if (relationType.includes('industry')) {
    return 'is-industry';
  }

  if (relationType.includes('concept')) {
