}

function getUiObservationForecastAdjustment(nodePredictionAnalysis) {
  if (!nodePredictionAnalysis || !nodePredictionAnalysis.ok) {
    return {
      ok: false,
      reason: 'NO_NODE_PREDICTION'
    };
  }

  const refinement = nodePredictionAnalysis.observationRefinement || null;

  if (!refinement || !refinement.ok) {
    return {
      ok: false,
      reason: 'NO_OBSERVATION_REFINEMENT'
    };
  }

  const projection = getNodePredictionMarketProjection(nodePredictionAnalysis);
  const predictionKind = String(
    projection && projection.ok && projection.predictionKind
      ? projection.predictionKind
      : deriveUiRawPredictionKind(nodePredictionAnalysis)
  );

  const confidence = Number(
    projection && projection.ok
      ? projection.confidence
      : nodePredictionAnalysis.confidence
  );

  const safeConfidence = Number.isFinite(confidence) ? clamp(confidence, 0, 1) : 0.3;
  const score = Number(refinement.score);
  const normalizedScore = Number.isFinite(score) ? clamp(score / 100, 0, 1) : 0.5;
  const type = String(refinement.type || '');
  const title = String(refinement.title || getUiPredictionKindLabel(predictionKind) || '结构校正');
  const tone = String(refinement.tone || '');

  let t20BiasPct = 0;
  let mode = 'neutral';

  if (
    predictionKind === 'RISK_PULLBACK'
    || predictionKind === 'RISK_REVERSAL'
    || predictionKind === 'RISK_WARNING'
    || predictionKind === 'SHORT_WINDOW_RISK'
    || tone === 'risk'
    || [
      'STRUCTURE_OVERHEATED',
      'LATE_CONFIRMATION',
      'PREHEAT_DECAY',
      'ISOLATED_NODE',
      'SHAPE_POSITION_RISK'
    ].includes(type)
  ) {
    mode = 'risk';
    t20BiasPct = -1.8 * (0.55 + normalizedScore * 0.45);
  } else if (predictionKind === 'TARGET_CATCHUP' || type === 'EXTERNAL_CONFIRMED_TARGET_WEAK') {
    mode = 'catchup';
    t20BiasPct = 2.4 * (0.45 + normalizedScore * 0.55);
  } else if (
    predictionKind === 'CHAIN_PREHEAT'
    || type === 'SUPPLY_CHAIN_PREHEAT'
    || type === 'RELATION_PREHEAT'
    || type === 'STRUCTURE_WARMING'
  ) {
    mode = 'preheat';
    t20BiasPct = 1.35 * (0.45 + normalizedScore * 0.55);
  } else if (
    predictionKind === 'EXTEND_UP'
    || type === 'TREND_CONTINUATION'
    || type === 'STRUCTURE_CONFIRMED'
  ) {
    mode = 'extend';
    t20BiasPct = 1.75 * (0.45 + normalizedScore * 0.55);
  } else if (predictionKind === 'LOW_REPAIR' || type === 'LOW_LEVEL_CONFIRMATION') {
    mode = 'repair';
    t20BiasPct = 1.15 * (0.45 + normalizedScore * 0.55);
  }

  const confidenceScale = safeConfidence >= 0.4
    ? 1
    : (safeConfidence >= 0.25 ? 0.78 : 0.58);

  t20BiasPct *= confidenceScale;

  if (isUiHostileMarket(nodePredictionAnalysis) && t20BiasPct > 0) {
    t20BiasPct *= 0.65;
  }

  const round = (value) => Math.round(Number(value || 0) * 100) / 100;
  const biasByDay = {
    3: round(t20BiasPct * 0.25),
    5: round(t20BiasPct * 0.42),
    10: round(t20BiasPct * 0.68),
    20: round(t20BiasPct)
  };

  return {
    ok: true,
    source: 'ui_observation_context_adjustment',
    mode,
    title,
    predictionKind,
    confidence: Math.round(safeConfidence * 1000) / 1000,
    score: Number.isFinite(score) ? Math.round(score * 10) / 10 : null,
    biasByDay,
    t20BiasPct: biasByDay[20],
    text: `${title}｜${getUiPredictionKindLabel(predictionKind)}｜T+20校正 ${formatPercent(biasByDay[20], 2)}`
  };
}

function getUiObservationForecastAdjustmentBiasPct(nodePredictionAnalysis, day, band = 'median') {
  const adjustment = nodePredictionAnalysis && nodePredictionAnalysis.observationForecastAdjustment && nodePredictionAnalysis.observationForecastAdjustment.ok
    ? nodePredictionAnalysis.observationForecastAdjustment
    : getUiObservationForecastAdjustment(nodePredictionAnalysis);

  if (!adjustment || !adjustment.ok) {
    return 0;
  }

  const normalizedDay = [3, 5, 10, 20].includes(Number(day))
    ? Number(day)
    : 20;

  const rawBias = Number(adjustment.biasByDay && adjustment.biasByDay[normalizedDay]);

  if (!Number.isFinite(rawBias)) {
    return 0;
  }

  const bandName = String(band || 'median');

  if (bandName === 'q1' || bandName === 'lower' || bandName === 'lowerQuartile') {
    return rawBias * 0.7;
  }

  if (bandName === 'q3' || bandName === 'upper' || bandName === 'upperQuartile') {
    return rawBias * 1.15;
  }

  return rawBias;
}


function getUiForecastPathDayKey(day) {
