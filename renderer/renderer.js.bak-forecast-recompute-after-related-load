function getComparisonRows(result) {
  const rows = result && result.comparison && Array.isArray(result.comparison.rows)
    ? result.comparison.rows
    : [];

  if (rows.length > 0) {
    const showLegacy = shouldShowLegacyComparison(result);
    const order = {
      [FINAL_DECISION_ALGO_VERSION]: 0,
      'buy-hold': 1,
      [V2_ALGO_VERSION]: 2,
      [LEGACY_ALGO_VERSION]: 3
    };

    return rows
      .filter((row) => {
        const algoVersion = String(row && row.algoVersion || '');

        if (algoVersion === LEGACY_ALGO_VERSION) {
          return showLegacy;
        }

        return algoVersion === FINAL_DECISION_ALGO_VERSION || algoVersion === 'buy-hold' || algoVersion === V2_ALGO_VERSION;
      })
      .map((row, index) => ({
        row,
        index
      }))
      .sort((left, right) => {
        const leftAlgo = String(left.row && left.row.algoVersion || '');
        const rightAlgo = String(right.row && right.row.algoVersion || '');
        const leftOrder = Object.prototype.hasOwnProperty.call(order, leftAlgo) ? order[leftAlgo] : 99;
        const rightOrder = Object.prototype.hasOwnProperty.call(order, rightAlgo) ? order[rightAlgo] : 99;

        if (leftOrder !== rightOrder) {
          return leftOrder - rightOrder;
        }

        return left.index - right.index;
      })
      .map((item) => item.row);
  }

  const finalModel = getFinalDecisionModel(result);
  const fallbackRows = finalModel
    ? [{
      algoVersion: finalModel.algoVersion || finalModel.modelId,
      name: finalModel.modelName || DECISION_CHAIN_NAME,
      returnPct: finalModel.metrics && finalModel.metrics.netReturnPct,
      tradeCount: finalModel.metrics && finalModel.metrics.tradeCount,
      winRatePct: finalModel.metrics && finalModel.metrics.winRatePct,
      maxDrawdownPct: finalModel.metrics && finalModel.metrics.maxDrawdownPct,
      endingCapital: finalModel.metrics && finalModel.metrics.endingCapital
    }]
    : [];

  if (result && result.buyHold) {
    fallbackRows.push({
      algoVersion: 'buy-hold',
      name: '买入持有',
      returnPct: result.buyHold.returnPct,
      tradeCount: 1,
      winRatePct: result.buyHold.returnPct > 0 ? 100 : 0,
      maxDrawdownPct: 0,
      endingCapital: result.buyHold.endingCapital
    });
  }

  const v2Model = getModelByAlgoVersion(result, V2_ALGO_VERSION);

  if (v2Model && v2Model.metrics) {
    fallbackRows.push({
      algoVersion: V2_ALGO_VERSION,
      name: '形位变 V2 旧策略对照',
      returnPct: v2Model.metrics.netReturnPct,
      tradeCount: v2Model.metrics.tradeCount,
      winRatePct: v2Model.metrics.winRatePct,
      maxDrawdownPct: v2Model.metrics.maxDrawdownPct,
      endingCapital: v2Model.metrics.endingCapital
    });
  }

  return fallbackRows;
}

function getComparisonSourceModel(result, row) {
  if (!row || row.algoVersion === 'buy-hold') {
    return null;
  }

  return (
    getModelByAlgoVersion(result, row.algoVersion) ||
    getModelById(result, row.algoVersion) ||
    null
  );
}

function getComparisonNetPnl(result, row) {
  const initialCapital = Number(result && result.options && result.options.initialCapital);
  const endingCapital = Number(row && row.endingCapital);

  if (!Number.isFinite(initialCapital) || !Number.isFinite(endingCapital)) {
    return 0;
  }

  return endingCapital - initialCapital;
}

function renderComparisonRows(result) {
  return getComparisonRows(result).map((row) => {
    const model = getComparisonSourceModel(result, row);
    const metrics = model && model.metrics ? model.metrics : {};
    const isBuyHold = row.algoVersion === 'buy-hold';
    const netPnl = isBuyHold ? getComparisonNetPnl(result, row) : Number(metrics.netPnl || 0);
    const returnPct = Number(row.returnPct);
    const rowName = row.algoVersion === FINAL_DECISION_ALGO_VERSION
      ? '象位归纳法评级模型'
      : (row.algoVersion === V2_ALGO_VERSION ? '形位变 V2 旧策略对照' : (row.name || row.algoVersion));
    const displayName = `${rowName}（收益 ${formatPercent(returnPct)}）`;

    return `
      <tr>
        <td>${formatText(displayName)}</td>
        <td>${formatNumber(isBuyHold ? row.tradeCount : metrics.tradeCount, 0)}</td>
        <td>${formatPercent(isBuyHold ? row.winRatePct : metrics.winRatePct)}</td>
        <td class="${moneyClass(isBuyHold ? returnPct : metrics.averageReturnPct)}">${formatPercent(isBuyHold ? returnPct : metrics.averageReturnPct)}</td>
        <td class="${moneyClass(isBuyHold ? returnPct : metrics.medianReturnPct)}">${formatPercent(isBuyHold ? returnPct : metrics.medianReturnPct)}</td>
        <td class="negative">${formatPercent(isBuyHold ? row.maxDrawdownPct : metrics.maxDrawdownPct)}</td>
        <td class="${moneyClass(metrics.maxSingleLoss)}">${isBuyHold ? '-' : formatNumber(metrics.maxSingleLoss)}</td>
        <td>${isBuyHold ? '-' : formatNumber(metrics.averageHoldDays)}</td>
        <td class="${moneyClass(isBuyHold ? netPnl : metrics.grossPnl)}">${formatNumber(isBuyHold ? netPnl : metrics.grossPnl)}</td>
        <td class="${moneyClass(netPnl)}">${formatNumber(netPnl)}</td>
        <td>${isBuyHold ? '0.00' : formatNumber(metrics.totalFees)}</td>
      </tr>
    `;
  }).join('');
}

function renderReturnComparisonSummary(result) {
