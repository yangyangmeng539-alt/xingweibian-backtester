function getForecastOverlayMatrixProgressInfo(matrixStatus) {
  if (!matrixStatus) {
    return {
      ok: false,
      completed: 0,
      total: 0,
      loading: false,
      text: ''
    };
  }

  const successCount = Number(
    matrixStatus.loaded
    ?? matrixStatus.success
    ?? matrixStatus.successCount
    ?? matrixStatus.done
    ?? matrixStatus.current
    ?? matrixStatus.sampleLoaded
    ?? matrixStatus.sampleDone
  );

  const failedCount = Number(
    matrixStatus.failed
    ?? matrixStatus.failedCount
    ?? matrixStatus.errorCount
    ?? 0
  );

  const total = Number(
    matrixStatus.total
    ?? matrixStatus.totalCount
    ?? matrixStatus.sampleTotal
    ?? matrixStatus.totalSample
    ?? matrixStatus.totalSamples
  );

  if (Number.isFinite(successCount) && Number.isFinite(total) && total > 0) {
    const completedRaw = successCount + (Number.isFinite(failedCount) ? failedCount : 0);
    const safeTotal = Math.max(0, Math.round(total));
    const safeCompleted = Math.max(0, Math.min(Math.round(completedRaw), safeTotal));

    return {
      ok: true,
      completed: safeCompleted,
      total: safeTotal,
      loading: matrixStatus.loading === true && safeCompleted < safeTotal,
      text: `${safeCompleted} / ${safeTotal}`
    };
  }

  const message = String(matrixStatus.message || '');

  const successFailedTotalMatch = message.match(/成功\s*(\d+)[\s\S]*?失败\s*(\d+)[\s\S]*?总样本\s*(\d+)/);

  if (successFailedTotalMatch) {
    const success = Number(successFailedTotalMatch[1]);
    const failed = Number(successFailedTotalMatch[2]);
    const safeTotal = Number(successFailedTotalMatch[3]);
    const safeCompleted = Math.max(0, Math.min(success + failed, safeTotal));

    return {
      ok: true,
      completed: safeCompleted,
      total: safeTotal,
      loading: matrixStatus.loading === true && safeCompleted < safeTotal,
      text: `${safeCompleted} / ${safeTotal}`
    };
  }

  const slashMatch = message.match(/(\d+)\s*\/\s*(\d+)/);

  if (slashMatch) {
    const safeCompleted = Number(slashMatch[1]);
    const safeTotal = Number(slashMatch[2]);

    return {
      ok: true,
      completed: safeCompleted,
      total: safeTotal,
      loading: matrixStatus.loading === true && safeCompleted < safeTotal,
      text: `${safeCompleted} / ${safeTotal}`
    };
  }

  return {
    ok: false,
    completed: 0,
    total: 0,
    loading: Boolean(matrixStatus.loading),
    text: ''
  };
}

