  }[modelId] || '#b9c6df';
}

function getChartPoint(index, value, total, minValue, maxValue, width, height, padding) {
  const x = total <= 1
    ? width / 2
    : padding.left + (index / (total - 1)) * (width - padding.left - padding.right);
  const range = maxValue - minValue;
  const y = range <= 0
    ? height / 2
    : height - padding.bottom - ((value - minValue) / range) * (height - padding.top - padding.bottom);

  return {
    x,
    y
  };
}

