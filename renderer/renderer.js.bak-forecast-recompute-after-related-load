  if (!pendingForecastActualOverlay) {
    return;
  }

  if (!activeNodePredictionAnalysis || !activeNodePredictionAnalysis.ok) {
    schedulePendingForecastActualOverlayRender(160);
    return;
  }

  const activeDate = normalizeTimelineDate(activeNodePredictionAnalysis.clickedDate || activeNodePredictionDate);
  const pendingDate = normalizeTimelineDate(pendingForecastActualDate);

  if (pendingDate && activeDate && pendingDate !== activeDate) {
    clearPendingForecastActualOverlay();
    return;
  }

  if (!interactiveCurveState || !interactiveCurveState.svg) {
    schedulePendingForecastActualOverlayRender(160);
    return;
  }

  renderForecastOverlay(activeNodePredictionAnalysis);
  renderForecastZoomInset(activeNodePredictionAnalysis);
