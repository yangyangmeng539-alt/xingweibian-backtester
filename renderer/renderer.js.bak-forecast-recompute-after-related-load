  };
}

function getEffectiveMarketGraphLabelMode(nodeCount) {
  const isFocusView = marketGraphState.viewPreset === 'focus' || marketGraphState.viewPreset === 'stockFocus';

  if (isFocusView && marketGraphState.labelMode === 'all' && nodeCount > 70) {
    return 'focusCompact';
  }

  if (marketGraphState.labelMode === 'all' && nodeCount > 300) {
    return 'important';
  }

  return marketGraphState.labelMode || 'important';
}

function getMarketGraphLabelPriority(node) {
  return Number(node && (
    node.labelPriority ||
    node.relationScore ||
    node.sharedStockCount ||
    node.weight ||
    node.degree ||
    0
  )) || 0;
}

function isMarketGraphFocusView() {
  return marketGraphState.viewPreset === 'focus' || marketGraphState.viewPreset === 'stockFocus';
}

function shouldShowMarketGraphLabel(node, nodeCount, effectiveLabelMode) {
  if (effectiveLabelMode === 'none') {
    return false;
  }

  const focusView = isMarketGraphFocusView();
  const focusCode = getUnifiedStockFocusCode();
  const nodeCode = getMarketGraphNodeStockCode(node);
  const priority = getMarketGraphLabelPriority(node);
  const selectedOrHovered = node && (
    node.id === marketGraphState.selectedNodeId ||
    node.id === marketGraphState.hoverNodeId
  );

  if (focusView) {
    if (focusCode && nodeCode && nodeCode === focusCode) {
      return true;
    }

    if (selectedOrHovered) {
      return true;
    }

    if (node.type === 'industry' || node.type === 'theme') {
      return true;
    }

    if (node.type === 'concept') {
      return Boolean(node.importantLabel) || priority >= 520 || Number(node.weight) >= 1.1;
    }

    if (isMarketGraphBoardType(node.type)) {
      return Boolean(node.importantLabel) || priority >= 560;
    }

    if (node.type === 'stock') {
      return Boolean(node.relatedToFocus) && priority >= 684;
    }

    return false;
  }

  if (effectiveLabelMode === 'all') {
    return true;
  }

  if (node.type === 'stock' || node.type === 'industry' || node.type === 'theme') {
    return true;
  }

  if (node.type === 'concept') {
    return Boolean(node.importantLabel) || Number(node.sharedStockCount) >= 2 || Number(node.weight) >= 0.9;
  }

  return Boolean(node.importantLabel) || Number(node.degree) >= 8;
}

function getMarketGraphLabelText(label) {
  const text = String(label || '').trim();

  if (text.length <= 16) {
    return text;
  }

  return `${text.slice(0, 15)}…`;
}

function getMarketGraphLabelLines(label) {
  const text = String(label || '').trim();

  if (!text) {
    return ['-'];
  }

  if (text.length <= 7) {
    return [text];
  }

  if (text.length <= 14) {
    return [
      text.slice(0, 7),
      text.slice(7)
    ];
  }

  return [
    text.slice(0, 7),
    text.slice(7, 14),
    `${text.slice(14, 19)}…`
  ];
}

function isMarketGraphRelationLabelNode(node) {
  const type = String(node && node.type || '');

  return type === 'industry'
    || type === 'concept'
    || type === 'theme'
    || type === 'board'
    || type === 'other_board'
    || type === 'style_board'
    || type === 'region_board';
}

function getMarketGraphLabelPosition(position, radius, node) {
  if (position.labelAnchor === 'end') {
    return {
      x: position.x - radius - 9,
      y: position.y + 4,
      anchor: 'end',
      direction: 'side'
    };
  }

  if (position.labelAnchor === 'start') {
    return {
      x: position.x + radius + 9,
      y: position.y + 4,
      anchor: 'start',
      direction: 'side'
    };
  }

  if (isMarketGraphRelationLabelNode(node) || position.labelDirection === 'up') {
    return {
      x: position.x,
      y: position.y - radius - 11,
      anchor: 'middle',
      direction: 'up'
    };
  }

  return {
    x: position.x,
    y: position.y + radius + 15,
    anchor: 'middle',
    direction: 'down'
  };
}

function getMarketGraphLabelBox(labelPosition, lines) {
  const maxLineLength = Math.max(1, ...lines.map((line) => String(line || '').length));
  const width = Math.max(28, maxLineLength * 9.2 + 14);
  const height = lines.length * 12 + 7;

  let x = labelPosition.x - width / 2;

  if (labelPosition.anchor === 'start') {
    x = labelPosition.x - 3;
  } else if (labelPosition.anchor === 'end') {
    x = labelPosition.x - width + 3;
  }

  return {
    x,
    y: labelPosition.y - 10,
    width,
    height,
    anchor: labelPosition.anchor,
    direction: labelPosition.direction || 'down',
    lines
  };
}

function doMarketGraphLabelBoxesOverlap(left, right, padding = 5) {
  return !(
    left.x + left.width + padding < right.x ||
    right.x + right.width + padding < left.x ||
    left.y + left.height + padding < right.y ||
    right.y + right.height + padding < left.y
  );
}

function clampMarketGraphLabelBox(box, width, height) {
  box.x = clamp(box.x, 8, Math.max(8, width - box.width - 8));
  box.y = clamp(box.y, 34, Math.max(34, height - box.height - 8));
  return box;
}

function buildMarketGraphLabelBox(node, position, radius, width, height) {
  const rawLabel = String(node && (node.label || node.code || node.id) || '');
  const label = getMarketGraphLabelText(rawLabel);
  const lines = getMarketGraphLabelLines(label);
  const labelPosition = getMarketGraphLabelPosition(position, radius, node);
  const box = getMarketGraphLabelBox(labelPosition, lines);

  return clampMarketGraphLabelBox({
    ...box,
    node,
    label,
    labelPosition
  }, width, height);
}

function resolveMarketGraphLabelBoxes(boxes, width, height) {
  const ordered = boxes.slice().sort((left, right) => {
    const priorityDiff = (Number(right.node && right.node.labelPriority) || 0) - (Number(left.node && left.node.labelPriority) || 0);

    if (priorityDiff !== 0) {
      return priorityDiff;
    }

    const leftStock = left.node && left.node.type === 'stock' ? 1 : 0;
    const rightStock = right.node && right.node.type === 'stock' ? 1 : 0;

    if (leftStock !== rightStock) {
      return rightStock - leftStock;
    }

    return String(left.label || '').localeCompare(String(right.label || ''), 'zh-Hans-CN');
  });

  const placed = [];

  ordered.forEach((box) => {
    const current = { ...box };
    const direction = current.direction === 'up' ? -1 : 1;
    let attempt = 0;

    while (
      attempt < 18
      && placed.some((placedBox) => doMarketGraphLabelBoxesOverlap(current, placedBox, 6))
    ) {
      current.y += direction * 15;

      if (current.y < 34 || current.y + current.height > height - 8) {
        current.y -= direction * 30;
        current.x += attempt % 2 === 0 ? 18 : -18;
      }

      clampMarketGraphLabelBox(current, width, height);
      attempt += 1;
    }

    placed.push(current);
  });

  return placed;
}

function renderMarketGraphLabelBox(box) {
  const textX = box.anchor === 'start'
    ? box.x + 8
    : (
      box.anchor === 'end'
        ? box.x + box.width - 8
        : box.x + box.width / 2
    );
  const firstTextY = box.y + 11;
  const nodeType = String(box.node && box.node.type || '');
  const isStock = nodeType === 'stock';

  return `
    <g class="market-graph-label-box" pointer-events="none">
      <rect
        x="${box.x.toFixed(2)}"
        y="${box.y.toFixed(2)}"
        width="${box.width.toFixed(2)}"
        height="${box.height.toFixed(2)}"
        rx="6"
        ry="6"
        fill="rgba(3, 16, 35, 0.84)"
        stroke="rgba(0, 220, 255, 0.24)"
        stroke-width="1"
      />
      <text
        x="${textX.toFixed(2)}"
        y="${firstTextY.toFixed(2)}"
        text-anchor="${box.anchor}"
        fill="${isStock ? '#e9fbff' : '#cdefff'}"
        font-size="${isStock ? '9.8' : '9.4'}"
        font-weight="${isStock ? '650' : '600'}"
        stroke="rgba(0, 8, 20, 0.9)"
        stroke-width="2"
        paint-order="stroke fill"
      >
        ${box.lines.map((line, index) => `
          <tspan x="${textX.toFixed(2)}" dy="${index === 0 ? 0 : 12}">${escapeHtml(line)}</tspan>
        `).join('')}
      </text>
    </g>
  `;
}

function getMarketGraphGuideLabels(width) {
  if (marketGraphState.viewPreset === 'themeOverview') {
    return [
      { x: width / 2, text: '行业 / 概念 / 主题聚合', anchor: 'middle' },
      { x: width - 90, text: '边 = 共享股票数', anchor: 'end' }
    ];
  }

  if (marketGraphState.viewPreset === 'themeFocus') {
    return [
      { x: width * 0.42, text: '中心主题', anchor: 'middle' },
      { x: width * 0.42 + 220, text: '成员股票' },
      { x: width - 90, text: '相关主题', anchor: 'end' }
    ];
  }

  if (marketGraphState.viewPreset === 'focus' || marketGraphState.viewPreset === 'stockFocus') {
    return [
      { x: width / 2, text: '中心股票', anchor: 'middle' },
      { x: width / 2 - 170, text: '行业 / 概念' },
      { x: width - 90, text: '关联股票', anchor: 'end' }
    ];
  }

  if (marketGraphState.viewPreset === 'resonance') {
    return [
      { x: width / 2, text: '共享概念 / 共享行业', anchor: 'middle' },
      { x: width - 90, text: '连接股票', anchor: 'end' }
    ];
  }

  return [
    { x: 86, text: '股票' },
    { x: width * 0.48, text: '核心行业', anchor: 'middle' },
    { x: width - 90, text: '强概念', anchor: 'end' }
  ];
}


function getMarketGraphNodeFocusClass(node) {
  const focusCode = getUnifiedStockFocusCode();
  const code = getMarketGraphNodeStockCode(node);
  const classes = [];

  if (focusCode && code && code === focusCode) {
    classes.push('is-focus-primary');
  } else if (focusCode && node && node.relatedToFocus) {
    classes.push('is-focus-related');
  }

  if (focusCode && node && node.type !== 'stock') {
    const graph = marketGraphState.visibleGraph || { edges: [] };
    const focusNodeId = `stock:${focusCode}`;
    const directlyConnected = (graph.edges || []).some((edge) => (
      (edge.source === focusNodeId && edge.target === node.id) ||
      (edge.target === focusNodeId && edge.source === node.id)
    ));

    if (directlyConnected) {
      classes.push('is-focus-context');
    }
  }

  return classes.length ? ` ${classes.join(' ')}` : '';
}

function renderMarketGraphSvg() {
  if (!marketGraphSvgBox) {
    return;
  }

  const graph = enrichMarketGraphWithRelatedStockNodes(getFilteredMarketGraph());
  marketGraphState.visibleGraph = graph;
  renderMarketGraphSummary(buildMarketGraphVisibleStats(graph));

  if (!graph.nodes.length) {
    renderMarketGraphEmpty(marketGraphState.search ? '没有匹配的股票关系。' : '暂无可绘制的关系数据。');
    return;
  }

  if (graph.nodes.length > 2000) {
    renderMarketGraphEmpty('节点过多，建议搜索或筛选。');
    setMarketGraphLog(`当前节点 ${formatNumber(graph.nodes.length, 0)} 个，已暂停渲染；建议搜索或筛选。`);
    return;
  }

  const width = 1180;
  const height = 620;
  const positions = buildMarketGraphLayout(graph.nodes, width, height);
  const nodeIds = new Set(graph.nodes.map((node) => node.id));
  const effectiveLabelMode = getEffectiveMarketGraphLabelMode(graph.nodes.length);
  const showLabelWarning = marketGraphState.labelMode === 'all' && graph.nodes.length > 300;
  const edgeSvg = graph.edges
    .filter((edge) => nodeIds.has(edge.source) && nodeIds.has(edge.target))
    .map((edge) => {
      const source = positions.get(edge.source);
      const target = positions.get(edge.target);

      if (!source || !target) {
        return '';
      }

      return `
        <line
          class="market-graph-edge ${getMarketGraphEdgeClass(edge)}"
          data-edge-source="${escapeHtml(edge.source)}"
          data-edge-target="${escapeHtml(edge.target)}"
          x1="${source.x.toFixed(2)}"
          y1="${source.y.toFixed(2)}"
          x2="${target.x.toFixed(2)}"
          y2="${target.y.toFixed(2)}"
          style="stroke-width: ${Math.max(0.75, Math.min(2.8, Number(edge.weight) || 1)).toFixed(2)}px"
        />
      `;
    })
    .join('');
  const labelBoxes = resolveMarketGraphLabelBoxes(
    graph.nodes
      .map((node) => {
        const position = positions.get(node.id) || { x: width / 2, y: height / 2 };
        const radius = getMarketGraphNodeRadius(node, graph.nodes.length);
        const showLabel = shouldShowMarketGraphLabel(node, graph.nodes.length, effectiveLabelMode);

        if (!showLabel) {
          return null;
        }

        return buildMarketGraphLabelBox(node, position, radius, width, height);
      })
      .filter(Boolean),
    width,
    height
  );

  const labelSvg = labelBoxes.map(renderMarketGraphLabelBox).join('');

  const nodeSvg = graph.nodes.map((node) => {
    const position = positions.get(node.id) || { x: width / 2, y: height / 2 };
    const radius = getMarketGraphNodeRadius(node, graph.nodes.length);
    const selectedClass = node.id === marketGraphState.selectedNodeId ? ' is-selected' : '';
    const focusClass = getMarketGraphNodeFocusClass(node);
    const label = String(node.label || node.code || node.id);
    const memberText = Number(node.memberStockCount) > 0
      ? ` / 成员 ${formatNumber(node.memberStockCount, 0)}`
      : '';
    const primaryGlow = focusClass.includes('is-focus-primary')
      ? `<circle class="market-graph-focus-core" cx="${position.x.toFixed(2)}" cy="${position.y.toFixed(2)}" r="${(radius + 11).toFixed(2)}" />`
      : '';
    const relatedGlow = focusClass.includes('is-focus-related') || focusClass.includes('is-focus-context')
      ? `<circle class="market-graph-focus-ring" cx="${position.x.toFixed(2)}" cy="${position.y.toFixed(2)}" r="${(radius + 6).toFixed(2)}" />`
      : '';

    return `
      <g
        class="market-graph-node market-graph-node-${escapeHtml(node.type)}${selectedClass}${focusClass}"
        data-node-id="${escapeHtml(node.id)}"
        tabindex="0"
        role="button"
        aria-label="${escapeHtml(label)}"
      >
        <title>${escapeHtml(`${label} / ${getMarketGraphTypeLabel(node.type)}${memberText}`)}</title>
        ${primaryGlow}
        ${relatedGlow}
        <circle cx="${position.x.toFixed(2)}" cy="${position.y.toFixed(2)}" r="${radius}" />
      </g>
    `;
  }).join('');

  marketGraphSvgBox.innerHTML = `
    <svg class="market-graph-svg" viewBox="0 0 ${width} ${height}" role="img" aria-label="市场态星图 V0">
      <rect class="market-graph-background" x="0" y="0" width="${width}" height="${height}" fill="rgba(2, 8, 20, 0.35)" />
      <g class="market-graph-guide-layer" aria-hidden="true">
        ${getMarketGraphGuideLabels(width).map((item) => (
          `<text x="${Number(item.x).toFixed(0)}" y="24" text-anchor="${item.anchor || 'start'}">${escapeHtml(item.text)}</text>`
        )).join('')}
      </g>
      <g class="market-graph-edge-layer">${edgeSvg}</g>
      <g class="market-graph-node-layer">${nodeSvg}</g>
      <g class="market-graph-label-layer">${labelSvg}</g>
      ${showLabelWarning ? '<text class="market-graph-warning" x="510" y="540" text-anchor="middle">节点过多，不建议显示全部标签，已临时切回重要标签。</text>' : ''}
    </svg>
  `;

  const svg = marketGraphSvgBox.querySelector('svg');
  if (svg) {
    svg.addEventListener('click', (event) => {
      if (event.target === svg || event.target.classList.contains('market-graph-background')) {
        returnMarketGraphOverview();
      }
    });
  }

  marketGraphSvgBox.querySelectorAll('[data-node-id]').forEach((nodeElement) => {
    nodeElement.addEventListener('click', (event) => {
      event.stopPropagation();
      selectMarketGraphNode(nodeElement.getAttribute('data-node-id'));
    });
    nodeElement.addEventListener('mouseenter', () => {
      hoverMarketGraphNode(nodeElement.getAttribute('data-node-id'));
    });
    nodeElement.addEventListener('mouseleave', clearMarketGraphHover);
    nodeElement.addEventListener('focus', () => {
      hoverMarketGraphNode(nodeElement.getAttribute('data-node-id'));
    });
    nodeElement.addEventListener('blur', clearMarketGraphHover);
    nodeElement.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        selectMarketGraphNode(nodeElement.getAttribute('data-node-id'));
      }
    });
  });

  applyMarketGraphHighlight(marketGraphState.hoverNodeId || marketGraphState.selectedNodeId);
  renderMarketGraphDetail(marketGraphState.hoverNodeId || marketGraphState.selectedNodeId || '');

  if (showLabelWarning) {
    setMarketGraphLog('节点过多，不建议显示全部标签，已临时显示重要标签。');
  }
}

function getMarketGraphNodeById(graph, nodeId) {
  return (graph.nodes || []).find((node) => node.id === nodeId) || null;
}

function getMarketGraphConnectedContext(nodeId, graph) {
  const nodeById = new Map((graph.nodes || []).map((item) => [item.id, item]));
  const connectedEdges = (graph.edges || []).filter((edge) => edge.source === nodeId || edge.target === nodeId);
  const connectedNodes = connectedEdges
    .map((edge) => nodeById.get(edge.source === nodeId ? edge.target : edge.source))
    .filter(Boolean);

  return {
    nodeById,
    connectedEdges,
    connectedNodes
  };
}

function uniqueMarketGraphLabels(nodes) {
  const seen = new Set();

  return nodes
    .map((node) => String(node && (node.label || node.code || node.id) || '').trim())
    .filter((label) => {
      if (!label || seen.has(label)) {
        return false;
      }

      seen.add(label);
      return true;
    });
}

function renderMarketGraphDetailRows(rows) {
  return rows.map((row) => `
    <div class="market-graph-detail-row">
      <span>${escapeHtml(row.label)}</span>
      <b>${escapeHtml(row.value || '-')}</b>
    </div>
  `).join('');
}

function renderMarketGraphTextList(items, className, emptyText) {
  const list = Array.isArray(items) ? items.filter(Boolean) : [];

  if (!list.length) {
    return `<div class="${className}"><div>${escapeHtml(emptyText || '-')}</div></div>`;
  }

  return `
    <div class="${className}">
      ${list.map((item) => `<div>${escapeHtml(item)}</div>`).join('')}
    </div>
  `;
}

function getMarketGraphRelationSummaryList(summary, key, fallback) {
  const values = summary && Array.isArray(summary[key]) ? summary[key] : null;

  if (values) {
    return values;
  }

  return Array.isArray(fallback) ? fallback : [];
}

function renderMarketGraphReasonRows(reasonItems) {
  const list = Array.isArray(reasonItems)
    ? reasonItems.map((item) => {
      if (typeof item === 'string') {
        return item;
      }

      return `${item.label || '同花顺'}：${item.reason || ''}`;
    }).filter(Boolean)
    : [];

  return `
    <details class="market-graph-detail-collapse">
      <summary>同花顺 reason（${formatNumber(list.length, 0)}）</summary>
      ${renderMarketGraphTextList(list, 'market-graph-reason-list', '暂无同花顺 reason。')}
    </details>
  `;
}

function renderMarketGraphRawRelationSections(node) {
  const cache = marketGraphState.rawRelationCache[node.code] || null;

  if (!cache) {
    return '';
  }

  if (cache.loading) {
    return '<div class="market-graph-detail-empty">正在读取全部关系...</div>';
  }

  if (cache.error) {
    return `<div class="market-graph-detail-empty">全部关系读取失败：${escapeHtml(cache.error)}</div>`;
  }

  const item = cache.item || {};
  const ths = Array.isArray(item.conceptThs) ? item.conceptThs : [];
  const plates = Array.isArray(item.plateEast) ? item.plateEast : [];
  const thsTexts = ths.map((concept) => {
    const name = concept && (concept.name || concept.concept_code) || '-';
    return concept && concept.reason ? `${name}：${concept.reason}` : String(name);
  });
  const plateTexts = plates.map((plate) => {
    const type = plate && plate.plate_type ? plate.plate_type : '板块';
    const name = plate && (plate.plate_name || plate.plate_code) || '-';
    return `${type}：${name}`;
  });

  return `
    <h4>全部同花顺概念</h4>
    ${renderMarketGraphTextList(thsTexts, 'market-graph-member-list', '暂无同花顺概念。')}
    <h4>全部东方财富关系</h4>
    ${renderMarketGraphTextList(plateTexts, 'market-graph-member-list', '暂无东方财富关系。')}
  `;
}

function renderMarketGraphStockDetail(node, graph) {
  const { connectedEdges, connectedNodes } = getMarketGraphConnectedContext(node.id, graph);
  const summary = node.relationSummary || {};
  const industries = uniqueMarketGraphLabels(connectedNodes.filter((item) => item.type === 'industry'));
  const concepts = uniqueMarketGraphLabels(connectedNodes.filter((item) => item.type === 'concept'));
  const boards = uniqueMarketGraphLabels(connectedNodes.filter((item) => (
    item.type === 'region_board' ||
    item.type === 'style_board' ||
    item.type === 'other_board'
  )));
  const strongConcepts = getMarketGraphRelationSummaryList(summary, 'strongConcepts', concepts);
  const summaryIndustries = getMarketGraphRelationSummaryList(summary, 'industries', industries);
  const summaryBoards = getMarketGraphRelationSummaryList(summary, 'boards', boards);
  const reasons = Array.isArray(summary.thsReasons) && summary.thsReasons.length
    ? summary.thsReasons
    : connectedEdges
      .map((edge) => edge.reason)
      .filter(Boolean)
      .slice(0, 5);
  const showAllLabel = marketGraphState.rawRelationCache[node.code] ? '刷新全部关系' : '显示全部关系';
  const hiddenStyleRegionCount = summary.hiddenStyleRegionCount || 0;
  const hiddenWeakCount = summary.hiddenWeakCount || 0;
  const industryPaths = Array.isArray(summary.industryPaths) ? summary.industryPaths : [];
  const displayedRelations = Array.isArray(summary.displayedRelations) ? summary.displayedRelations : [];
  const allIndustries = Array.isArray(summary.allIndustries) ? summary.allIndustries : summaryIndustries;
  const allConcepts = Array.isArray(summary.allConcepts) ? summary.allConcepts : strongConcepts;

  return `
    <h3>${escapeHtml(node.label || node.code || '-')}</h3>
    ${renderMarketGraphDetailRows([
      { label: '股票代码', value: node.code || '-' },
      { label: '股票名称', value: node.label || '-' },
      { label: '图上强关系', value: displayedRelations.join('、') },
      { label: '所属行业', value: summaryIndustries.join('、') },
      { label: '强概念', value: strongConcepts.join('、') },
      { label: '板块', value: summaryBoards.join('、') },
      { label: '隐藏噪音', value: formatNumber(summary.hiddenNoiseCount || 0, 0) },
      { label: '隐藏地域/风格/指数', value: formatNumber(hiddenStyleRegionCount, 0) },
      { label: '隐藏弱关系', value: formatNumber(hiddenWeakCount, 0) },
      { label: '当前边数', value: formatNumber(connectedEdges.length, 0) }
    ])}
    <h4>已折叠行业路径</h4>
    ${renderMarketGraphTextList(industryPaths, 'market-graph-member-list', '暂无折叠行业路径。')}
    <h4>全部行业 / 概念</h4>
    ${renderMarketGraphTextList([
      allIndustries.length ? `行业：${allIndustries.join('、')}` : '',
      allConcepts.length ? `概念：${allConcepts.join('、')}` : ''
    ], 'market-graph-member-list', '暂无行业/概念。')}
    ${renderMarketGraphReasonRows(reasons)}
    <button class="market-graph-detail-action" type="button" data-market-graph-expand-stock="${escapeHtml(node.code || '')}">展开当前股票全部关系到图上</button>
    <button class="market-graph-detail-action" type="button" data-market-graph-show-all="${escapeHtml(node.code || '')}">${escapeHtml(showAllLabel)}</button>
    ${renderMarketGraphRawRelationSections(node)}
  `;
}

function formatMarketGraphStockMember(stock) {
  if (typeof stock === 'string') {
    return stock;
  }

  const code = stock && stock.code ? String(stock.code) : '';
  const name = stock && stock.name ? String(stock.name) : '';
  return `${code || '-'} ${name}`.trim();
}

function getMarketGraphRelatedThemes(node, graph) {
  if (Array.isArray(node.relatedThemesPreview) && node.relatedThemesPreview.length) {
    return node.relatedThemesPreview;
  }

  const { nodeById, connectedEdges } = getMarketGraphConnectedContext(node.id, graph);

  return connectedEdges
    .filter((edge) => edge.relationType === 'shared_stock')
    .map((edge) => {
      const otherId = edge.source === node.id ? edge.target : edge.source;
      const other = nodeById.get(otherId);

      if (!other) {
        return null;
      }

      return {
        id: other.id,
        label: other.label || other.id,
        type: other.type,
        sharedStockCount: Number(edge.sharedStockCount) || 0,
        sharedStocksPreview: edge.sharedStocksPreview || []
      };
    })
    .filter(Boolean)
    .sort((left, right) => (Number(right.sharedStockCount) || 0) - (Number(left.sharedStockCount) || 0))
    .slice(0, 20);
}

function renderMarketGraphThemeDetail(node, graph) {
  const { connectedEdges } = getMarketGraphConnectedContext(node.id, graph);
  const stats = marketGraphState.graph && marketGraphState.graph.stats ? marketGraphState.graph.stats : {};
  const memberSource = Array.isArray(node.memberStocks) && node.memberStocks.length
    ? node.memberStocks
    : (Array.isArray(node.memberStocksPreview) ? node.memberStocksPreview : []);
  const focusedThemeId = marketGraphState.focusThemeId || stats.focusedThemeId || '';
  const memberLimit = marketGraphState.viewPreset === 'themeFocus' && node.id === focusedThemeId
    ? memberSource.length
    : 50;
  const memberTexts = memberSource
    .slice(0, memberLimit)
    .map(formatMarketGraphStockMember);
  const relatedThemes = getMarketGraphRelatedThemes(node, graph).slice(0, 20);
  const relatedTexts = relatedThemes.map((item) => (
    `${item.label || item.id}（${getMarketGraphTypeLabel(item.type)}，共享 ${formatNumber(item.sharedStockCount || 0, 0)} 只）`
  ));
  const shownMemberCount = Math.min(memberTexts.length, Number(node.memberStockCount) || memberTexts.length);
  const memberHint = Number(node.memberStockCount) > shownMemberCount
    ? `当前列表显示 ${formatNumber(shownMemberCount, 0)} / ${formatNumber(node.memberStockCount, 0)}`
    : `当前列表显示 ${formatNumber(shownMemberCount, 0)}`;

  return `
    <h3>${escapeHtml(node.label || '-')}</h3>
    ${renderMarketGraphDetailRows([
      { label: '主题名称', value: node.label || '-' },
      { label: '类型', value: getMarketGraphTypeLabel(node.type) },
      { label: '成员股票数', value: formatNumber(node.memberStockCount || memberTexts.length || 0, 0) },
      { label: '关联主题数', value: formatNumber(relatedThemes.length, 0) },
      { label: '关系计数', value: formatNumber(node.relationCount || connectedEdges.length || 0, 0) },
      { label: '权重', value: formatNumber(node.weight || 0, 2) },
      { label: '数据来源', value: node.source || '-' }
    ])}
    <h4>成员股票</h4>
    <div class="market-graph-detail-empty">${escapeHtml(memberHint)}</div>
    ${renderMarketGraphTextList(memberTexts, 'market-graph-member-list', '暂无成员股票。')}
    <h4>关联主题前 20</h4>
    ${renderMarketGraphTextList(relatedTexts, 'market-graph-member-list', '暂无关联主题。')}
    <button class="market-graph-detail-action" type="button" data-market-graph-expand-theme="${escapeHtml(node.id || '')}">展开该主题股票</button>
  `;
}

function renderMarketGraphGroupDetail(node, graph) {
  if (isMarketGraphThemeType(node.type)) {
    return renderMarketGraphThemeDetail(node, graph);
  }

  const { nodeById, connectedEdges } = getMarketGraphConnectedContext(node.id, graph);
  const members = new Map();

  connectedEdges.forEach((edge) => {
    const otherId = edge.target === node.id ? edge.source : edge.target;
    const other = nodeById.get(otherId);

    if (other && other.type === 'stock') {
      members.set(other.id, other);
    }
  });

  const memberList = Array.from(members.values());
  const memberTexts = memberList
    .slice(0, 30)
    .map((item) => `${item.code || '-'} ${item.label || ''}`.trim());

  return `
    <h3>${escapeHtml(node.label || '-')}</h3>
    ${renderMarketGraphDetailRows([
      { label: '节点类型', value: getMarketGraphTypeLabel(node.type) },
      { label: '节点代码', value: node.code || node.plateCode || node.conceptCode || '-' },
      { label: '数据来源', value: node.source || '-' },
      { label: '成员股票数', value: formatNumber(memberList.length || node.memberStockCount || 0, 0) },
      { label: '连接边数量', value: formatNumber(connectedEdges.length, 0) },
      { label: '共享节点', value: node.isShared ? '是' : '否' },
      { label: '权重', value: formatNumber(node.weight || 0, 2) }
    ])}
    ${renderMarketGraphTextList(memberTexts, 'market-graph-member-list', '暂无成员股票。')}
  `;
}

function renderMarketGraphViewIntro() {
  const preset = marketGraphState.viewPreset || 'themeOverview';
  const titleMap = {
    themeOverview: '市场总览',
    themeFocus: '主题展开',
    stockFocus: '股票聚焦',
    resonance: '共振模式',
    focus: '聚焦模式',
    overview: '概览模式',
    raw: '原始调试'
  };
  const descriptionMap = {
