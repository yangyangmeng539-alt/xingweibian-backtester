    }
  };
}

async function focusSupplyChainOnStock(code, options = {}) {
  const normalizedCode = setUnifiedStockFocus(code, options);

  if (!normalizedCode) {
    return {
      ok: false,
      error: '股票代码无效。'
    };
  }

  if (!window.xwbApi || typeof window.xwbApi.queryStockSupplyChain !== 'function') {
    return {
      ok: false,
      error: '产业链股票归属 API 不可用。'
    };
  }

  const response = await window.xwbApi.queryStockSupplyChain({
    code: normalizedCode,
    maxChains: SUPPLY_CHAIN_MAX_CHAINS
  });

  if (!response || !response.ok) {
    return {
      ok: false,
      error: `股票产业链归属读取失败：${formatDisplayError(response && response.error)}`
    };
  }

  const stockResult = response.stock || null;
  supplyChainState.stockResult = stockResult;
  renderSupplyChainStockResult(stockResult);

  if (!stockResult || !stockResult.found) {
    renderSupplyChainLayers(supplyChainState.selectedChain);
    return {
      ok: false,
      error: `未找到股票 ${normalizedCode} 的产业链归属。`
    };
  }

  const assignments = Array.isArray(stockResult.assignments) ? stockResult.assignments : [];
  const firstAssignment = assignments[0] || null;
  const chainId = firstAssignment ? String(firstAssignment.chainId || '').trim() : '';

  if (!chainId) {
    renderSupplyChainLayers(supplyChainState.selectedChain);
    return {
      ok: false,
      error: `股票 ${normalizedCode} 没有可用的产业链 chainId。`
    };
  }

  if (firstAssignment.parentId) {
    supplyChainState.selectedPrimaryId = firstAssignment.parentId;
    renderSupplyChainPrimaryList();
  }

  if (supplyChainState.selectedChainId !== chainId || !supplyChainState.selectedChain || !supplyChainState.selectedChain.found) {
    await selectSupplyChainChain(chainId);
  } else {
    renderSupplyChainLayers(supplyChainState.selectedChain);
  }

  updateSupplyChainGraphDetail({
    type: 'stock',
    layerKey: firstAssignment.layer || '',
    stock: {
      ...stockResult,
      layerKey: firstAssignment.layer || '',
      layerLabel: firstAssignment.layerName || '',
      chainId,
      chainName: firstAssignment.chainName || ''
    }
  });

  return {
    ok: true,
    stock: stockResult,
    assignment: firstAssignment,
    chainId
  };
}

async function focusStockAcrossMarketAndSupplyChain(code, options = {}) {
  const normalizedCode = setUnifiedStockFocus(code, options);

  if (!normalizedCode) {
    setMarketGraphLog('无法联动：股票代码无效。');
    return {
      ok: false,
      error: '股票代码无效。'
    };
  }

  const seq = stockFocusLinkState.seq + 1;
  stockFocusLinkState.seq = seq;
  stockFocusLinkState.updating = true;

  try {
    if (!options.skipMarketGraph) {
      marketGraphState.viewPreset = 'stockFocus';
      marketGraphState.focusCode = normalizedCode;
      marketGraphState.focusThemeId = '';
      marketGraphState.expandStockCode = options.expand ? normalizedCode : '';
      marketGraphState.search = '';
      marketGraphState.hideWeak = options.expand ? false : marketGraphState.hideWeak;
      marketGraphState.showBoards = options.expand ? true : marketGraphState.showBoards;
      marketGraphState.showStyleRegion = options.expand ? true : marketGraphState.showStyleRegion;
      marketGraphState.labelMode = 'important';
      marketGraphState.selectedNodeId = `stock:${normalizedCode}`;
      marketGraphState.hoverNodeId = '';
      updateMarketGraphControls();
      await loadMarketGraph('full');

      if (seq !== stockFocusLinkState.seq) {
        return {
          ok: false,
          stale: true
        };
      }

      marketGraphState.selectedNodeId = `stock:${normalizedCode}`;
      marketGraphState.hoverNodeId = '';
      applyMarketGraphHighlight(marketGraphState.selectedNodeId);
      renderMarketGraphDetail(marketGraphState.selectedNodeId);
    }

    let supplyResult = null;

    if (!options.skipSupplyChain) {
      supplyResult = await focusSupplyChainOnStock(normalizedCode, options);
    } else {
      renderSupplyChainLayers(supplyChainState.selectedChain);
    }

    const supplyText = supplyResult && supplyResult.ok && supplyResult.assignment
      ? `产业链：${supplyResult.assignment.parentName || '-'} / ${supplyResult.assignment.chainName || '-'} / ${supplyResult.assignment.layerName || '-'}`
      : '产业链：暂无归属或读取失败';

    setMarketGraphLog(`焦点联动：${normalizedCode}｜关系图已聚焦｜${supplyText}`);
    setSupplyChainStatus(`焦点联动：${normalizedCode}。${supplyText}`);

    return {
      ok: true,
      code: normalizedCode,
      supplyChain: supplyResult
    };
  } catch (error) {
    const message = formatDisplayError(error && error.message ? error.message : error);
    setMarketGraphLog(`焦点联动失败：${message}`);
    setSupplyChainStatus(`焦点联动失败：${message}`);
    return {
      ok: false,
      error: message
    };
  } finally {
    if (seq === stockFocusLinkState.seq) {
      stockFocusLinkState.updating = false;
    }
  }
}

function getMarketGraphNodeStockCode(node) {
  if (!node) {
    return '';
  }

  return normalizeObservationStockCode(node.code || node.stockCode || node.symbol || node.id);
}

function getMarketGraphNodeStockName(node) {
  if (!node) {
    return '';
  }

  return String(node.label || node.name || node.stockName || node.shortName || node.code || '').trim();
}

function getMarketGraphRelationNodeLabel(node) {
  if (!node) {
    return '';
  }

  return String(node.label || node.name || node.conceptName || node.industryName || node.boardName || node.id || '').trim();
}

function getMarketGraphRelationNodeType(node) {
  if (!node) {
    return 'unknown';
  }

  const type = String(node.type || '').trim();

  if (type) {
    return type;
  }

  if (node.conceptCode) {
    return 'concept';
  }

  if (node.industryCode) {
    return 'industry';
  }

  if (node.plateCode || node.boardCode) {
    return 'board';
  }

  return 'unknown';
}

function getMarketGraphRelationTypeWeight(type) {
  const cleanType = String(type || '').trim();

  return MARKET_GRAPH_STOCK_RELATION_TYPE_WEIGHTS[cleanType] || 1;
}

function getMarketGraphEdgeWeight(edge) {
  const value = Number(edge && (edge.weight || edge.score || edge.strength));

  if (!Number.isFinite(value) || value <= 0) {
    return 1;
  }

  return Math.max(0.25, Math.min(value, 3));
}

function getMarketGraphRelationMemberPenalty(memberCount) {
  const count = Math.max(1, Number(memberCount || 1));

  return Math.min(1, 8 / Math.sqrt(count));
}

function getMarketGraphRelationStrength(score) {
  const value = Number(score || 0);

  if (value >= 3.5) {
    return 'strong';
  }

  if (value >= 1.6) {
    return 'middle';
  }

  return 'weak';
}

function getMarketGraphRelationNodeInlineMembers(node) {
  if (!node || typeof node !== 'object') {
    return [];
  }

  return [
    ...(Array.isArray(node.memberStocks) ? node.memberStocks : []),
    ...(Array.isArray(node.memberStocksPreview) ? node.memberStocksPreview : []),
    ...(Array.isArray(node.sharedStocksPreview) ? node.sharedStocksPreview : []),
    ...(Array.isArray(node.stocks) ? node.stocks : []),
    ...(Array.isArray(node.stockMembers) ? node.stockMembers : [])
  ];
}

function getMarketGraphInlineStockCode(stock) {
  if (!stock) {
    return '';
  }

  if (typeof stock === 'string') {
    return normalizeObservationStockCode(stock);
  }

  return normalizeObservationStockCode(stock.code || stock.stockCode || stock.symbol || stock.id);
}

function getMarketGraphInlineStockName(stock) {
  if (!stock || typeof stock === 'string') {
    return '';
  }

  return String(stock.name || stock.label || stock.stockName || stock.shortName || '').trim();
}

function collectMarketGraphRelationMemberStocks(relationNode, nodeById, edges) {
  const relationNodeId = relationNode && relationNode.id;
  const members = new Map();

  if (!relationNodeId) {
    return [];
  }

  edges.forEach((edge) => {
    if (!edge || (edge.source !== relationNodeId && edge.target !== relationNodeId)) {
      return;
    }

    const otherId = edge.source === relationNodeId ? edge.target : edge.source;
    const other = nodeById.get(otherId);

    if (!other || other.type !== 'stock') {
      return;
    }

    const code = getMarketGraphNodeStockCode(other);

    if (!code) {
      return;
    }

    members.set(code, {
      code,
      name: getMarketGraphNodeStockName(other),
      source: 'edge_stock',
      edge
    });
  });

  getMarketGraphRelationNodeInlineMembers(relationNode).forEach((stock) => {
    const code = getMarketGraphInlineStockCode(stock);

    if (!code || members.has(code)) {
      return;
    }

    members.set(code, {
      code,
      name: getMarketGraphInlineStockName(stock),
      source: 'inline_member',
      edge: null
    });
  });

  return Array.from(members.values());
}

function addDerivedStockRelation(relationMap, stock, relationNode, relationScore, edgeToCurrent) {
  const code = normalizeObservationStockCode(stock && stock.code);

  if (!code) {
    return;
  }

  const relationType = getMarketGraphRelationNodeType(relationNode);
  const relationLabel = getMarketGraphRelationNodeLabel(relationNode);
  const existed = relationMap.get(code) || {
    code,
    name: stock.name || code,
    relationScore: 0,
    relationTypes: [],
    relationLabels: [],
    relationNodes: [],
    relationStrength: 'weak',
    sources: ['relation_derived']
  };

  if (!existed.name && stock.name) {
    existed.name = stock.name;
  }

  existed.relationScore += Number(relationScore || 0);

  if (relationType && !existed.relationTypes.includes(relationType)) {
    existed.relationTypes.push(relationType);
  }

  if (relationLabel && !existed.relationLabels.includes(relationLabel)) {
    existed.relationLabels.push(relationLabel);
  }

  existed.relationNodes.push({
    id: relationNode.id || '',
    type: relationType,
    label: relationLabel,
    score: relationScore,
    edgeWeight: getMarketGraphEdgeWeight(edgeToCurrent)
  });

  existed.relationStrength = getMarketGraphRelationStrength(existed.relationScore);

  relationMap.set(code, existed);
}

function buildStockStockRelationsForCode(code, graph) {
  const normalizedCode = normalizeObservationStockCode(code);
  const nodes = Array.isArray(graph && graph.nodes) ? graph.nodes : [];
  const edges = Array.isArray(graph && graph.edges) ? graph.edges : [];
  const nodeById = new Map(nodes.map((node) => [node.id, node]));
  const currentNode = findObservationMarketGraphStockNode(graph, normalizedCode);
  const relationMap = new Map();
  const relationNodeMap = new Map();
  const debug = {
    code: normalizedCode,
    nodes: nodes.length,
    edges: edges.length,
    currentStockNodeFound: Boolean(currentNode),
    currentNodeId: currentNode ? currentNode.id : '',
    connectedRelationNodes: 0,
    scannedRelationNodes: 0,
    derivedStocks: 0,
    relationSamples: []
  };

  if (!normalizedCode || !nodes.length || !edges.length) {
    return {
      stocks: [],
      debug
    };
  }

  if (currentNode) {
    edges.forEach((edge) => {
      if (!edge || (edge.source !== currentNode.id && edge.target !== currentNode.id)) {
        return;
      }

      const otherId = edge.source === currentNode.id ? edge.target : edge.source;
      const other = nodeById.get(otherId);

      if (!other) {
        return;
      }

      if (other.type === 'stock') {
        const otherCode = getMarketGraphNodeStockCode(other);

        if (otherCode && otherCode !== normalizedCode) {
          addDerivedStockRelation(relationMap, {
            code: otherCode,
            name: getMarketGraphNodeStockName(other)
          }, {
            id: '',
            type: 'stock',
            label: '直接股票关系'
          }, 2 * getMarketGraphEdgeWeight(edge), edge);
        }

        return;
      }

      relationNodeMap.set(other.id, {
        node: other,
        edgeToCurrent: edge,
        source: 'current_edge'
      });
    });
  }

  if (!relationNodeMap.size) {
    nodes.forEach((node) => {
      if (!node || node.type === 'stock') {
        return;
      }

      const members = collectMarketGraphRelationMemberStocks(node, nodeById, edges);
      const hasCurrent = members.some((stock) => normalizeObservationStockCode(stock.code) === normalizedCode);

      if (hasCurrent) {
        relationNodeMap.set(node.id, {
          node,
          edgeToCurrent: null,
          source: 'member_scan'
        });
      }
    });
  }

  debug.connectedRelationNodes = relationNodeMap.size;

  relationNodeMap.forEach(({ node, edgeToCurrent, source }) => {
    const members = collectMarketGraphRelationMemberStocks(node, nodeById, edges);
    const memberCount = Math.max(
      members.length,
      Number(node.memberStockCount || node.stockCount || node.count || 0),
      1
    );
    const relationType = getMarketGraphRelationNodeType(node);
    const baseWeight = getMarketGraphRelationTypeWeight(relationType);
    const edgeWeight = getMarketGraphEdgeWeight(edgeToCurrent);
    const memberPenalty = getMarketGraphRelationMemberPenalty(memberCount);
    const relationScore = baseWeight * edgeWeight * memberPenalty;

    debug.scannedRelationNodes += 1;

    if (debug.relationSamples.length < 10) {
      debug.relationSamples.push({
        id: node.id,
        type: relationType,
        label: getMarketGraphRelationNodeLabel(node),
        source,
        memberCount,
        baseWeight,
        memberPenalty,
        relationScore: Number(relationScore.toFixed(3))
      });
    }

    members.forEach((stock) => {
      const stockCode = normalizeObservationStockCode(stock.code);

      if (!stockCode || stockCode === normalizedCode) {
        return;
      }

      addDerivedStockRelation(relationMap, stock, node, relationScore, edgeToCurrent);
    });
  });

  const stocks = Array.from(relationMap.values())
    .map((stock) => ({
      ...stock,
      relationScore: Number(stock.relationScore.toFixed(4)),
      relationStrength: getMarketGraphRelationStrength(stock.relationScore)
    }))
    .sort((left, right) => {
      if (right.relationScore !== left.relationScore) {
        return right.relationScore - left.relationScore;
      }

      return String(left.code).localeCompare(String(right.code));
    });

  debug.derivedStocks = stocks.length;

  return {
    stocks,
    debug
  };
}

function getObservationMarketGraphCandidates(code) {
  const normalizedCode = normalizeObservationStockCode(code);
  const result = new Map();

  if (!normalizedCode) {
    const empty = [];
    empty.debug = {
      code: '',
      reason: 'EMPTY_CODE',
      finalCandidates: 0
    };
    return empty;
  }

  const graphList = [];

  [
    marketGraphState.visibleGraph,
    marketGraphState.graph
  ].filter(Boolean).forEach((graph) => {
    if (!graphList.includes(graph)) {
      graphList.push(graph);
    }
  });

  const debugList = [];

  graphList.forEach((graph) => {
    const derived = buildStockStockRelationsForCode(normalizedCode, graph);
    debugList.push(derived.debug);

    derived.stocks.forEach((stock) => {
      addObservationStock(result, {
        code: stock.code,
        name: stock.name
      }, 'relation_derived', {
        relationTypes: stock.relationTypes,
        relationLabels: stock.relationLabels,
        relationScore: stock.relationScore,
        relationStrength: stock.relationStrength
      });
    });
  });

  if (!result.size && marketGraphState.visibleGraph && marketGraphState.visibleGraph !== graphList[0]) {
    const fallback = buildStockStockRelationsForCode(normalizedCode, marketGraphState.visibleGraph);
    debugList.push(fallback.debug);

    fallback.stocks.forEach((stock) => {
      addObservationStock(result, {
        code: stock.code,
        name: stock.name
      }, 'relation_derived_visible', {
        relationTypes: stock.relationTypes,
        relationLabels: stock.relationLabels,
        relationScore: stock.relationScore,
        relationStrength: stock.relationStrength
      });
    });
  }

  result.delete(normalizedCode);

  const stocks = Array.from(result.values())
    .map((stock) => ({
      ...stock,
      relationScore: Number(stock.relationScore || 0),
      relationStrength: stock.relationStrength || getMarketGraphRelationStrength(stock.relationScore || 0)
    }))
    .sort((left, right) => {
      if (right.relationScore !== left.relationScore) {
        return right.relationScore - left.relationScore;
      }

      return String(left.code).localeCompare(String(right.code));
    })
    .slice(0, OBSERVATION_CONTEXT_MAX_RELATION_STOCKS);

  const debug = {
    code: normalizedCode,
    viewPreset: marketGraphState.viewPreset,
    focusCode: marketGraphState.focusCode || '',
    graphCount: graphList.length,
    derivedDebug: debugList,
    finalCandidates: stocks.length,
    sample: stocks.slice(0, 12).map((stock) => ({
      code: stock.code,
      name: stock.name,
      relationScore: stock.relationScore,
      relationStrength: stock.relationStrength,
      relationTypes: stock.relationTypes,
      relationLabels: stock.relationLabels
    }))
  };

  stocks.debug = debug;

  if (OBSERVATION_CONTEXT_RELATION_DEBUG_ENABLED) {
    console.log('[OBSERVATION_STOCK_STOCK_RELATIONS]', debug);
    console.log('[OBSERVATION_RELATION_CANDIDATES]', debug);
  }

  return stocks;
}

async function ensureObservationSupplyChainForStock(code) {
  const normalizedCode = normalizeObservationStockCode(code);

  if (!normalizedCode) {
    return {
      ok: false,
      error: '缺少股票代码。'
    };
  }

  if (!window.xwbApi || typeof window.xwbApi.queryStockSupplyChain !== 'function') {
    return {
      ok: false,
      error: '产业链股票归属 API 不可用。'
    };
  }

  const response = await window.xwbApi.queryStockSupplyChain({
    code: normalizedCode,
    maxChains: SUPPLY_CHAIN_MAX_CHAINS
  });

  if (!response || !response.ok) {
    return {
      ok: false,
      error: `股票产业链归属读取失败：${formatDisplayError(response && response.error)}`
    };
  }

  const stockResult = response.stock || null;
  supplyChainState.stockResult = stockResult;
  renderSupplyChainStockResult(stockResult);

  if (!stockResult || !stockResult.found) {
    return {
      ok: false,
      error: `未找到股票 ${normalizedCode} 的产业链归属。`
    };
  }

  const assignments = Array.isArray(stockResult.assignments) ? stockResult.assignments : [];
  const firstAssignment = assignments[0] || null;
  const chainId = firstAssignment ? String(firstAssignment.chainId || '').trim() : '';

  if (!chainId) {
    return {
      ok: false,
      error: `股票 ${normalizedCode} 没有可用的产业链 chainId。`
    };
  }

  if (supplyChainState.selectedChainId !== chainId) {
    await selectSupplyChainChain(chainId);
  }

  return {
    ok: true,
    stock: stockResult,
    assignment: firstAssignment,
    chainId
  };
}

function getObservationSupplyChainCandidates(code) {
  const normalizedCode = normalizeObservationStockCode(code);
  const result = new Map();
  const chain = supplyChainState.selectedChain;

  if (!normalizedCode || !chain || !chain.layers) {
    return {
      stocks: [],
      self: null
    };
  }

  let self = null;

  SUPPLY_CHAIN_LAYER_DEFS.forEach((def) => {
    const layer = getSupplyChainLayer(chain, def.key);
    const stocks = Array.isArray(layer.stocks) ? layer.stocks : [];

    stocks.forEach((stock) => {
      const stockCode = normalizeObservationStockCode(stock && stock.code);

      if (!stockCode) {
        return;
      }

      const layerExtra = {
        layerKey: def.key,
        layerLabel: def.label,
        chainId: chain.id || supplyChainState.selectedChainId || '',
        chainName: chain.name || ''
      };

      if (stockCode === normalizedCode) {
        self = {
          code: stockCode,
          name: stock.name || stock.label || stock.code || '',
          market: stock.market || '',
          confidence: stock.confidence,
          source: stock.source || '',
          matchedTerms: Array.isArray(stock.matchedTerms) ? stock.matchedTerms : [],
          ...layerExtra
        };
        return;
      }

      addObservationStock(result, stock, 'supply_chain', layerExtra);
    });
  });

  if (!self) {
    return {
      stocks: [],
      self: null
    };
  }

  return {
    stocks: Array.from(result.values()).slice(0, OBSERVATION_CONTEXT_MAX_SUPPLY_CHAIN_STOCKS),
    self
  };
}

function getObservationDateWindow(clickedDate) {
  const state = interactiveCurveState;
  const cleanDate = normalizeTimelineDate(clickedDate);

  if (!state || !state.data || !Array.isArray(state.data.series) || !state.data.dateIndex || !state.data.dateIndex.has(cleanDate)) {
    return [];
  }

  const series = state.data.series;
  const centerIndex = state.data.dateIndex.get(cleanDate);
  const startIndex = Math.max(0, centerIndex - OBSERVATION_CONTEXT_LOOKBACK_DAYS);
  const endIndex = Math.min(series.length - 1, centerIndex + OBSERVATION_CONTEXT_FORWARD_DAYS);

  return series.slice(startIndex, endIndex + 1).map((item, index) => {
    const absoluteIndex = startIndex + index;

    return {
      date: normalizeTimelineDate(item.date),
      offset: absoluteIndex - centerIndex,
      index: absoluteIndex
    };
  });
}

function buildCurrentStockTimelineForObservation(dateWindow) {
  const state = interactiveCurveState;

  if (!state || !state.data) {
    return [];
  }

  return dateWindow.map((point) => {
    const item = state.data.series[point.index] || {};
    const dailyState = state.data.stateByIndex && state.data.stateByIndex.has(point.index)
      ? state.data.stateByIndex.get(point.index)
      : null;
    const opportunity = state.data.opportunityByIndex && state.data.opportunityByIndex.has(point.index)
      ? state.data.opportunityByIndex.get(point.index)
      : null;

    return {
      date: point.date,
      offset: point.offset,
      close: Number.isFinite(Number(item.close)) ? Number(item.close) : null,
      shapeType: dailyState && dailyState.shape ? dailyState.shape.type || '' : '',
      positionType: dailyState && dailyState.position ? dailyState.position.type || '' : '',
      changeType: dailyState && dailyState.change ? dailyState.change.type || '' : '',
      stateCode: dailyState ? dailyState.stateCode || '' : '',
      stateName: dailyState ? dailyState.stateName || '' : '',
      opportunityGrade: opportunity ? opportunity.opportunityGrade || '' : '',
      opportunityScore: opportunity ? opportunity.opportunityScore || null : null,
      stateStatus: dailyState ? 'loaded' : 'no_state_for_date'
    };
  });
}

function buildPendingRelatedStockTimeline(stock, dateWindow) {
  return dateWindow.map((point) => ({
    code: stock.code,
    date: point.date,
    offset: point.offset,
    stateStatus: 'pending_external_stock_state'
  }));
}

function buildRelatedStockTimelineFromBacktestResult(stock, dateWindow, result) {
  const series = getTimelineSeries(result);
  const dailyStates = getXwbDailyStates(result);
  const dailyOpportunities = getDailyOpportunities(result);

  const closeByDate = new Map(series.map((item) => [
    normalizeTimelineDate(item && item.date),
    Number(item && item.close)
  ]));

  const stateByDate = new Map(dailyStates.map((item) => [
    normalizeTimelineDate(item && item.date),
    item
  ]));

  const opportunityByDate = new Map(dailyOpportunities.map((item) => [
    normalizeTimelineDate(item && item.date),
    item
  ]));

  return dateWindow.map((point) => {
    const date = normalizeTimelineDate(point.date);
    const dailyState = stateByDate.get(date) || null;
    const opportunity = opportunityByDate.get(date) || null;
    const close = closeByDate.has(date) ? closeByDate.get(date) : null;

    return {
      code: stock.code,
      name: stock.name || '',
      date,
      offset: point.offset,
      close: Number.isFinite(Number(close)) ? Number(close) : null,

      shapeType: dailyState && dailyState.shape ? dailyState.shape.type || '' : '',
      positionType: dailyState && dailyState.position ? dailyState.position.type || '' : '',
      changeType: dailyState && dailyState.change ? dailyState.change.type || '' : '',
      stateCode: dailyState ? dailyState.stateCode || '' : '',
      stateName: dailyState ? dailyState.stateName || '' : '',

      opportunityGrade: opportunity ? opportunity.opportunityGrade || '' : '',
      opportunityScore: opportunity ? opportunity.opportunityScore || null : null,
      riskLevel: opportunity ? opportunity.riskLevel || '' : '',
      actionBias: opportunity ? opportunity.actionBias || '' : '',

      stateStatus: dailyState ? 'loaded' : 'no_state_for_date'
    };
  });
}

async function hydrateObservationRelatedStockMatrix(context) {
  if (!context || !context.ok || !context.related || !Array.isArray(context.related.matrix)) {
    return context;
  }

  if (!window.xwbApi || typeof window.xwbApi.runBacktest !== 'function') {
    context.related.matrixStatus = {
      ok: false,
      loading: false,
      loaded: 0,
      failed: 0,
      total: 0,
      totalRelated: context.related.matrix.length,
      failures: [],
      message: 'runBacktest API 不可用，无法批量加载相关股票状态。'
    };
    context.observationSummary = summarizeObservationMatrix(context);
    renderObservationContextStatus(context);
    return context;
  }

  const parsedParams = readBacktestParams();

  if (parsedParams.error) {
    context.related.matrixStatus = {
      ok: false,
      loading: false,
      loaded: 0,
      failed: 0,
      total: 0,
      totalRelated: context.related.matrix.length,
      failures: [],
      message: parsedParams.error
    };
    context.observationSummary = summarizeObservationMatrix(context);
    renderObservationContextStatus(context);
    return context;
  }

  const dateWindow = context.window && Array.isArray(context.window.dates)
    ? context.window.dates
    : [];

  if (!dateWindow.length) {
    context.related.matrixStatus = {
      ok: false,
      loading: false,
      loaded: 0,
      failed: 0,
      total: 0,
      totalRelated: context.related.matrix.length,
      failures: [],
      message: '观察窗口为空，无法加载相关股票状态。'
    };
    context.observationSummary = summarizeObservationMatrix(context);
    renderObservationContextStatus(context);
    return context;
  }

  const requestStartDate = String(startDateInput && startDateInput.value || '').trim()
    || dateWindow[0].date;

  const requestEndDate = String(endDateInput && endDateInput.value || '').trim()
    || dateWindow[dateWindow.length - 1].date;

  const rows = context.related.matrix.slice(0, OBSERVATION_CONTEXT_STATE_BATCH_LIMIT);

  let loaded = 0;
  let failed = 0;
  const failureSamples = [];

  context.observationSummary = null;
  context.related.matrixStatus = {
    ok: true,
    loading: true,
    loaded,
    failed,
    total: rows.length,
    totalRelated: context.related.matrix.length,
    failures: failureSamples,
    message: `正在加载相关股票状态：0 / ${rows.length}`
  };

  renderObservationContextStatus(context);

  for (const row of rows) {
    const code = normalizeObservationStockCode(row.code);

    if (!code) {
      failed += 1;
      row.timeline = buildPendingRelatedStockTimeline(row, dateWindow);
      row.loadError = '股票代码无效。';

      if (failureSamples.length < 5) {
        failureSamples.push(`${row.code || '-'} ${row.name || ''}：${row.loadError}`);
      }
    } else {
      try {
        const response = await window.xwbApi.runBacktest({
          symbol: code,
          startDate: requestStartDate,
          endDate: requestEndDate,
          refresh: false,
          cacheOnly: true,
          sourceMode: 'sqlite_cache_only',
          params: parsedParams.params
        });

        if (!response || !response.ok || !response.result) {
          failed += 1;
          row.timeline = buildPendingRelatedStockTimeline(row, dateWindow);
          row.loadError = response && response.error
            ? String(response.error)
            : '相关股票状态读取失败。';

          console.warn('[OBSERVATION_MATRIX_BACKTEST_FAIL]', {
            code,
            name: row.name || '',
            requestStartDate,
            requestEndDate,
            error: row.loadError,
            response
          });

          if (failureSamples.length < 5) {
            failureSamples.push(`${code} ${row.name || ''}：${row.loadError}`);
          }
        } else {
          loaded += 1;
          row.timeline = buildRelatedStockTimelineFromBacktestResult(row, dateWindow, response.result);
          row.loadError = '';
        }
      } catch (error) {
        failed += 1;
        row.timeline = buildPendingRelatedStockTimeline(row, dateWindow);
        row.loadError = error && error.message ? error.message : String(error);

        console.warn('[OBSERVATION_MATRIX_BACKTEST_THROW]', {
          code,
          name: row.name || '',
          requestStartDate,
          requestEndDate,
          error: row.loadError
        });

        if (failureSamples.length < 5) {
          failureSamples.push(`${code} ${row.name || ''}：${row.loadError}`);
        }
      }
    }

    context.related.matrixStatus = {
      ok: true,
      loading: true,
      loaded,
      failed,
      total: rows.length,
      totalRelated: context.related.matrix.length,
      failures: failureSamples,
      message: failureSamples.length
        ? `正在加载相关股票状态：${loaded + failed} / ${rows.length}｜失败示例：${failureSamples[0]}`
        : `正在加载相关股票状态：${loaded + failed} / ${rows.length}`
    };

    renderObservationContextStatus(context);
  }

  context.related.matrixStatus = {
    ok: true,
    loading: false,
    loaded,
    failed,
    total: rows.length,
    totalRelated: context.related.matrix.length,
    failures: failureSamples,
    message: failureSamples.length
      ? `相关股票状态加载完成：成功 ${loaded}，失败 ${failed}，本轮样本 ${rows.length} / 总样本 ${context.related.matrix.length}｜失败示例：${failureSamples.join('；')}`
      : `相关股票状态加载完成：成功 ${loaded}，失败 ${failed}，本轮样本 ${rows.length} / 总样本 ${context.related.matrix.length}`
  };

  context.observationSummary = summarizeObservationMatrix(context);
  context.playbackFrames = buildObservationPlaybackFrames(context);
  context.currentPlaybackOffset = 0;
  context.currentPlaybackFrame = getObservationPlaybackFrameByOffset(context, 0);

  renderStructureRhythmMap(context);
  renderObservationContextStatus(context);

  console.log('[OBSERVATION_MATRIX_SUMMARY]', context.observationSummary);
  console.log('[OBSERVATION_PLAYBACK_FRAMES]', {
    total: context.playbackFrames.length,
    current: context.currentPlaybackFrame,
    frames: context.playbackFrames
  });

  return context;
}

function getObservationMatrixPointAtOffset(timeline, offset) {
  const list = Array.isArray(timeline) ? timeline : [];
  return list.find((point) => Number(point && point.offset) === Number(offset)) || null;
}

function isObservationMatrixPointLoaded(point) {
  return Boolean(point && point.stateStatus === 'loaded');
}

function isObservationStrongShape(point) {
  const type = String(point && point.shapeType || '');

  return [
    'VOLUME_BREAKOUT',
    'MA_TURN_STRONG',
    'CLOSE_ABOVE_KEY_MA',
    'BREAKOUT_PREPARE',
    'BASE_REPAIR',
    'OVERSOLD_REBOUND',
    'PULLBACK'
  ].includes(type);
}

function isObservationStrongChange(point) {
  const type = String(point && point.changeType || '');

  return [
    'STRENGTHENING',
    'CONTINUING_UP',
    'PULLBACK_STABLE',
    'TURN_UP',
    'BREAKOUT_CONFIRM',
    'STABILIZED'
  ].includes(type);
}

function isObservationPositiveState(point) {
  const stateCode = String(point && point.stateCode || '');

  return [
    'LOW_STARTING',
    'PULLBACK_REPAIR',
    'MID_TREND_CONTINUING'
  ].includes(stateCode);
}

function isObservationOpportunityPoint(point) {
  const grade = String(point && point.opportunityGrade || '');
  const score = Number(point && point.opportunityScore);

  return grade === 'A' || grade === 'B' || (Number.isFinite(score) && score >= 60);
}

function isObservationStrongPoint(point) {
  if (!isObservationMatrixPointLoaded(point)) {
    return false;
  }

  return (
    isObservationStrongShape(point) ||
    isObservationStrongChange(point) ||
    isObservationPositiveState(point) ||
    isObservationOpportunityPoint(point)
  );
}

function getObservationFirstStrongOffset(timeline, minOffset, maxOffset) {
  const list = Array.isArray(timeline) ? timeline : [];

  for (let offset = minOffset; offset <= maxOffset; offset += 1) {
    const point = list.find((item) => Number(item && item.offset) === offset);

    if (isObservationStrongPoint(point)) {
      return offset;
    }
  }

  return null;
}

function getObservationLayerKey(row) {
  const layers = Array.isArray(row && row.layers) ? row.layers : [];
  const firstLayer = layers[0] || {};
  return String(firstLayer.layerKey || 'unknown');
}

function getObservationLayerLabel(row) {
  const layers = Array.isArray(row && row.layers) ? row.layers : [];
  const firstLayer = layers[0] || {};
  return String(firstLayer.layerLabel || firstLayer.layerKey || '未知层级');
}

function getObservationMatrixRatio(count, total) {
  const num = Number(count);
  const den = Number(total);

  if (!Number.isFinite(num) || !Number.isFinite(den) || den <= 0) {
    return 0;
  }

  return num / den;
}

function formatObservationMatrixRatio(count, total) {
  const ratio = getObservationMatrixRatio(count, total);
  return `${formatNumber(count, 0)} / ${formatNumber(total, 0)}（${formatPercent(ratio * 100, 1)}）`;
}

function getObservationMatrixVerdict(summary) {
  const loadedCount = Number(summary.loadedCount || 0);

  if (loadedCount <= 0) {
    return {
      type: 'NO_MATRIX',
      title: '暂无矩阵',
      text: '相关股票状态矩阵尚未加载成功，无法判断共振或传导。'
    };
  }

  const t0StrongRatio = getObservationMatrixRatio(summary.t0StrongCount, loadedCount);
  const nearStrongRatio = getObservationMatrixRatio(summary.nearStrongCount, loadedCount);
  const preStrongRatio = getObservationMatrixRatio(summary.preStrongCount, loadedCount);
  const leadRatio = getObservationMatrixRatio(summary.leadCount, loadedCount);

  if (leadRatio >= 0.35 && nearStrongRatio >= 0.35) {
    return {
      type: 'ADVANCE_RESONANCE',
      title: '提前共振',
      text: 'T0 前已有较多相关股票提前走强，并在 T0 附近继续共振；当前股更像处在产业链传导或板块扩散中。'
    };
  }

  if (t0StrongRatio >= 0.35 || nearStrongRatio >= 0.45) {
    return {
      type: 'SAME_TIME_RESONANCE',
      title: '同频共振',
      text: 'T0 附近相关股票强状态占比较高，当前节点不是孤立异动，更接近同链共振。'
    };
  }

  if (preStrongRatio >= 0.3) {
    return {
      type: 'PREHEAT',
      title: '链内预热',
      text: 'T0 前有一部分相关股票已经走强，但 T0 附近共振强度不足，需要继续观察是否扩散。'
    };
  }

  if (summary.target && summary.target.t0Strong && t0StrongRatio < 0.15 && preStrongRatio < 0.15) {
    return {
      type: 'ISOLATED_TARGET',
      title: '疑似孤立',
      text: '当前股自身节点较强，但相关股票矩阵没有明显同步响应，偏孤立异动。'
    };
  }

  return {
    type: 'WEAK_CONTEXT',
    title: '弱共振',
    text: '相关股票矩阵暂未形成明显提前启动或同频共振，结构强度偏弱。'
  };
}

function summarizeObservationMatrix(context) {
  const matrix = context && context.related && Array.isArray(context.related.matrix)
    ? context.related.matrix
    : [];

  const targetTimeline = context && context.currentStock && Array.isArray(context.currentStock.timeline)
    ? context.currentStock.timeline
    : [];

  const loadedRows = matrix.filter((row) => {
    const timeline = Array.isArray(row && row.timeline) ? row.timeline : [];
    return timeline.some(isObservationMatrixPointLoaded);
  });

  const rowSummaries = loadedRows.map((row) => {
    const timeline = Array.isArray(row.timeline) ? row.timeline : [];
    const t0Point = getObservationMatrixPointAtOffset(timeline, 0);
    const firstStrongOffset = getObservationFirstStrongOffset(timeline, -20, 20);
    const firstPreStrongOffset = getObservationFirstStrongOffset(timeline, -20, -1);
    const firstNearStrongOffset = getObservationFirstStrongOffset(timeline, -5, 0);
    const firstAfterStrongOffset = getObservationFirstStrongOffset(timeline, 1, 20);

    return {
      code: row.code,
      name: row.name || '',
      sources: Array.isArray(row.sources) ? row.sources : [],
      relationTypes: Array.isArray(row.relationTypes) ? row.relationTypes : [],
      layers: Array.isArray(row.layers) ? row.layers : [],
      layerKey: getObservationLayerKey(row),
      layerLabel: getObservationLayerLabel(row),
      t0Loaded: isObservationMatrixPointLoaded(t0Point),
      t0Strong: isObservationStrongPoint(t0Point),
      t0Opportunity: isObservationOpportunityPoint(t0Point),
      firstStrongOffset,
      firstPreStrongOffset,
      firstNearStrongOffset,
      firstAfterStrongOffset
    };
  });

  const loadedCount = rowSummaries.length;
  const t0LoadedCount = rowSummaries.filter((row) => row.t0Loaded).length;
  const t0StrongRows = rowSummaries.filter((row) => row.t0Strong);
  const t0OpportunityRows = rowSummaries.filter((row) => row.t0Opportunity);
  const preStrongRows = rowSummaries.filter((row) => row.firstPreStrongOffset !== null);
  const nearStrongRows = rowSummaries.filter((row) => row.firstNearStrongOffset !== null);
  const afterStrongRows = rowSummaries.filter((row) => row.firstAfterStrongOffset !== null);
  const leadRows = rowSummaries.filter((row) => row.firstPreStrongOffset !== null && row.firstPreStrongOffset <= -1);

  const layerMap = new Map();

  rowSummaries.forEach((row) => {
    const key = row.layerKey || 'unknown';
    const existed = layerMap.get(key) || {
      layerKey: key,
      layerLabel: row.layerLabel || key,
      loadedCount: 0,
      t0StrongCount: 0,
      t0OpportunityCount: 0,
      preStrongCount: 0,
      nearStrongCount: 0,
      firstStrongOffset: null,
      samples: []
    };

    existed.loadedCount += 1;

    if (row.t0Strong) {
      existed.t0StrongCount += 1;
    }

    if (row.t0Opportunity) {
      existed.t0OpportunityCount += 1;
    }

    if (row.firstPreStrongOffset !== null) {
      existed.preStrongCount += 1;
    }

    if (row.firstNearStrongOffset !== null) {
      existed.nearStrongCount += 1;
    }

    if (row.firstStrongOffset !== null) {
      existed.firstStrongOffset = existed.firstStrongOffset === null
        ? row.firstStrongOffset
        : Math.min(existed.firstStrongOffset, row.firstStrongOffset);
    }

    if (existed.samples.length < 8) {
      existed.samples.push({
        code: row.code,
        name: row.name,
        firstStrongOffset: row.firstStrongOffset,
        t0Strong: row.t0Strong
      });
    }

    layerMap.set(key, existed);
  });

  const layerOrder = new Map(SUPPLY_CHAIN_LAYER_DEFS.map((def, index) => [def.key, index]));
  const layers = Array.from(layerMap.values()).sort((left, right) => {
    const leftOrder = layerOrder.has(left.layerKey) ? layerOrder.get(left.layerKey) : 99;
    const rightOrder = layerOrder.has(right.layerKey) ? layerOrder.get(right.layerKey) : 99;

    if (leftOrder !== rightOrder) {
      return leftOrder - rightOrder;
    }

    return String(left.layerLabel).localeCompare(String(right.layerLabel), 'zh-Hans-CN');
  });

  const targetT0Point = getObservationMatrixPointAtOffset(targetTimeline, 0);
  const targetFirstStrongOffset = getObservationFirstStrongOffset(targetTimeline, -20, 20);
  const targetFirstPreStrongOffset = getObservationFirstStrongOffset(targetTimeline, -20, -1);

  const summary = {
    ok: true,
    totalCandidateCount: matrix.length,
    loadedCount,
    t0LoadedCount,
    t0StrongCount: t0StrongRows.length,
    t0OpportunityCount: t0OpportunityRows.length,
    preStrongCount: preStrongRows.length,
    nearStrongCount: nearStrongRows.length,
    afterStrongCount: afterStrongRows.length,
    leadCount: leadRows.length,
    target: {
      code: context && context.code || '',
      t0: context && context.t0 || '',
      t0Loaded: isObservationMatrixPointLoaded(targetT0Point),
      t0Strong: isObservationStrongPoint(targetT0Point),
      t0Opportunity: isObservationOpportunityPoint(targetT0Point),
      firstStrongOffset: targetFirstStrongOffset,
      firstPreStrongOffset: targetFirstPreStrongOffset,
      stateCode: targetT0Point ? targetT0Point.stateCode || '' : '',
      opportunityGrade: targetT0Point ? targetT0Point.opportunityGrade || '' : ''
    },
    layers,
    leadingSamples: leadRows.slice(0, 8).map((row) => ({
      code: row.code,
      name: row.name,
      layerLabel: row.layerLabel,
      firstPreStrongOffset: row.firstPreStrongOffset
    })),
    t0StrongSamples: t0StrongRows.slice(0, 8).map((row) => ({
      code: row.code,
      name: row.name,
      layerLabel: row.layerLabel
    }))
  };

  summary.verdict = getObservationMatrixVerdict(summary);

  summary.narrative = [
    `矩阵样本 ${formatNumber(summary.loadedCount, 0)} / ${formatNumber(summary.totalCandidateCount, 0)}`,
    `T0强状态 ${formatObservationMatrixRatio(summary.t0StrongCount, summary.loadedCount)}`,
    `T-20~T-1提前走强 ${formatObservationMatrixRatio(summary.preStrongCount, summary.loadedCount)}`,
    `T-5~T0近端共振 ${formatObservationMatrixRatio(summary.nearStrongCount, summary.loadedCount)}`,
    `机会A/B ${formatObservationMatrixRatio(summary.t0OpportunityCount, summary.loadedCount)}`,
    `结论：${summary.verdict.title}`
  ].join('；');

  return summary;
}

function summarizeNodePredictionObservationRows(rows) {
  const list = Array.isArray(rows) ? rows : [];
  const loadedRows = list.filter((row) => {
    const timeline = Array.isArray(row && row.timeline) ? row.timeline : [];
    return timeline.some(isObservationMatrixPointLoaded);
  });

  let t0StrongCount = 0;
  let t0OpportunityCount = 0;
  let preStrongCount = 0;
  let nearStrongCount = 0;
  let earlyLeadCount = 0;
  const samples = [];

  loadedRows.forEach((row) => {
    const timeline = Array.isArray(row && row.timeline) ? row.timeline : [];
    const t0Point = getObservationMatrixPointAtOffset(timeline, 0);
    const firstPreStrongOffset = getObservationFirstStrongOffset(timeline, -20, -1);
    const firstNearStrongOffset = getObservationFirstStrongOffset(timeline, -5, 0);

    const t0Strong = isObservationStrongPoint(t0Point);
    const t0Opportunity = isObservationOpportunityPoint(t0Point);

    if (t0Strong) {
      t0StrongCount += 1;
    }

    if (t0Opportunity) {
      t0OpportunityCount += 1;
    }

    if (firstPreStrongOffset !== null) {
      preStrongCount += 1;
    }

    if (firstNearStrongOffset !== null) {
      nearStrongCount += 1;
    }

    if (firstPreStrongOffset !== null && firstPreStrongOffset <= -6) {
      earlyLeadCount += 1;
    }

    if (samples.length < 8 && (t0Strong || firstPreStrongOffset !== null || firstNearStrongOffset !== null)) {
      samples.push({
        code: row.code,
        name: row.name || '',
        layerLabel: getObservationLayerLabel(row),
        firstPreStrongOffset,
        t0Strong
      });
    }
  });

  const loadedCount = loadedRows.length;

  return {
    loadedCount,
    t0StrongCount,
    t0OpportunityCount,
    preStrongCount,
    nearStrongCount,
    earlyLeadCount,
    t0StrongRatio: loadedCount > 0 ? t0StrongCount / loadedCount : 0,
    t0OpportunityRatio: loadedCount > 0 ? t0OpportunityCount / loadedCount : 0,
    preStrongRatio: loadedCount > 0 ? preStrongCount / loadedCount : 0,
    nearStrongRatio: loadedCount > 0 ? nearStrongCount / loadedCount : 0,
    earlyLeadRatio: loadedCount > 0 ? earlyLeadCount / loadedCount : 0,
    samples
  };
}

function buildNodePredictionDominantLayer(rows) {
  const layerMap = new Map();

  (Array.isArray(rows) ? rows : []).forEach((row) => {
    const key = getObservationLayerKey(row);
    const label = getObservationLayerLabel(row);

    if (!key || key === 'unknown') {
      return;
    }

    const existed = layerMap.get(key) || {
      layerKey: key,
      layerLabel: label,
      rows: []
    };

    existed.rows.push(row);
    layerMap.set(key, existed);
  });

  const layerItems = Array.from(layerMap.values()).map((item) => {
    const stats = summarizeNodePredictionObservationRows(item.rows);

    return {
      layerKey: item.layerKey,
      layerLabel: item.layerLabel,
      ...stats,
      score: stats.nearStrongRatio * 120
        + stats.t0StrongRatio * 110
        + stats.preStrongRatio * 70
        + stats.loadedCount * 0.01
    };
  });

  return layerItems.sort((left, right) => right.score - left.score)[0] || null;
}

function mixNodePredictionObservationRatio(left, right, key) {
  const leftLoaded = Number(left && left.loadedCount || 0);
  const rightLoaded = Number(right && right.loadedCount || 0);
  const total = leftLoaded + rightLoaded;

  if (total <= 0) {
    return 0;
  }

  return (
    Number(left && left[key] || 0) * leftLoaded
    + Number(right && right[key] || 0) * rightLoaded
  ) / total;
}

function buildNodePredictionObservationRefinement(context) {
  if (window.xwbApi && typeof window.xwbApi.buildNodeStructurePrediction === 'function') {
    return window.xwbApi.buildNodeStructurePrediction(context);
