function handleInteractiveCurveMove(event) {
  const state = interactiveCurveState;

  if (!state || !state.svg || state.data.series.length === 0) {
    return;
  }

  if (activeForecastBoxDrag || getForecastDraggableBox(event.target)) {
    return;
  }

  const rect = state.svg.getBoundingClientRect();
  const mouseX = ((event.clientX - rect.left) / rect.width) * state.width;
  const mouseY = ((event.clientY - rect.top) / rect.height) * state.height;
  const index = getInteractiveIndexFromX(mouseX, state);
  const item = state.data.series[index];
  const crosshair = state.svg.querySelector('#curveCrosshair');
  const activeLayer = state.svg.querySelector('#activeCurvePointLayer');
  const x = getInteractiveX(index, state);

  if (crosshair) {
    crosshair.setAttribute('x1', x.toFixed(2));
    crosshair.setAttribute('x2', x.toFixed(2));
    crosshair.setAttribute('visibility', 'visible');
  }

  state.svg.querySelectorAll('.curve-point-active').forEach((point) => {
    point.classList.remove('curve-point-active');
  });

  let nearestMarker = null;
  let nearestDistance = Infinity;

  for (const marker of state.data.markers) {
    const distance = Math.hypot(marker.x - mouseX, marker.y - mouseY);

    if (distance < nearestDistance) {
      nearestDistance = distance;
      nearestMarker = marker;
    }
  }

  if (nearestMarker && nearestDistance <= 14) {
    const markerElement = state.svg.querySelector(`[data-marker-key="${nearestMarker.markerKey}"]`);

    if (markerElement) {
      markerElement.classList.add('curve-point-active');
    }

    if (activeLayer) {
      activeLayer.innerHTML = `
        <circle class="curve-point curve-point-active" cx="${nearestMarker.x.toFixed(2)}" cy="${nearestMarker.y.toFixed(2)}" r="7"></circle>
        <text class="chart-marker-label" x="${nearestMarker.x.toFixed(2)}" y="${(nearestMarker.y - 11).toFixed(2)}">${escapeHtml(nearestMarker.label)}</text>
      `;
    }

    updateInteractiveInfoPanel({
      type: 'trade',
      row: nearestMarker.row,
      title: `${nearestMarker.label}点交易`
    });
    return;
  }

  if (activeLayer) {
    activeLayer.innerHTML = '';
  }

  updateInteractiveInfoPanel({
    type: 'date',
    index,
    item
  });
}

function renderInteractiveCurve(result) {
