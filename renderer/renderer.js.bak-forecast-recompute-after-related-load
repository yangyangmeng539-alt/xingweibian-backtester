}

function renderSupplyChainLayerStock(stock) {
  const terms = Array.isArray(stock.matchedTerms) ? stock.matchedTerms.slice(0, 5) : [];
  const sourceLabel = getSupplyChainSourceLabel(stock);
  const sourceClass = stock.source === 'user'
  ? ' is-user'
  : (stock.source === 'inferred' ? ' is-inferred' : '');

  return `
    <div class="supply-chain-stock-row">
      <div>
        <strong>${formatText(stock.code)} ${formatText(stock.name)}</strong>
        <span>${formatText(stock.market)} · 置信度 ${formatSupplyChainConfidence(stock.confidence)}</span>
      </div>
      <div class="supply-chain-stock-tags">
        <em class="supply-chain-source${sourceClass}">${formatText(sourceLabel)}</em>
        ${terms.map((term) => `<i>${formatText(term)}</i>`).join('')}
      </div>
    </div>
  `;
}

function getSupplyChainLayer(chain, layerKey) {
  if (!chain || !chain.layers || !chain.layers[layerKey]) {
    return { stocks: [], stockCount: 0, displayCount: 0 };
  }

  const layer = chain.layers[layerKey] || {};
  return {
    ...layer,
    stocks: Array.isArray(layer.stocks) ? layer.stocks : [],
    stockCount: Number(layer.stockCount || 0),
    displayCount: Number(layer.displayCount || 0)
  };
}

function renderSupplyChainGraphStockNode(stock, layerKey) {
  const inferredClass = stock.source === 'inferred' ? ' is-inferred' : '';

  return `
    <button class="supply-chain-graph-stock-node${inferredClass}" type="button" data-graph-layer="${formatText(layerKey)}" data-graph-stock="${formatText(stock.code)}">
      <b>${formatText(stock.name || stock.code)}</b>
      <span>${formatText(stock.code)} · ${formatSupplyChainConfidence(stock.confidence)}</span>
    </button>
  `;
}

function renderSupplyChainGraphLayer(chain, def) {
  const layer = getSupplyChainLayer(chain, def.key);
  const stocks = layer.stocks.slice(0, 8);
  const hiddenCount = Math.max(0, (layer.stockCount || 0) - stocks.length);

  return `
    <section class="supply-chain-graph-layer" data-graph-layer-box="${formatText(def.key)}">
      <button class="supply-chain-graph-layer-head" type="button" data-graph-layer="${formatText(def.key)}">
        <strong>${formatText(def.label)}</strong>
        <span>${formatNumber(layer.stockCount || 0, 0)} 只</span>
      </button>

      <div class="supply-chain-graph-stock-nodes">
        ${
          stocks.length
            ? stocks.map((stock) => renderSupplyChainGraphStockNode(stock, def.key)).join('')
            : '<div class="supply-chain-graph-empty">暂无股票</div>'
        }
        ${hiddenCount > 0 ? `<div class="supply-chain-graph-more">+${formatNumber(hiddenCount, 0)} 个在下方列表</div>` : ''}
      </div>
    </section>
  `;
}

function findSupplyChainGraphStock(chain, layerKey, code) {
  const layer = getSupplyChainLayer(chain, layerKey);
  const normalizedCode = String(code || '').trim();

  return layer.stocks.find((stock) => String(stock.code || '').trim() === normalizedCode) || null;
}

