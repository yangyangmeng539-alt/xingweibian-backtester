function clearMarketGraphFetchPoll() {
  if (marketGraphFetchPollTimer) {
    clearTimeout(marketGraphFetchPollTimer);
    marketGraphFetchPollTimer = null;
  }
}

function scheduleMarketGraphFetchPoll() {
  clearMarketGraphFetchPoll();
  marketGraphFetchPollTimer = setTimeout(() => {
    refreshMarketGraphFetchStatus({ fromPoll: true });
  }, 1600);
}

async function refreshMarketGraphFetchErrors() {
  if (!window.xwbApi || typeof window.xwbApi.getMarketGraphRelationFetchErrors !== 'function') {
    return;
  }

  try {
    const response = await window.xwbApi.getMarketGraphRelationFetchErrors();

    if (response.ok) {
      renderMarketGraphFetchErrors(response.errors);
    }
  } catch (_error) {
    renderMarketGraphFetchErrors(null);
  }
}

async function refreshMarketGraphFetchStatus(options = {}) {
  if (!window.xwbApi || typeof window.xwbApi.getMarketGraphRelationFetchStatus !== 'function') {
    setMarketGraphLog('市场态星图采集 API 不可用。');
    return null;
  }

  const wasRunning = Boolean(marketGraphState.fetchRunning);

  try {
    const response = await window.xwbApi.getMarketGraphRelationFetchStatus();

    if (!response.ok) {
      setMarketGraphLog(`采集状态读取失败：${formatDisplayError(response.error)}`);
      return null;
    }

    const status = response.status || {};
    marketGraphState.fetchRunning = Boolean(status.running);
    renderMarketGraphFetchStatus(status);
    await refreshMarketGraphFetchErrors();

    if (marketGraphState.fetchRunning) {
      scheduleMarketGraphFetchPoll();
    } else {
      clearMarketGraphFetchPoll();

      if (wasRunning && options.fromPoll) {
        await refreshMarketGraphSummary();
        await loadMarketGraph('full');
        setMarketGraphLog('采集结束，已刷新关系摘要和市场总览。');
      }
    }

    return status;
  } catch (error) {
    setMarketGraphLog(`采集状态读取失败：${formatDisplayError(error && error.message ? error.message : error)}`);
    return null;
  }
}

async function startMarketGraphRelationFetch(mode) {
  const payload = MARKET_GRAPH_FETCH_PAYLOADS[mode];

  if (!payload) {
    setMarketGraphLog('未知采集模式。');
    return;
  }

  if (!window.xwbApi || typeof window.xwbApi.startMarketGraphRelationFetch !== 'function') {
    setMarketGraphLog('市场态星图采集 API 不可用。');
    return;
  }

  updateMarketGraphFetchControls(true);
  setMarketGraphLog('正在启动关系数据采集...');

  try {
    const response = await window.xwbApi.startMarketGraphRelationFetch(payload);

    if (!response.ok) {
      if (response.status) {
        marketGraphState.fetchRunning = Boolean(response.status.running);
        renderMarketGraphFetchStatus(response.status);
      }

      setMarketGraphLog(`采集启动失败：${formatMarketGraphStartError(response.error)}`);
      updateMarketGraphFetchControls(false);
      return;
    }

    const status = response.status || {};
    marketGraphState.fetchRunning = Boolean(status.running);
    renderMarketGraphFetchStatus(status);
    await refreshMarketGraphFetchErrors();

    if (response.alreadyRunning) {
      setMarketGraphLog('已有关系数据采集进程正在运行。');
    } else {
      setMarketGraphLog('关系数据采集已启动。');
    }

    if (marketGraphState.fetchRunning) {
      scheduleMarketGraphFetchPoll();
    }
  } catch (error) {
    setMarketGraphLog(`采集启动失败：${formatMarketGraphStartError(error && error.message ? error.message : error)}`);
    updateMarketGraphFetchControls(false);
  }
}

async function stopMarketGraphRelationFetch() {
  if (!window.xwbApi || typeof window.xwbApi.stopMarketGraphRelationFetch !== 'function') {
    setMarketGraphLog('市场态星图采集 API 不可用。');
    return;
  }

  setMarketGraphLog('正在停止关系数据采集...');

  try {
    const response = await window.xwbApi.stopMarketGraphRelationFetch();

    if (!response.ok) {
      setMarketGraphLog(`停止采集失败：${formatDisplayError(response.error)}`);
      return;
    }

    const status = response.status || {};
    marketGraphState.fetchRunning = Boolean(status.running);
    renderMarketGraphFetchStatus(status);
    setMarketGraphLog(marketGraphState.fetchRunning ? '已请求停止采集。' : '当前没有运行中的采集进程。');

    if (marketGraphState.fetchRunning) {
      scheduleMarketGraphFetchPoll();
    } else {
      clearMarketGraphFetchPoll();
      await refreshMarketGraphFetchErrors();
    }
  } catch (error) {
    setMarketGraphLog(`停止采集失败：${formatDisplayError(error && error.message ? error.message : error)}`);
  }
}

