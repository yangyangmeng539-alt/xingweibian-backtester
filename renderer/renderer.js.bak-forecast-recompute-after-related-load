function renderFullMarketSyncProgress(progress) {
  const data = progress || {};
  const currentText = data.currentSymbol
    ? `${data.currentSymbol}${data.currentName ? ` ${data.currentName}` : ''}`
    : '-';
  const percent = clamp(Number(data.percent) || 0, 0, 100);

  if (syncTotalText) syncTotalText.textContent = formatNumber(data.total, 0);
  if (syncDoneText) syncDoneText.textContent = formatNumber(data.done, 0);
  if (syncSkippedText) syncSkippedText.textContent = formatNumber(data.skipped, 0);
  if (syncNoDailyBarsText) syncNoDailyBarsText.textContent = formatNumber(data.noDailyBars, 0);
  if (syncFailedText) syncFailedText.textContent = formatNumber(data.failed, 0);
  if (syncActiveText) syncActiveText.textContent = formatNumber(data.activeWorkers, 0);
  if (syncCurrentText) syncCurrentText.textContent = currentText;
  if (syncStatusText) syncStatusText.textContent = data.currentStatus || (data.running ? 'RUNNING' : '-');
  if (syncElapsedText) syncElapsedText.textContent = formatDuration(data.elapsedMs);
  if (syncRemainingText) {
    syncRemainingText.textContent = data.running && (!Number.isFinite(Number(data.estimatedRemainingMs)) || Number(data.estimatedRemainingMs) <= 0)
      ? '估算中'
      : formatDuration(data.estimatedRemainingMs);
  }
  if (syncAvgCostText) syncAvgCostText.textContent = formatDuration(data.avgCostMs);
  if (syncStatePathText) syncStatePathText.textContent = data.statePath || '-';
  if (syncProgressFill) syncProgressFill.style.width = `${percent}%`;
  setSyncMessage(data.lastMessage || `进度 ${percent.toFixed(2)}%`);
}

function stopFullMarketSyncPolling() {
  if (fullMarketSyncPollTimer) {
    clearInterval(fullMarketSyncPollTimer);
    fullMarketSyncPollTimer = null;
  }
}

async function pollFullMarketSyncStatus() {
  try {
    const api = getSyncApiForMarket(activeSyncMarket);

    if (!window.xwbApi || typeof api.status !== 'function') {
      return;
    }

    const response = await api.status();

    if (!response.ok) {
      setSyncMessage(`状态读取失败：${formatDisplayError(response.error)}`);
      stopFullMarketSyncPolling();
      return;
    }

    renderFullMarketSyncProgress(response.progress);

    if (!response.progress || !response.progress.running) {
      stopFullMarketSyncPolling();
    }
  } catch (error) {
    setSyncMessage(`状态读取失败：${formatDisplayError(error && error.message ? error.message : error)}`);
    stopFullMarketSyncPolling();
  }
}

function startFullMarketSyncPolling() {
  stopFullMarketSyncPolling();
  fullMarketSyncPollTimer = setInterval(() => {
    pollFullMarketSyncStatus();
  }, 1000);
}

