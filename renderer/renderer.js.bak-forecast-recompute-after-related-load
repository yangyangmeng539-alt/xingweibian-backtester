      <line class="chart-grid-line" x1="${layout.left}" y1="${pricePanel.top}" x2="${layout.left}" y2="${pricePanel.bottom}"></line>
      <line class="chart-grid-line" x1="${layout.left}" y1="${pricePanel.bottom}" x2="${layout.right}" y2="${pricePanel.bottom}"></line>
      <line class="chart-grid-line" x1="${layout.left}" y1="${equityPanel.top}" x2="${layout.left}" y2="${equityPanel.bottom}"></line>
      <line class="chart-grid-line" x1="${layout.left}" y1="${equityPanel.bottom}" x2="${layout.right}" y2="${equityPanel.bottom}"></line>
      <text class="curve-layer-label" x="${layout.left}" y="${pricePanel.top - 10}">价格 close</text>
      <text class="curve-layer-label" x="${layout.left}" y="${equityPanel.top - 10}">最终资金 equity</text>
      <text class="chart-range-label" x="${layout.right}" y="${pricePanel.top - 10}">${formatText(rangeLabel)}</text>
      ${renderSvgPolyline(pricePoints, 'chart-line price-line')}
      ${equityLines}
      <g id="curveMarkerLayer">${markerHtml}</g>
      <line class="curve-crosshair" id="curveCrosshair" x1="0" y1="${pricePanel.top}" x2="0" y2="${equityPanel.bottom}" visibility="hidden"></line>
      <g id="activeCurvePointLayer"></g>
      <rect class="curve-event-layer" x="${layout.left}" y="${pricePanel.top}" width="${layout.right - layout.left}" height="${equityPanel.bottom - pricePanel.top}"></rect>
      <g id="nodeHitLayer">${nodeHitPointHtml}</g>
      <g id="forecastOverlayLayer"></g>
      <g id="forecastZoomInsetLayer"></g>
      ${renderInteractiveAxisTicks(axisTicks, height, equityPanel)}
    </svg>
    <div class="curve-legend">
      <span><i class="legend-line price"></i>价格</span>
      ${data.models.map((model) => `<span><i class="legend-line" style="background: ${getModelColor(model.modelId)}"></i>${formatText(model.algoVersion || model.modelId)} 最终资金</span>`).join('')}
