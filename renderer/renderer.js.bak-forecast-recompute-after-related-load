function normalizeTimelineDate(value) {
  const text = String(value || '').trim();

  if (/^\d{4}-\d{2}-\d{2}/.test(text)) {
    return text.slice(0, 10);
  }

  if (/^\d{8}$/.test(text)) {
    return `${text.slice(0, 4)}-${text.slice(4, 6)}-${text.slice(6, 8)}`;
  }

  return '';
}

function getTimelineSeries(result) {
  return (Array.isArray(result && result.priceSeries) ? result.priceSeries : [])
    .map((item) => ({
      ...(item || {}),
      date: normalizeTimelineDate(item && item.date)
    }))
    .filter((item) => item.date && Number.isFinite(Number(item.close)))
    .sort((left, right) => String(left.date).localeCompare(String(right.date)));
}

function buildTimelineOptions(result) {
  const series = getTimelineSeries(result);
  const monthsByYear = {};

  for (const item of series) {
    const year = item.date.slice(0, 4);
    const month = item.date.slice(5, 7);

    if (!monthsByYear[year]) {
      monthsByYear[year] = new Set();
    }

    monthsByYear[year].add(month);
  }

  const normalizedMonthsByYear = {};
  Object.entries(monthsByYear).forEach(([year, months]) => {
    normalizedMonthsByYear[year] = Array.from(months).sort();
  });

  const years = Object.keys(normalizedMonthsByYear).sort();

  return {
    series,
    years,
    monthsByYear: normalizedMonthsByYear,
    minDate: series.length ? series[0].date : '',
    maxDate: series.length ? series[series.length - 1].date : ''
  };
}

function mergeTimelineState(value) {
  const raw = value && typeof value === 'object' ? value : {};
  const mode = TIMELINE_MODES.has(raw.mode) ? raw.mode : TIMELINE_DEFAULT_STATE.mode;
  const rawMonth = String(raw.month || '').trim();
  const quick = Object.prototype.hasOwnProperty.call(TIMELINE_QUICK_WINDOWS, raw.quick) || raw.quick === 'trade'
    ? raw.quick
    : '';

  return {
    ...TIMELINE_DEFAULT_STATE,
    ...raw,
    mode,
    quick,
    year: String(raw.year || ''),
    month: rawMonth ? rawMonth.padStart(2, '0').slice(-2) : '',
    date: normalizeTimelineDate(raw.date),
    rangeStart: normalizeTimelineDate(raw.rangeStart),
    rangeEnd: normalizeTimelineDate(raw.rangeEnd)
  };
}

function getTimelineState() {
  try {
    return mergeTimelineState(JSON.parse(localStorage.getItem(TIMELINE_STORAGE_KEY) || 'null'));
  } catch (_error) {
    return mergeTimelineState(currentTimelineState);
  }
}

function saveTimelineState(state) {
  currentTimelineState = mergeTimelineState(state);

  try {
    localStorage.setItem(TIMELINE_STORAGE_KEY, JSON.stringify(currentTimelineState));
  } catch (_error) {
    // localStorage 不可用时不影响图表观察。
  }
}

function getDefaultTimelineYear(options) {
  return options.years[options.years.length - 1] || '';
}

function getDefaultTimelineMonth(options, year) {
  const months = options.monthsByYear[year] || [];
  return months[months.length - 1] || '';
}

function findNearestTimelineIndex(series, date) {
  const cleanDate = normalizeTimelineDate(date);

  if (series.length === 0 || !cleanDate) {
    return -1;
  }

  const exactIndex = series.findIndex((item) => item.date === cleanDate);

  if (exactIndex >= 0) {
    return exactIndex;
  }

  let nearestIndex = 0;
  let nearestDistance = Infinity;
  const targetTime = new Date(`${cleanDate}T00:00:00`).getTime();

  if (!Number.isFinite(targetTime)) {
    return -1;
  }

  series.forEach((item, index) => {
    const time = new Date(`${item.date}T00:00:00`).getTime();
    const distance = Math.abs(time - targetTime);

    if (distance < nearestDistance) {
      nearestDistance = distance;
      nearestIndex = index;
    }
  });

  return nearestIndex;
}

function normalizeTimelineStateForResult(inputState, options) {
  const state = mergeTimelineState(inputState);

  if (options.series.length === 0) {
    return { ...TIMELINE_DEFAULT_STATE };
  }

  if (state.quick && Object.prototype.hasOwnProperty.call(TIMELINE_QUICK_WINDOWS, state.quick)) {
    return {
      ...state,
      mode: 'range'
    };
  }

  if (state.quick === 'trade') {
    const hasRange = state.rangeStart && state.rangeEnd
      && state.rangeEnd >= options.minDate
      && state.rangeStart <= options.maxDate;

    return hasRange ? state : { ...TIMELINE_DEFAULT_STATE };
  }

  if (state.mode === 'year') {
    return options.years.includes(state.year)
      ? state
      : { ...TIMELINE_DEFAULT_STATE };
  }

  if (state.mode === 'month') {
    const months = options.monthsByYear[state.year] || [];
    return months.includes(state.month)
      ? state
      : { ...TIMELINE_DEFAULT_STATE };
  }

  if (state.mode === 'day') {
    return state.date && state.date >= options.minDate && state.date <= options.maxDate
      ? state
      : { ...TIMELINE_DEFAULT_STATE };
  }

  return state.mode === 'all' ? state : { ...TIMELINE_DEFAULT_STATE };
}

function getTimelineQuickAnchorIndex(series) {
  if (!Array.isArray(series) || series.length === 0) {
    return -1;
  }

  const selectedDate = normalizeTimelineDate(
    activeNodePredictionDate
    || (activeNodePredictionAnalysis && activeNodePredictionAnalysis.clickedDate)
  );

  if (selectedDate) {
    const selectedIndex = findNearestTimelineIndex(series, selectedDate);

    if (Number.isInteger(selectedIndex) && selectedIndex >= 0) {
      return selectedIndex;
    }
  }

  // 没有点击节点时，默认锚定最后一根 K 线，也就是现在/最新日期。
  return series.length - 1;
}

function getCenteredTimelineWindow(series, anchorIndex, size) {
  const count = Array.isArray(series) ? series.length : 0;
  const cleanSize = Math.max(1, Math.min(Number(size) || count, count));

  if (count <= 0) {
    return [];
  }

  const cleanAnchorIndex = Number.isInteger(anchorIndex)
    ? clamp(anchorIndex, 0, count - 1)
    : count - 1;

  // 如果节点就在最后附近，保持原来的“最近 N 根”逻辑，不往右越界。
  if (cleanAnchorIndex >= count - 1) {
    return series.slice(Math.max(0, count - cleanSize));
  }

  const halfLeft = Math.floor(cleanSize / 2);
  let startIndex = cleanAnchorIndex - halfLeft;
  let endIndex = startIndex + cleanSize - 1;

  if (startIndex < 0) {
    startIndex = 0;
    endIndex = cleanSize - 1;
  }

  if (endIndex >= count) {
    endIndex = count - 1;
    startIndex = Math.max(0, endIndex - cleanSize + 1);
  }

  return series.slice(startIndex, endIndex + 1);
}

function getTimelineWindow(state, options) {
  const series = options.series;

  if (series.length === 0) {
    return {
      series: [],
      startDate: '',
      endDate: ''
    };
  }

  if (state.quick && Object.prototype.hasOwnProperty.call(TIMELINE_QUICK_WINDOWS, state.quick)) {
    const size = TIMELINE_QUICK_WINDOWS[state.quick];
    const anchorIndex = getTimelineQuickAnchorIndex(series);
    const filtered = getCenteredTimelineWindow(series, anchorIndex, size);

    return {
      series: filtered,
      startDate: filtered[0] ? filtered[0].date : '',
      endDate: filtered[filtered.length - 1] ? filtered[filtered.length - 1].date : ''
    };
  }

  if (state.quick === 'trade' && state.rangeStart && state.rangeEnd) {
    const startDate = state.rangeStart <= state.rangeEnd ? state.rangeStart : state.rangeEnd;
    const endDate = state.rangeStart <= state.rangeEnd ? state.rangeEnd : state.rangeStart;
    const filtered = series.filter((item) => item.date >= startDate && item.date <= endDate);

    return {
      series: filtered,
      startDate,
      endDate
    };
  }

  if (state.mode === 'year') {
    const filtered = series.filter((item) => item.date.startsWith(state.year));

    return {
      series: filtered,
      startDate: `${state.year}-01-01`,
      endDate: `${state.year}-12-31`
    };
  }

  if (state.mode === 'month') {
    const prefix = `${state.year}-${state.month}`;
    const filtered = series.filter((item) => item.date.startsWith(prefix));

    return {
      series: filtered,
      startDate: `${prefix}-01`,
      endDate: `${prefix}-31`
    };
  }

  if (state.mode === 'day') {
    const centerIndex = findNearestTimelineIndex(series, state.date);
    const startIndex = Math.max(0, centerIndex - 20);
    const endIndex = Math.min(series.length - 1, centerIndex + 20);
    const filtered = centerIndex >= 0 ? series.slice(startIndex, endIndex + 1) : [];

    return {
      series: filtered,
      startDate: filtered[0] ? filtered[0].date : '',
      endDate: filtered[filtered.length - 1] ? filtered[filtered.length - 1].date : ''
    };
  }

  return {
    series,
    startDate: options.minDate,
    endDate: options.maxDate
  };
}

function filterModelEquityCurve(model, dateSet) {
  const curve = Array.isArray(model.equityCurve) ? model.equityCurve : [];

  return curve
    .map((point) => ({
      ...(point || {}),
      date: normalizeTimelineDate(point && point.date)
    }))
    .filter((point) => point.date && dateSet.has(point.date));
}

function applyTimelineFilter(result) {
  const options = buildTimelineOptions(result);
  const state = normalizeTimelineStateForResult(getTimelineState(), options);
  const timelineWindow = getTimelineWindow(state, options);
  const dateSet = new Set(timelineWindow.series.map((item) => item.date));
  const finalModel = getFinalDecisionModel(result);
  const models = finalModel
    ? [{
      ...finalModel,
      modelName: DECISION_CHAIN_NAME,
      equityCurve: filterModelEquityCurve(finalModel, dateSet)
    }]
    : [];

  currentTimelineState = state;

  return {
    ...result,
    priceSeries: timelineWindow.series,
    models,
    timeline: {
      state,
      options,
      startDate: timelineWindow.startDate,
      endDate: timelineWindow.endDate,
      totalCount: options.series.length,
      visibleCount: timelineWindow.series.length
    }
  };
}

function setSelectOptions(select, values, selectedValue) {
  if (!select) {
    return;
  }

  select.innerHTML = values
    .map((value) => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`)
    .join('');
  select.value = values.includes(selectedValue) ? selectedValue : (values[0] || '');
}

function getTimelineControlState(options) {
  const state = normalizeTimelineStateForResult(currentTimelineState, options);
  const year = options.years.includes(state.year) ? state.year : getDefaultTimelineYear(options);
  const month = (options.monthsByYear[year] || []).includes(state.month)
    ? state.month
    : getDefaultTimelineMonth(options, year);
  const date = state.date && state.date >= options.minDate && state.date <= options.maxDate
    ? state.date
    : options.maxDate;

  return {
    ...state,
    year,
    month,
    date
  };
}

function updateTimelineControlClasses(state) {
  const isYearMode = state.mode === 'year' || state.mode === 'month';
  const isMonthMode = state.mode === 'month';
  const isDayMode = state.mode === 'day';
  const quickButtons = {
    all: timelineQuickAll,
    '1y': timelineQuick1Y,
    '6m': timelineQuick6M,
    '3m': timelineQuick3M,
    '1m': timelineQuick1M
  };

  if (timelineModeSelect) {
    timelineModeSelect.classList.toggle('timeline-active', state.mode !== 'all' || Boolean(state.quick));
  }

  if (timelineYearSelect) {
    timelineYearSelect.classList.toggle('timeline-active', isYearMode);
  }

  if (timelineMonthSelect) {
    timelineMonthSelect.classList.toggle('timeline-active', isMonthMode);
  }

  if (timelineDateInput) {
    timelineDateInput.classList.toggle('timeline-active', isDayMode || state.quick === 'trade');
  }

  Object.entries(quickButtons).forEach(([key, button]) => {
    if (!button) {
      return;
    }

    const isActive = key === 'all'
      ? state.mode === 'all' && !state.quick
      : state.quick === key;
    button.classList.toggle('timeline-active', isActive);
  });
}

function renderTimelineControls(result) {
  if (!timelineControlBox) {
    return;
  }

  const options = buildTimelineOptions(result);
  const state = getTimelineControlState(options);
  const months = options.monthsByYear[state.year] || [];
  const hasData = options.series.length > 0;

  timelineControlBox.hidden = !hasData;

  if (!hasData) {
    return;
  }

  if (timelineModeSelect) {
    timelineModeSelect.value = ['all', 'year', 'month', 'day'].includes(state.mode)
      ? state.mode
      : 'all';
    timelineModeSelect.onchange = () => {
      const mode = timelineModeSelect.value;
      const nextYear = state.year || getDefaultTimelineYear(options);
      const nextMonth = state.month || getDefaultTimelineMonth(options, nextYear);
      const nextDate = state.date || options.maxDate;

      saveTimelineState({
        mode,
        year: mode === 'year' || mode === 'month' ? nextYear : '',
        month: mode === 'month' ? nextMonth : '',
        date: mode === 'day' ? nextDate : '',
        quick: '',
        rangeStart: '',
        rangeEnd: ''
      });
      renderInteractiveCurve(result);
    };
  }

  setSelectOptions(timelineYearSelect, options.years, state.year);
  setSelectOptions(timelineMonthSelect, months, state.month);

  if (timelineYearSelect) {
    timelineYearSelect.disabled = state.mode !== 'year' && state.mode !== 'month';
    timelineYearSelect.onchange = () => {
      const year = timelineYearSelect.value;
      const nextMonth = getDefaultTimelineMonth(options, year);

      saveTimelineState({
        mode: state.mode === 'month' ? 'month' : 'year',
        year,
        month: state.mode === 'month' ? nextMonth : '',
        date: '',
        quick: '',
        rangeStart: '',
        rangeEnd: ''
      });
      renderInteractiveCurve(result);
    };
  }

  if (timelineMonthSelect) {
    timelineMonthSelect.disabled = state.mode !== 'month';
    timelineMonthSelect.onchange = () => {
      saveTimelineState({
        mode: 'month',
        year: timelineYearSelect ? timelineYearSelect.value : state.year,
        month: timelineMonthSelect.value,
        date: '',
        quick: '',
        rangeStart: '',
        rangeEnd: ''
      });
      renderInteractiveCurve(result);
    };
  }

  if (timelineDateInput) {
    timelineDateInput.min = options.minDate;
    timelineDateInput.max = options.maxDate;
    timelineDateInput.value = state.date || options.maxDate;
    timelineDateInput.disabled = state.mode !== 'day';
    timelineDateInput.onchange = () => {
      saveTimelineState({
        mode: 'day',
        year: '',
        month: '',
        date: timelineDateInput.value || options.maxDate,
        quick: '',
        rangeStart: '',
        rangeEnd: ''
      });
      renderInteractiveCurve(result);
    };
  }

  if (timelineQuickAll) {
    timelineQuickAll.onclick = () => {
      saveTimelineState({ ...TIMELINE_DEFAULT_STATE });
      renderInteractiveCurve(result);
    };
  }

  [
    [timelineQuick1Y, '1y'],
    [timelineQuick6M, '6m'],
    [timelineQuick3M, '3m'],
    [timelineQuick1M, '1m']
  ].forEach(([button, quick]) => {
    if (!button) {
      return;
    }

    button.onclick = () => {
      saveTimelineState({
        mode: 'range',
        year: '',
        month: '',
        date: '',
        quick,
        rangeStart: '',
        rangeEnd: ''
      });
      renderInteractiveCurve(result);
    };
  });

  updateTimelineControlClasses(state);
}

function isTradeVisibleInCurrentRange(trade) {
  const state = interactiveCurveState;

  if (!state || !state.data || !state.data.dateIndex || !trade) {
    return false;
  }

  return ['signalDate', 'entryDate', 'exitDate'].some((key) => {
    return state.data.dateIndex.has(normalizeTimelineDate(trade[key]));
  });
}

function setTimelineRangeByTrade(trade, result) {
  const options = buildTimelineOptions(result);
  const series = options.series;

  if (!trade || series.length === 0) {
    return false;
  }

  const signalDate = normalizeTimelineDate(trade.signalDate) || normalizeTimelineDate(trade.entryDate) || normalizeTimelineDate(trade.exitDate);
  const exitDate = normalizeTimelineDate(trade.exitDate) || normalizeTimelineDate(trade.entryDate) || signalDate;
  const signalIndex = findNearestTimelineIndex(series, signalDate);
  const exitIndex = findNearestTimelineIndex(series, exitDate);

  if (signalIndex < 0 || exitIndex < 0) {
    return false;
  }

  const startIndex = Math.max(0, Math.min(signalIndex, exitIndex) - 20);
  const endIndex = Math.min(series.length - 1, Math.max(signalIndex, exitIndex) + 20);
  const rangeStart = series[startIndex] ? series[startIndex].date : '';
  const rangeEnd = series[endIndex] ? series[endIndex].date : '';

  saveTimelineState({
    mode: 'range',
    year: signalDate.slice(0, 4),
    month: signalDate.slice(5, 7),
    date: signalDate,
    quick: 'trade',
    rangeStart,
    rangeEnd
  });

  return Boolean(rangeStart && rangeEnd);
}

function buildInteractiveCurveData(result) {
  const series = getTimelineSeries(result);
  const rows = getDecisionTradeRows(result);
  const finalModel = getFinalDecisionModel(result);
  const models = finalModel ? [finalModel] : [];
  const diagnostics = finalModel && Array.isArray(finalModel.diagnostics)
    ? finalModel.diagnostics
    : [];
  const dailyStates = result && result.xwbStateAnalysis && Array.isArray(result.xwbStateAnalysis.dailyStates)
    ? result.xwbStateAnalysis.dailyStates
    : [];
  const dailyOpportunities = result && result.opportunityAnalysis && Array.isArray(result.opportunityAnalysis.dailyOpportunities)
    ? result.opportunityAnalysis.dailyOpportunities
    : [];
  const dateIndex = new Map(series.map((item, index) => [String(item.date), index]));
  const priceByDate = new Map(series.map((item) => [String(item.date), Number(item.close)]));
  const eventsByIndex = new Map();
  const diagnosticsByIndex = new Map();
  const stateByDate = new Map();
  const stateByIndex = new Map();
  const opportunityByDate = new Map();
  const opportunityByIndex = new Map();
  const allMarkers = [];

  diagnostics.forEach((item) => {
    const date = normalizeTimelineDate(item && item.date);

    if (dateIndex.has(date)) {
      diagnosticsByIndex.set(dateIndex.get(date), item);
    }
  });

  dailyStates.forEach((item) => {
    const date = normalizeTimelineDate(item && item.date);

    if (date) {
      stateByDate.set(date, item);
    }
  });

  dailyOpportunities.forEach((item) => {
    const date = normalizeTimelineDate(item && item.date);

    if (date) {
      opportunityByDate.set(date, item);
    }
  });

  series.forEach((item, index) => {
    const date = normalizeTimelineDate(item && item.date);
    const dailyState = stateByDate.get(date);
    const opportunity = opportunityByDate.get(date);

    if (dailyState) {
      stateByIndex.set(index, dailyState);
    }

    if (opportunity) {
      opportunityByIndex.set(index, opportunity);
    }
  });

  rows.forEach((row, rowIndex) => {
    [
      ['signalDate', '信', 'signal'],
      ['entryDate', '买', 'entry'],
      ['exitDate', '卖', 'exit']
    ].forEach(([key, label, type]) => {
      const date = normalizeTimelineDate(row.trade[key]);

      if (!dateIndex.has(date)) {
        return;
      }

      const index = dateIndex.get(date);
      const event = {
        row,
        rowIndex,
        date,
        index,
        label,
        type,
        markerKey: `${rowIndex}-${type}`
      };

      allMarkers.push(event);

      if (!eventsByIndex.has(index)) {
        eventsByIndex.set(index, []);
      }

      eventsByIndex.get(index).push(event);
    });
  });

  const markers = allMarkers;
  const equityByModel = models.map((model) => {
    const curve = Array.isArray(model.equityCurve) ? model.equityCurve : [];
    const byDate = new Map(curve
      .map((point) => [normalizeTimelineDate(point && point.date), point])
      .filter(([date]) => Boolean(date)));

    return {
      model,
      curve,
      byDate
    };
  });

  return {
    result,
    series,
    rows,
    models,
    dateIndex,
    priceByDate,
    eventsByIndex,
    diagnosticsByIndex,
    stateByIndex,
    opportunityByIndex,
    markers,
    equityByModel
  };
}

function getPanelPoint(index, value, total, minValue, maxValue, layout, panel) {
  const x = total <= 1
    ? (layout.left + layout.right) / 2
    : layout.left + (index / (total - 1)) * (layout.right - layout.left);
  const range = maxValue - minValue;
  const y = range <= 0
    ? (panel.top + panel.bottom) / 2
    : panel.bottom - ((value - minValue) / range) * (panel.bottom - panel.top);

  return {
    x,
    y
  };
}

function getInteractiveIndexFromX(x, state) {
  const count = state.data.series.length;

  if (count <= 1) {
    return 0;
  }

  const ratio = (x - state.layout.left) / (state.layout.right - state.layout.left);
  return clamp(Math.round(ratio * (count - 1)), 0, count - 1);
}

function getInteractiveX(index, state) {
  const count = state.data.series.length;

  if (count <= 1) {
    return (state.layout.left + state.layout.right) / 2;
  }

  return state.layout.left + (index / (count - 1)) * (state.layout.right - state.layout.left);
}

function getInteractiveXByCount(index, count, layout) {
  if (count <= 1) {
    return (layout.left + layout.right) / 2;
  }

  return layout.left + (index / (count - 1)) * (layout.right - layout.left);
}

function getTimelineSpanMode(series) {
  if (!Array.isArray(series) || series.length === 0) {
    return 'day';
  }

  const firstDate = normalizeTimelineDate(series[0].date);
  const lastDate = normalizeTimelineDate(series[series.length - 1].date);

  if (!firstDate || !lastDate) {
    return 'day';
  }

  const sameYear = firstDate.slice(0, 4) === lastDate.slice(0, 4);
  const sameMonth = firstDate.slice(0, 7) === lastDate.slice(0, 7);

  if (!sameYear) {
    return 'multi-year';
  }

  if (!sameMonth) {
    return 'year';
  }

  return 'month';
}

function formatInteractiveAxisDate(date, spanMode) {
  const cleanDate = normalizeTimelineDate(date);

  if (!cleanDate) {
    return '';
  }

  if (spanMode === 'multi-year') {
    return cleanDate.slice(0, 7);
  }

  return cleanDate.slice(5, 10);
}

function buildInteractiveAxisTicks(series, layout) {
  const count = Array.isArray(series) ? series.length : 0;

  if (count === 0) {
    return [];
  }

  const targetCount = Math.min(8, Math.max(2, count));
  const spanMode = getTimelineSpanMode(series);
  const indexes = new Set();

  if (targetCount === 1) {
    indexes.add(0);
  } else {
    for (let i = 0; i < targetCount; i += 1) {
      indexes.add(Math.round((i / (targetCount - 1)) * (count - 1)));
    }
  }

  indexes.add(0);
  indexes.add(count - 1);

  return Array.from(indexes)
    .sort((left, right) => left - right)
    .map((index) => {
      const item = series[index] || {};
      const isStart = index === 0;
      const isEnd = index === count - 1;

      return {
        index,
        date: normalizeTimelineDate(item.date),
        label: formatInteractiveAxisDate(item.date, spanMode),
        x: getInteractiveXByCount(index, count, layout),
        tone: isStart || isEnd ? 'edge' : 'middle',
        anchor: isStart ? 'start' : (isEnd ? 'end' : 'middle')
      };
    })
    .filter((tick) => tick.date && tick.label);
}

function renderInteractiveAxisTicks(ticks, height, equityPanel) {
  if (!Array.isArray(ticks) || ticks.length === 0) {
