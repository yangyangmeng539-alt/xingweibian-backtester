function setSupplyChainEditorStatus(text) {
  if (supplyChainEditorStatus) {
    supplyChainEditorStatus.textContent = text || '';
  }
}

function normalizeSupplyChainEditorStock(raw) {
  const source = raw && typeof raw === 'object' ? raw : {};
  const code = normalizeObservationStockCode(source.code || source.symbol);

  if (!code) {
    return null;
  }

  return {
    code,
    symbol: code,
    name: String(source.name || source.stockName || source.label || code).trim(),
    market: code.startsWith('HK:') ? 'HK' : 'CN_A',
    note: String(source.note || '').trim()
  };
}

function getSupplyChainEditorLayerStocks(layer) {
  const list = supplyChainEditorState.layers[layer];

  return Array.isArray(list) ? list : [];
}

function addStockToSupplyChainEditorLayer(layer, stock) {
  const normalizedLayer = SUPPLY_CHAIN_LAYER_DEFS.some((def) => def.key === layer) ? layer : '';

  if (!normalizedLayer) {
    return false;
  }

  const normalizedStock = normalizeSupplyChainEditorStock(stock);

  if (!normalizedStock) {
    return false;
  }

  const list = getSupplyChainEditorLayerStocks(normalizedLayer);
  const existed = list.some((item) => item.code === normalizedStock.code);

  if (existed) {
    setSupplyChainEditorStatus(`${normalizedStock.code} 已在 ${normalizedLayer} 层。`);
    return false;
  }

  supplyChainEditorState.layers[normalizedLayer] = [
    ...list,
    normalizedStock
  ];

  renderSupplyChainEditorLayers();
  setSupplyChainEditorStatus(`已加入：${normalizedStock.code} ${normalizedStock.name}`);

  return true;
}

function removeStockFromSupplyChainEditorLayer(layer, code) {
  const normalizedLayer = SUPPLY_CHAIN_LAYER_DEFS.some((def) => def.key === layer) ? layer : '';

  if (!normalizedLayer) {
    return;
  }

  const normalizedCode = normalizeObservationStockCode(code);
  const list = getSupplyChainEditorLayerStocks(normalizedLayer);

  supplyChainEditorState.layers[normalizedLayer] = list.filter((item) => item.code !== normalizedCode);
  renderSupplyChainEditorLayers();
}

function renderSupplyChainEditorSearchResult(items) {
  if (!supplyChainEditorSearchResult) {
    return;
  }

  const list = Array.isArray(items) ? items : [];

  if (!list.length) {
    supplyChainEditorSearchResult.innerHTML = '<div class="supply-chain-editor-empty">暂无搜索结果。</div>';
    return;
  }

  supplyChainEditorSearchResult.innerHTML = list.map((item, index) => `
    <div class="supply-chain-editor-stock-card" draggable="true" data-stock-index="${index}">
      <b>${formatText(item.code)}</b>
      <span>${formatText(item.name || '-')}</span>
      <em>${formatText(item.market || '')}</em>
    </div>
  `).join('');

  supplyChainEditorSearchResult.querySelectorAll('.supply-chain-editor-stock-card').forEach((card) => {
    card.addEventListener('dragstart', (event) => {
      const index = Number(card.dataset.stockIndex);
      const stock = supplyChainEditorState.searchItems[index];

      if (!stock) {
        return;
      }

      event.dataTransfer.setData('application/json', JSON.stringify(stock));
      event.dataTransfer.effectAllowed = 'copy';
    });
  });
}

function renderSupplyChainEditorLayers() {
  if (!supplyChainEditorDropGrid) {
    return;
  }

  SUPPLY_CHAIN_LAYER_DEFS.forEach((def) => {
    const box = supplyChainEditorDropGrid.querySelector(`[data-layer-list="${def.key}"]`);

    if (!box) {
      return;
    }

    const list = getSupplyChainEditorLayerStocks(def.key);

    if (!list.length) {
      box.innerHTML = '<div class="supply-chain-editor-drop-empty">拖入股票</div>';
      return;
    }

    box.innerHTML = list.map((stock) => `
      <div class="supply-chain-editor-added-stock">
        <div>
          <b>${formatText(stock.code)}</b>
          <span>${formatText(stock.name || '-')}</span>
          <em>${formatText(stock.market || '')}</em>
        </div>
        <button type="button" data-remove-layer="${formatText(def.key)}" data-remove-code="${formatText(stock.code)}">移除</button>
      </div>
    `).join('');
  });

  supplyChainEditorDropGrid.querySelectorAll('button[data-remove-layer]').forEach((button) => {
    button.addEventListener('click', () => {
      removeStockFromSupplyChainEditorLayer(
        button.dataset.removeLayer || '',
        button.dataset.removeCode || ''
      );
    });
  });
}

function clearSupplyChainEditor() {
  supplyChainEditorState.editingChainId = '';

  supplyChainEditorState.layers = {
    upstream: [],
    midstream: [],
    downstream: [],
    service: [],
    terminal: []
  };

  if (supplyChainEditorPrimaryInput) supplyChainEditorPrimaryInput.value = '';
  if (supplyChainEditorSecondaryInput) supplyChainEditorSecondaryInput.value = '';
  if (supplyChainEditorNoteInput) supplyChainEditorNoteInput.value = '';

  renderSupplyChainEditorLayers();
  setSupplyChainEditorStatus('编辑区已清空。');
}

async function searchSupplyChainEditorStocks() {
  if (!window.xwbApi || typeof window.xwbApi.searchSupplyChainEditorStocks !== 'function') {
    setSupplyChainEditorStatus('产业链编辑器搜索 API 不可用。');
    return;
  }

  const query = String(supplyChainEditorSearchInput && supplyChainEditorSearchInput.value || '').trim();

  if (!query) {
    setSupplyChainEditorStatus('请输入股票代码或名称。');
    return;
  }

  supplyChainEditorState.searching = true;
  if (supplyChainEditorSearchButton) supplyChainEditorSearchButton.disabled = true;
  setSupplyChainEditorStatus('正在搜索股票...');

  try {
    const response = await window.xwbApi.searchSupplyChainEditorStocks({
      query,
      maxResults: 24
    });

    if (!response || !response.ok) {
      setSupplyChainEditorStatus(`股票搜索失败：${formatDisplayError(response && response.error)}`);
      return;
    }

    supplyChainEditorState.searchItems = Array.isArray(response.items) ? response.items : [];
    renderSupplyChainEditorSearchResult(supplyChainEditorState.searchItems);
    setSupplyChainEditorStatus(`搜索完成：${supplyChainEditorState.searchItems.length} 条结果，可拖入编辑区。`);
  } catch (error) {
    setSupplyChainEditorStatus(`股票搜索失败：${formatDisplayError(error && error.message ? error.message : error)}`);
  } finally {
    supplyChainEditorState.searching = false;
    if (supplyChainEditorSearchButton) supplyChainEditorSearchButton.disabled = false;
  }
}

function readSupplyChainEditorPayload() {
  return {
    id: supplyChainEditorState.editingChainId || '',
    primaryName: String(supplyChainEditorPrimaryInput && supplyChainEditorPrimaryInput.value || '').trim(),
    secondaryName: String(supplyChainEditorSecondaryInput && supplyChainEditorSecondaryInput.value || '').trim(),
    note: String(supplyChainEditorNoteInput && supplyChainEditorNoteInput.value || '').trim(),
    layers: supplyChainEditorState.layers
  };
}

function normalizeSupplyChainEditorLayersFromChain(chain) {
  const result = {
    upstream: [],
    midstream: [],
    downstream: [],
    service: [],
    terminal: []
  };

  const layers = chain && chain.layers && typeof chain.layers === 'object'
    ? chain.layers
    : {};

  SUPPLY_CHAIN_LAYER_DEFS.forEach((def) => {
    const layerValue = layers[def.key];

    let stocks = [];

    if (Array.isArray(layerValue)) {
      stocks = layerValue;
    } else if (layerValue && Array.isArray(layerValue.stocks)) {
      stocks = layerValue.stocks;
    }

    result[def.key] = stocks
      .map((item) => normalizeSupplyChainEditorStock(item))
      .filter(Boolean);
  });

  return result;
}

async function loadSelectedSupplyChainUserChainToEditor() {
  const selectedChainId = String(supplyChainState.selectedChainId || '').trim();

  if (!selectedChainId.startsWith('user-chain:')) {
    setSupplyChainEditorStatus('当前选中的不是用户自建产业链，不能载入编辑。');
    return;
  }

  if (!window.xwbApi || typeof window.xwbApi.querySupplyChainUserChain !== 'function') {
    setSupplyChainEditorStatus('用户产业链读取 API 不可用。');
    return;
  }

  setSupplyChainEditorStatus('正在载入当前自建产业链...');

  try {
    const response = await window.xwbApi.querySupplyChainUserChain({
      chainId: selectedChainId
    });

    if (!response || !response.ok || !response.chain || !response.chain.found) {
      setSupplyChainEditorStatus('载入失败：未找到当前自建产业链。');
      return;
    }

    const chain = response.chain;

    supplyChainEditorState.editingChainId = chain.id || selectedChainId;
    supplyChainEditorState.layers = normalizeSupplyChainEditorLayersFromChain(chain);

    if (supplyChainEditorPrimaryInput) {
      supplyChainEditorPrimaryInput.value = chain.parentName || '';
    }

    if (supplyChainEditorSecondaryInput) {
      supplyChainEditorSecondaryInput.value = chain.name || '';
    }

    if (supplyChainEditorNoteInput) {
      supplyChainEditorNoteInput.value = chain.note || '';
    }

    renderSupplyChainEditorLayers();
    setSupplyChainEditorStatus(`已载入编辑：${chain.parentName || ''} / ${chain.name || ''}`);
  } catch (error) {
    setSupplyChainEditorStatus(`载入失败：${formatDisplayError(error && error.message ? error.message : error)}`);
  }
}

function closeSupplyChainDeleteConfirm(confirmed) {
  if (supplyChainDeleteConfirmOverlay) {
    supplyChainDeleteConfirmOverlay.hidden = true;
    supplyChainDeleteConfirmOverlay.classList.remove('is-open');
  }

  const resolve = supplyChainDeleteConfirmResolve;
  supplyChainDeleteConfirmResolve = null;

  if (typeof resolve === 'function') {
    resolve(Boolean(confirmed));
  }
}

function openSupplyChainDeleteConfirm(options = {}) {
  if (!supplyChainDeleteConfirmOverlay) {
    setSupplyChainEditorStatus('删除确认框未初始化。');
    return Promise.resolve(false);
  }

  if (supplyChainDeleteConfirmTitle) {
    supplyChainDeleteConfirmTitle.textContent = options.title || '删除用户自建产业链';
  }

  if (supplyChainDeleteConfirmMessage) {
    supplyChainDeleteConfirmMessage.textContent = options.message || '确认删除当前选中的用户自建二级链？';
  }

  if (supplyChainDeleteConfirmTarget) {
    supplyChainDeleteConfirmTarget.textContent = options.target || '-';
  }

  supplyChainDeleteConfirmOverlay.hidden = false;

  requestAnimationFrame(() => {
    supplyChainDeleteConfirmOverlay.classList.add('is-open');

    if (supplyChainDeleteConfirmCancelButton) {
      supplyChainDeleteConfirmCancelButton.focus();
    }
  });

  return new Promise((resolve) => {
    supplyChainDeleteConfirmResolve = resolve;
  });
}

function initializeSupplyChainDeleteConfirmDialog() {
  if (!supplyChainDeleteConfirmOverlay) {
    return;
  }

  if (supplyChainDeleteConfirmCancelButton) {
    supplyChainDeleteConfirmCancelButton.addEventListener('click', () => {
      closeSupplyChainDeleteConfirm(false);
    });
  }

  if (supplyChainDeleteConfirmOkButton) {
    supplyChainDeleteConfirmOkButton.addEventListener('click', () => {
      closeSupplyChainDeleteConfirm(true);
    });
  }

  supplyChainDeleteConfirmOverlay.addEventListener('click', (event) => {
    if (event.target === supplyChainDeleteConfirmOverlay) {
      closeSupplyChainDeleteConfirm(false);
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && !supplyChainDeleteConfirmOverlay.hidden) {
      closeSupplyChainDeleteConfirm(false);
    }
  });
}

async function deleteSelectedSupplyChainUserChain() {
  const selectedChainId = String(supplyChainState.selectedChainId || '').trim();

  if (!selectedChainId.startsWith('user-chain:')) {
    setSupplyChainEditorStatus('当前选中的不是用户自建产业链，不能删除。');
    return;
  }

  if (!window.xwbApi || typeof window.xwbApi.deleteSupplyChainUserChain !== 'function') {
    setSupplyChainEditorStatus('用户产业链删除 API 不可用。');
    return;
  }

  const selectedChain = supplyChainState.selectedChain || {};
  const title = `${selectedChain.parentName || ''} / ${selectedChain.name || selectedChainId}`;

  const confirmed = await openSupplyChainDeleteConfirm({
    title: '删除用户自建产业链',
    message: '确认删除当前选中的用户自建二级链？',
    target: title
  });

  if (!confirmed) {
    setSupplyChainEditorStatus('已取消删除。');
    return;
  }

  setSupplyChainEditorStatus('正在删除用户自建产业链...');

  try {
    const response = await window.xwbApi.deleteSupplyChainUserChain({
      chainId: selectedChainId
    });

    if (!response || !response.ok) {
      setSupplyChainEditorStatus(`删除失败：${formatDisplayError(response && (response.error || response.reason))}`);
      return;
    }

    if (supplyChainEditorState.editingChainId === selectedChainId) {
      clearSupplyChainEditor();
    }

    setSupplyChainEditorStatus(`已删除：${title}`);
    await refreshSupplyChainPanel();
  } catch (error) {
    setSupplyChainEditorStatus(`删除失败：${formatDisplayError(error && error.message ? error.message : error)}`);
  }
}

async function saveSupplyChainEditorDraft() {
  if (!window.xwbApi || typeof window.xwbApi.saveSupplyChainUserChain !== 'function') {
    setSupplyChainEditorStatus('产业链保存 API 不可用。');
    return;
  }

  const payload = readSupplyChainEditorPayload();

  if (!payload.primaryName) {
    setSupplyChainEditorStatus('请输入一级产业链名称。');
    return;
  }

  if (!payload.secondaryName) {
    setSupplyChainEditorStatus('请输入二级细分链名称。');
    return;
  }

  const stockCount = Object.values(payload.layers || {}).reduce((sum, list) => {
    return sum + (Array.isArray(list) ? list.length : 0);
  }, 0);

  if (!stockCount) {
    setSupplyChainEditorStatus('请至少拖入一只股票。');
    return;
  }

  supplyChainEditorState.saving = true;
  if (supplyChainEditorSaveButton) supplyChainEditorSaveButton.disabled = true;
  setSupplyChainEditorStatus('正在保存用户自建产业链...');

  try {
    const response = await window.xwbApi.saveSupplyChainUserChain(payload);

    if (!response || !response.ok) {
      setSupplyChainEditorStatus(`保存失败：${formatDisplayError(response && response.error)}`);
      return;
    }

    setSupplyChainEditorStatus(`保存成功：${payload.primaryName} / ${payload.secondaryName}`);
    supplyChainEditorState.editingChainId = response.chainId || '';
    await refreshSupplyChainPanel();

    if (response.primaryId) {
      await selectSupplyChainPrimary(response.primaryId);
    }

    if (response.chainId) {
      await selectSupplyChainChain(response.chainId);
    }
  } catch (error) {
    setSupplyChainEditorStatus(`保存失败：${formatDisplayError(error && error.message ? error.message : error)}`);
  } finally {
    supplyChainEditorState.saving = false;
    if (supplyChainEditorSaveButton) supplyChainEditorSaveButton.disabled = false;
  }
}

function initializeSupplyChainEditorPanel() {
  if (!supplyChainEditorPanel) {
    return;
  }

  initializeSupplyChainDeleteConfirmDialog();

  renderSupplyChainEditorLayers();

  if (supplyChainEditorSearchButton) {
    supplyChainEditorSearchButton.addEventListener('click', searchSupplyChainEditorStocks);
  }

  if (supplyChainEditorSearchInput) {
    supplyChainEditorSearchInput.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        searchSupplyChainEditorStocks();
      }
    });
  }

  if (supplyChainEditorLoadButton) {
    supplyChainEditorLoadButton.addEventListener('click', loadSelectedSupplyChainUserChainToEditor);
  }

  if (supplyChainEditorDeleteButton) {
    supplyChainEditorDeleteButton.addEventListener('click', deleteSelectedSupplyChainUserChain);
  }

  if (supplyChainEditorClearButton) {
    supplyChainEditorClearButton.addEventListener('click', clearSupplyChainEditor);
  }

  if (supplyChainEditorSaveButton) {
    supplyChainEditorSaveButton.addEventListener('click', saveSupplyChainEditorDraft);
  }

  supplyChainEditorDropGrid.querySelectorAll('.supply-chain-editor-drop-zone').forEach((zone) => {
    zone.addEventListener('dragover', (event) => {
      event.preventDefault();
      zone.classList.add('is-drag-over');
      event.dataTransfer.dropEffect = 'copy';
    });

    zone.addEventListener('dragleave', () => {
      zone.classList.remove('is-drag-over');
    });

    zone.addEventListener('drop', (event) => {
      event.preventDefault();
      zone.classList.remove('is-drag-over');

      try {
        const stock = JSON.parse(event.dataTransfer.getData('application/json') || 'null');
        addStockToSupplyChainEditorLayer(zone.dataset.layer || '', stock);
      } catch (_error) {
        setSupplyChainEditorStatus('拖入失败：股票数据无效。');
      }
    });
  });
}

function setSupplyChainStatus(text) {
  if (supplyChainStatus) {
    supplyChainStatus.textContent = text || '';
  }
}

function setSupplyChainBusy(button, busy) {
  if (button) {
    button.disabled = Boolean(busy);
  }
}

function formatSupplyChainConfidence(value) {
  const num = Number(value);

  if (!Number.isFinite(num)) {
    return '-';
  }

  const percent = num <= 1 ? num * 100 : num;
  return `${percent.toFixed(percent >= 10 ? 1 : 2)}%`;
}

function getSupplyChainSourceLabel(item) {
  if (item && item.source === 'inferred') {
    return '系统推断';
  }

  return item && item.sourceLabel ? item.sourceLabel : '-';
}

function isUserSupplyChainEntity(item) {
  const source = String(item && item.source || '').toLowerCase();
  const id = String(item && item.id || '');

  return source === 'user'
    || id.startsWith('user-primary:')
    || id.startsWith('user-chain:');
}

function getSupplyChainUserBadgeHtml(item) {
  if (!isUserSupplyChainEntity(item)) {
    return '';
  }

  return '<em class="supply-chain-user-badge">自建</em>';
}

function getSupplyChainListItemClass(item, activeClass) {
  const userClass = isUserSupplyChainEntity(item) ? ' is-user-chain' : '';

  return `supply-chain-list-item${activeClass || ''}${userClass}`;
}

function renderSupplyChainSummary(summary) {
  const data = summary || {};

  if (supplyChainPrimaryCountText) supplyChainPrimaryCountText.textContent = formatNumber(data.primaryChainCount || 0, 0);
  if (supplyChainSecondaryCountText) supplyChainSecondaryCountText.textContent = formatNumber(data.secondaryChainCount || 0, 0);
  if (supplyChainStockCountText) supplyChainStockCountText.textContent = formatNumber(data.stockCount || 0, 0);
  if (supplyChainAssignmentCountText) supplyChainAssignmentCountText.textContent = formatNumber(data.assignmentTotal || 0, 0);

  if (supplyChainModeBadge) {
    supplyChainModeBadge.textContent = data.version ? 'SEED V2' : 'SEED';
  }
}

function renderSupplyChainPrimaryList() {
  if (!supplyChainPrimaryList) {
    return;
  }

  if (!supplyChainState.primaryChains.length) {
    supplyChainPrimaryList.textContent = '暂无一级产业链。';
    return;
  }

  supplyChainPrimaryList.innerHTML = supplyChainState.primaryChains.map((chain) => {
    const activeClass = chain.id === supplyChainState.selectedPrimaryId ? ' is-active' : '';
    const itemClass = getSupplyChainListItemClass(chain, activeClass);
