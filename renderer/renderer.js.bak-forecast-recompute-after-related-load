function areParamsEqual(left, right) {
  return Object.keys(defaultBacktestParams).every((key) => {
    return Number(left[key]) === Number(right[key]);
  });
}

function getPresetKeyForParams(params) {
  for (const [key, preset] of Object.entries(backtestParamPresets)) {
    if (areParamsEqual(params, preset.params)) {
      return key;
    }
  }

  return 'custom';
}

function setPresetLabel(presetKey) {
  currentPresetKey = presetKey;
  paramsPresetName.textContent = presetKey === 'custom'
    ? '自定义参数'
    : backtestParamPresets[presetKey].name;
}

function applyParamsToInputs(params) {
  const merged = {
    ...defaultBacktestParams,
    ...(params || {})
  };

  for (const [key, input] of Object.entries(paramInputs)) {
    input.value = merged[key];
  }

  setPresetLabel(getPresetKeyForParams(merged));
}

function saveParamsToStorage(params, presetKey) {
  try {
    localStorage.setItem(PARAMS_STORAGE_KEY, JSON.stringify({
      presetKey,
      params
    }));
  } catch (_error) {
    // localStorage 不可用时不影响回测。
  }
}

function loadParamsFromStorage() {
  try {
    const saved = JSON.parse(localStorage.getItem(PARAMS_STORAGE_KEY) || 'null');

    if (!saved || typeof saved !== 'object') {
      return null;
    }

    return {
      presetKey: saved.presetKey || 'custom',
      params: {
        ...defaultBacktestParams,
        ...(saved.params || {})
      }
    };
  } catch (_error) {
    return null;
  }
}

function applyPreset(presetKey) {
  const preset = backtestParamPresets[presetKey] || backtestParamPresets.standard;
  const params = {
    ...preset.params
  };

  applyParamsToInputs(params);
  setPresetLabel(presetKey);
  saveParamsToStorage(params, presetKey);
}

function updateAdvancedParamsState(expanded) {
  advancedParams.hidden = !expanded;
  paramsToggle.setAttribute('aria-expanded', String(expanded));
  paramsToggle.textContent = expanded ? '收起高级参数' : '展开高级参数';
}

function parseParam(input, key, label, rules) {
  const raw = input.value.trim();
  const value = raw === '' ? defaultBacktestParams[key] : Number(raw);

  if (!Number.isFinite(value)) {
    return {
      error: `${label}必须是数字。`
    };
  }

  if (rules.integer && !Number.isInteger(value)) {
    return {
      error: `${label}必须是整数。`
    };
  }

  if (rules.greaterThan !== undefined && value <= rules.greaterThan) {
    return {
      error: `${label}必须大于 ${rules.greaterThan}。`
    };
  }

  if (rules.min !== undefined && value < rules.min) {
    return {
      error: `${label}不能小于 ${rules.min}。`
    };
  }

  if (rules.maxExclusive !== undefined && value >= rules.maxExclusive) {
    return {
      error: `${label}必须小于 ${rules.maxExclusive}。`
    };
  }

  return {
    value
  };
}

function readBacktestParams() {
  const fields = [
    ['initialCapital', initialCapitalInput, '初始资金', { greaterThan: 0 }],
    ['commissionRate', commissionRateInput, '佣金率', { min: 0 }],
    ['minCommission', minCommissionInput, '最低佣金', { min: 0 }],
    ['stampTaxRate', stampTaxRateInput, '印花税', { min: 0 }],
    ['transferFeeRate', transferFeeRateInput, '过户费', { min: 0 }],
    ['slippageRate', slippageRateInput, '滑点', { min: 0, maxExclusive: 1 }],
    ['holdDaysAB', holdDaysABInput, 'A/B 持仓天数', { integer: true, min: 1 }],
    ['holdDaysC', holdDaysCInput, 'C 持仓天数', { integer: true, min: 1 }],
    ['stopLossPct', stopLossPctInput, '止损比例', { greaterThan: 0, maxExclusive: 1 }]
  ];
  const params = {};

  for (const [key, input, label, rules] of fields) {
    const parsed = parseParam(input, key, label, rules);

    if (parsed.error) {
      return parsed;
    }

    params[key] = parsed.value;
  }

  return {
    params
  };
}

function persistCurrentParams() {
  const parsed = readBacktestParams();

  if (parsed.error) {
    setPresetLabel('custom');
    return;
  }

  const presetKey = getPresetKeyForParams(parsed.params);
  setPresetLabel(presetKey);
  saveParamsToStorage(parsed.params, presetKey);
}

function initializeParams() {
  const saved = loadParamsFromStorage();

  if (saved) {
    applyParamsToInputs(saved.params);
  } else {
    applyPreset('standard');
  }

  updateAdvancedParamsState(false);

  paramsToggle.addEventListener('click', () => {
    updateAdvancedParamsState(advancedParams.hidden);
  });

  document.querySelectorAll('[data-preset]').forEach((button) => {
    button.addEventListener('click', () => {
      applyPreset(button.dataset.preset);
    });
  });

  resetParamsButton.addEventListener('click', () => {
    applyPreset('standard');
  });

  Object.values(paramInputs).forEach((input) => {
    input.addEventListener('change', persistCurrentParams);
  });
}

function getMergedTrades(result) {
  const finalModel = getFinalDecisionModel(result);
  const models = finalModel ? [finalModel] : [];
  const rows = [];

  for (const model of models) {
    const trades = Array.isArray(model.trades)
      ? model.trades
      : (
        Array.isArray(model.allTrades)
          ? model.allTrades
          : (Array.isArray(model.sampleTrades) ? model.sampleTrades : [])
      );

    for (const trade of trades) {
      rows.push({
        model,
        trade
      });
    }
  }

  return rows.sort((left, right) => {
    const leftDate = String(left.trade.signalDate || '');
    const rightDate = String(right.trade.signalDate || '');

    if (leftDate !== rightDate) {
      return leftDate.localeCompare(rightDate);
    }

    return String(left.model.modelId || '').localeCompare(String(right.model.modelId || ''));
  });
}

function getModelById(result, modelId) {
  const models = Array.isArray(result && result.models) ? result.models : [];
  return models.find((model) => String(model.modelId || '') === modelId) || null;
}

function getModelByAlgoVersion(result, algoVersion) {
  const models = Array.isArray(result && result.models) ? result.models : [];
  return models.find((model) => String(model.algoVersion || '') === algoVersion) || null;
}

function getFinalDecisionModel(result) {
  const models = Array.isArray(result && result.models) ? result.models : [];
  return (
    getModelByAlgoVersion(result, FINAL_DECISION_ALGO_VERSION) ||
    getModelById(result, FINAL_DECISION_ALGO_VERSION) ||
    models[models.length - 1] ||
    null
  );
}

function hasDebugLegacyEnabled(result) {
  const value = result && result.options ? result.options.debugLegacy : false;
  return value === true || value === 'true';
}

function shouldShowLegacyComparison(result) {
  const comparison = result && result.comparison ? result.comparison : {};
  const legacyReturnPct = comparison.legacyReturnPct;

  return Boolean(
    hasDebugLegacyEnabled(result) &&
    legacyReturnPct !== null &&
    legacyReturnPct !== undefined &&
    Number.isFinite(Number(legacyReturnPct)) &&
    getModelByAlgoVersion(result, LEGACY_ALGO_VERSION)
  );
}

function getDisplayModels(result) {
  const finalModel = getFinalDecisionModel(result);
  const models = finalModel ? [finalModel] : [];

  if (shouldShowLegacyComparison(result)) {
    const legacyModel = getModelByAlgoVersion(result, LEGACY_ALGO_VERSION);

    if (legacyModel && legacyModel !== finalModel) {
      models.push(legacyModel);
    }
  }

  return models;
}

function getModelTrades(model) {
  if (!model) {
    return [];
  }

  if (Array.isArray(model.trades)) {
    return model.trades;
  }

  if (Array.isArray(model.allTrades)) {
    return model.allTrades;
  }

  return Array.isArray(model.sampleTrades) ? model.sampleTrades : [];
}

function getDecisionTradeRows(result) {
  const finalModel = getFinalDecisionModel(result);

  if (!finalModel) {
    return [];
  }

  return getModelTrades(finalModel)
    .map((trade) => ({
      model: finalModel,
      trade
    }))
    .sort((left, right) => {
      return String(left.trade.signalDate || '').localeCompare(String(right.trade.signalDate || ''));
    });
}

function getStageTradeCount(result, modelId) {
  return getModelTrades(getModelById(result, modelId)).length;
}

function getDecisionActionText(trade, eventType) {
  if (eventType === 'entry') {
    return '买入';
  }

  if (eventType === 'exit') {
    return '卖出';
  }

  if (trade && (trade.entryDate || trade.exitDate)) {
    return '买入→卖出';
  }

  return '观望';
}

function formatStagePassText(reasons, emptyText) {
  if (Array.isArray(reasons) && reasons.length > 0) {
    return `通过：${reasons.map((reason) => String(reason)).join('、')}`;
  }

  return `通过：${emptyText}`;
}

function getStageJudgmentText(trade, stage) {
  const source = trade || {};
  const textReasons = (reasons) => {
    return Array.isArray(reasons) && reasons.length > 0
      ? reasons.map((reason) => String(reason)).join('、')
      : '-';
  };

  if (stage.key === 'shape' && source.shapeStage) {
    return `${source.shapePassed ? '通过' : '未通过'}：${formatShapeType(source.shapeType)}；${textReasons(source.shapeReasons)}`;
  }

  if (stage.key === 'position' && source.positionStage) {
    return `${source.positionPassed ? '通过' : '未通过'}：${formatPositionZone(source.positionZone)} / ${formatNumber(source.positionScore, 0)} 分；${textReasons(source.positionReasons)}`;
  }

  if (stage.key === 'change' && source.changeStage) {
    return `${source.changePassed ? '通过' : '未通过'}：${formatChangeType(source.changeType)}；${textReasons(source.changeReasons)}`;
  }

  const reasonKey = stage.reasonKey;
  const fallback = {
    shapeReasons: '形态候选成立',
    positionReasons: '位置条件成立',
    changeReasons: '变化确认成立'
  }[reasonKey] || '阶段条件成立';

  return formatStagePassText(source[reasonKey], fallback);
}

function getDecisionRejectText(trade) {
  if (!trade) {
    return '未进入形态候选。';
  }

  const decision = trade.finalDecision || {};

  if (decision.rejectReason) {
    return formatRejectReason(decision.rejectReason);
  }

  return '无，已完成形→位→变确认。';
}

function getDecisionStageCounts(result) {
  const dailyStates = getXwbDailyStates(result);
  const dailyOpportunities = getDailyOpportunities(result);

  if (dailyStates.length > 0 || dailyOpportunities.length > 0) {
    const shapeCount = dailyStates.filter((item) => item && item.shape && item.shape.type !== 'UNKNOWN_SHAPE').length;
    const positionCount = dailyStates.filter((item) => item && item.position && Number(item.position.score) > 0).length;
    const changeCount = dailyStates.filter((item) => item && item.change && item.change.type !== 'UNKNOWN_CHANGE').length;
    const buyCount = dailyOpportunities.filter((item) => item && (item.opportunityGrade === 'A' || item.opportunityGrade === 'B')).length;

    return {
      shapeCount,
      positionCount,
      changeCount,
      buyCount,
      positionRejected: Math.max(0, shapeCount - positionCount),
      changeRejected: Math.max(0, positionCount - changeCount)
    };
  }

  const finalModel = getFinalDecisionModel(result);
  const diagnostics = finalModel && Array.isArray(finalModel.diagnostics)
    ? finalModel.diagnostics
    : [];
  const shapeCount = diagnostics.filter((item) => item.shapePassed).length;
  const positionCount = diagnostics.filter((item) => item.shapePassed && item.positionPassed).length;
  const changeCount = diagnostics.filter((item) => item.shapePassed && item.positionPassed && item.changePassed).length;
  const buyCount = diagnostics.filter((item) => item.rejectReason === 'BUY_EXECUTED').length;

  return {
    shapeCount,
    positionCount,
    changeCount,
    buyCount,
    positionRejected: Math.max(0, shapeCount - positionCount),
    changeRejected: Math.max(0, positionCount - changeCount)
  };
}

function getDateDecisionState(events, diagnostic) {
  const list = Array.isArray(events) ? events : [];

  if (diagnostic) {
    if (diagnostic.opportunityGrade) {
      return {
        shape: '已识别状态',
        position: formatOpportunityGrade(diagnostic.opportunityGrade),
        change: formatOpportunityRisk(diagnostic.riskLevel),
        decision: formatOpportunityAction(diagnostic.actionBias),
        reject: diagnostic.rejectReason || '无明显失败条件'
      };
    }

    return {
      shape: diagnostic.shapePassed ? formatShapeType(diagnostic.shapeType) : '未通过',
      position: diagnostic.positionPassed ? formatPositionZone(diagnostic.positionZone) : '未通过',
      change: diagnostic.changePassed ? formatChangeType(diagnostic.changeType) : '未确认',
      decision: diagnostic.finalAction === 'BUY'
        ? '买入'
        : (diagnostic.finalAction === 'SELL' ? '卖出' : '观望'),
      reject: formatRejectReason(diagnostic.rejectReason)
    };
  }

  if (list.length === 0) {
    return {
      shape: '无候选触发',
      position: '未进入位置判断',
      change: '未进入变化确认',
      decision: '观望',
      reject: '卡在观其形：当天未触发形态候选。'
    };
  }

  const hasEntry = list.some((event) => event.type === 'entry');
  const hasExit = list.some((event) => event.type === 'exit');
  const hasSignal = list.some((event) => event.type === 'signal');

  return {
    shape: '通过',
    position: '通过',
    change: '通过',
    decision: hasExit ? '卖出' : (hasEntry ? '买入' : (hasSignal ? '观望' : '观望')),
    reject: '无，已进入完整决策链。'
  };
}

