    width: labelWidth,
    height: labelHeight
  });

  layer.innerHTML = `
    <line class="forecast-overlay-node-line" x1="${clickedPoint.x.toFixed(2)}" y1="${state.pricePanel.top}" x2="${clickedPoint.x.toFixed(2)}" y2="${state.equityPanel.bottom}"></line>
