  }
}

function renderForecastZoomInset(nodePredictionAnalysis) {
  const state = interactiveCurveState;

  if (!state || !state.svg) {
    return;
  }

  const layer = state.svg.querySelector('#forecastZoomInsetLayer');

  if (!layer) {
    return;
  }

  layer.innerHTML = '';

  if (!nodePredictionAnalysis || !nodePredictionAnalysis.ok) {
    clearForecastZoomInset();
    return;
  }

  const clickedDate = normalizeTimelineDate(nodePredictionAnalysis.clickedDate);
  const currentNode = nodePredictionAnalysis.currentNode || {};
  const clickedClose = Number(currentNode.close);

  if (!clickedDate || !state.data.dateIndex.has(clickedDate) || !Number.isFinite(clickedClose) || clickedClose <= 0) {
    return;
  }

  const forecastDays = getForecastDays(nodePredictionAnalysis);
  const statsByDay = new Map((nodePredictionAnalysis.futurePathStats || []).map((item) => [Number(item.day), item]));
  const actualByDay = new Map((nodePredictionAnalysis.actualFuturePath || []).map((item) => [Number(item.day), item]));
  const actualFutureGuard = getActualFutureVisibilityGuard(nodePredictionAnalysis);
  const rows = [{
    day: 0,
    date: clickedDate,
    medianPrice: clickedClose,
    q1Price: clickedClose,
    q3Price: clickedClose,
    actualPrice: clickedClose
  }];

  for (let day = 1; day <= forecastDays; day += 1) {
    const stat = statsByDay.get(day) || {};
    const actual = actualByDay.get(day);
    const actualClose = actual && actual.exists ? Number(actual.close) : null;

    rows.push({
      day,
      date: actual && actual.exists ? normalizeTimelineDate(actual.date) : `T+${day}`,
      medianPrice: returnPctToPrice(
        clickedClose,
        getStructureAdjustedForecastReturnPct(nodePredictionAnalysis, day, stat.medianReturnPct, 'median')
      ),
      q1Price: returnPctToPrice(
        clickedClose,
        getStructureAdjustedForecastReturnPct(nodePredictionAnalysis, day, stat.lowerQuartileReturnPct, 'q1')
      ),
      q3Price: returnPctToPrice(
        clickedClose,
        getStructureAdjustedForecastReturnPct(nodePredictionAnalysis, day, stat.upperQuartileReturnPct, 'q3')
      ),
      actualPrice: actualFutureGuard.visibleDays.has(day) && Number.isFinite(actualClose) ? actualClose : null
    });
  }

  const yValues = rows.flatMap((row) => {
    return [row.medianPrice, row.q1Price, row.q3Price, row.actualPrice]
      .filter((value) => {
        if (value === null || value === undefined || value === '') {
          return false;
        }

        const number = Number(value);

        return Number.isFinite(number) && number > 0;
      })
      .map((value) => Number(value));
  });

  if (yValues.length < 2) {
    return;
  }

  const rawMin = Math.min(...yValues);
  const rawMax = Math.max(...yValues);
  const rawRange = rawMax - rawMin;
  const yPadding = rawRange > 0 ? rawRange * 0.12 : Math.max(Math.abs(rawMax) * 0.02, 1);
  const yMin = rawMin - yPadding;
  const yMax = rawMax + yPadding;
  const yRange = yMax - yMin;
  const zoomLayout = getForecastZoomAutoLayout(state);
  const insetWidth = zoomLayout.width;
  const insetHeight = zoomLayout.height;
  const insetX = zoomLayout.x;
  const insetY = zoomLayout.y;
  const plot = {
    left: insetX + 34,
    right: insetX + insetWidth - 12,
    top: insetY + 62,
    bottom: insetY + insetHeight - 42
  };
   const zoomScaleDays = FORECAST_ZOOM_DAYS;
  const xScale = (day) => plot.left + (Number(day) / zoomScaleDays) * (plot.right - plot.left);
  const yScale = (price) => plot.bottom - ((price - yMin) / yRange) * (plot.bottom - plot.top);
  const toPoint = (row, key) => {
    const rawPrice = row ? row[key] : null;

    // 关键修复：
    // 不能让 null / undefined / '' 进入 Number()。
    // Number(null) === 0，会把“暂无真实数据”误画成 0 价格，
    // 导致局部放大里的真实线突然砸到底部。
    if (rawPrice === null || rawPrice === undefined || rawPrice === '') {
      return null;
    }

    const price = Number(rawPrice);

    if (!Number.isFinite(price) || price <= 0) {
      return null;
    }

    return {
      day: row.day,
      date: row.date,
      price,
      x: xScale(row.day),
      y: yScale(price)
    };
  };
  const medianPoints = normalizeForecastLinePoints(rows.map((row) => toPoint(row, 'medianPrice')).filter(Boolean));
  const q1Points = normalizeForecastLinePoints(rows.map((row) => toPoint(row, 'q1Price')).filter(Boolean));
  const q3Points = normalizeForecastLinePoints(rows.map((row) => toPoint(row, 'q3Price')).filter(Boolean));
  const actualPoints = normalizeForecastLinePoints(rows.map((row) => toPoint(row, 'actualPrice')).filter(Boolean));
  const hasRealActualFuture = actualFutureGuard.canShowAny && actualPoints.length > 1;
  const pathTitle = getNodePathTypeText(nodePredictionAnalysis);
  const insetTitle = hasRealActualFuture
    ? `局部放大：模型预测 vs 真实｜${pathTitle}`
    : '局部放大：预判路径｜暂无真实走势';
  const safeMedianPoints = normalizeForecastLinePoints(medianPoints);
  const safeQ1Points = normalizeForecastLinePoints(q1Points);
  const safeQ3Points = normalizeForecastLinePoints(q3Points);
  const safeActualPoints = normalizeForecastLinePoints(actualPoints);

  const bandPath = buildForecastBandPath(safeQ1Points, safeQ3Points);
  const medianPath = buildSvgPath(safeMedianPoints);
  const actualPath = buildSvgPath(safeActualPoints);
  const forecastVisualMode = getForecastOverlayVisualMode(nodePredictionAnalysis);
  const clipId = 'forecastZoomInsetClip';

  const milestoneDays = [3, 5, 10, 20].filter((day) => day <= forecastDays);
  const rowByDay = new Map(rows.map((row) => [Number(row.day), row]));

  const milestoneMarkerHtml = milestoneDays.map((day) => {
