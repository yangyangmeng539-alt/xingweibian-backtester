function renderSupplyChainStockResult(stock) {
  if (!supplyChainStockResult) {
    return;
  }

  if (!stock) {
    supplyChainStockResult.textContent = '输入股票代码查询产业链归属。';
    return;
  }

  if (!stock.found) {
    supplyChainStockResult.textContent = `未找到股票代码 ${stock.code || '-'} 的产业链归属。`;
    return;
  }

  const assignments = Array.isArray(stock.assignments) ? stock.assignments : [];
  const rows = assignments.length
    ? assignments.map((assignment) => {
