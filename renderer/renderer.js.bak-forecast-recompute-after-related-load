function getHoverAnalysisStructureType(nodePredictionAnalysis) {
  if (!nodePredictionAnalysis || typeof nodePredictionAnalysis !== 'object') {
    return '';
  }

  const refinement = nodePredictionAnalysis.observationRefinement || {};

  return String(
    nodePredictionAnalysis.structureType
    || refinement.type
    || ''
  );
}

function getHoverAnalysisStructureTitle(nodePredictionAnalysis) {
  if (!nodePredictionAnalysis || typeof nodePredictionAnalysis !== 'object') {
    return '';
  }

  const refinement = nodePredictionAnalysis.observationRefinement || {};

  return String(
    nodePredictionAnalysis.structureTitle
    || refinement.title
    || refinement.text
    || ''
  );
}

function getHoverAnalysisRapidTitle(nodePredictionAnalysis) {
  const prediction = getRapidTypePrediction(nodePredictionAnalysis);

  if (prediction && prediction.predictedRapidTitle) {
    return String(prediction.predictedRapidTitle || '');
  }

  const rapid = getRapidChangeAnalysis(nodePredictionAnalysis);

  return String(
    rapid && (rapid.rapidTitle || rapid.title || rapid.typeTitle)
    || ''
  );
}

function getHoverAnalysisRapidGroup(nodePredictionAnalysis) {
  const prediction = getRapidTypePrediction(nodePredictionAnalysis);

  if (prediction && prediction.predictedRapidGroup) {
    return String(prediction.predictedRapidGroup || '');
  }

  const rapid = getRapidChangeAnalysis(nodePredictionAnalysis);

  return String(
    rapid && (rapid.rapidGroup || rapid.group || rapid.typeGroup)
    || ''
  );
}

function getHoverPredictionKind(nodePredictionAnalysis) {
  const explicitKind = String(
    nodePredictionAnalysis && (
      nodePredictionAnalysis.predictionKind
      || nodePredictionAnalysis.validationPredictionKind
      || nodePredictionAnalysis.nodePredictionKind
    )
    || ''
  );

  if (explicitKind) {
    return explicitKind;
  }

  const structureType = getHoverAnalysisStructureType(nodePredictionAnalysis);
  const rapidGroup = getHoverAnalysisRapidGroup(nodePredictionAnalysis);

  if (structureType === 'EXTERNAL_CONFIRMED_TARGET_WEAK') {
    return 'TARGET_CATCHUP';
  }

  if (
    structureType === 'SUPPLY_CHAIN_PREHEAT'
    || structureType === 'RELATION_PREHEAT'
    || structureType === 'STRUCTURE_WARMING'
  ) {
    return 'CHAIN_PREHEAT';
  }

  if (structureType === 'SHAPE_POSITION_RISK' || structureType === 'PREHEAT_DECAY') {
    return 'RISK_WARNING';
  }

  if (structureType === 'LOW_LEVEL_CONFIRMATION') {
    return 'LOW_REPAIR';
  }

  if (structureType === 'TREND_CONTINUATION' || structureType === 'STRUCTURE_CONFIRMED' || rapidGroup === 'EXTEND_UP') {
    return 'EXTEND_UP';
  }

  return rapidGroup || 'MIXED';
}

function getHoverConfidenceBand(confidence) {
  const value = Number(confidence);

  if (!Number.isFinite(value)) {
    return 'LOW';
  }

  if (value >= 0.68) {
    return 'HIGH';
  }

  if (value >= 0.40) {
    return 'MID';
  }

  return 'LOW';
}

function getHoverPredictionConfidence(nodePredictionAnalysis, predictionKind) {
  const explicitConfidence = Number(
    nodePredictionAnalysis && (
      nodePredictionAnalysis.confidence
      || nodePredictionAnalysis.validationConfidence
      || nodePredictionAnalysis.nodePredictionConfidence
    )
  );

  if (Number.isFinite(explicitConfidence)) {
    return clamp(explicitConfidence, 0, 1);
  }

  const structureType = getHoverAnalysisStructureType(nodePredictionAnalysis);
  const rapidTitle = getHoverAnalysisRapidTitle(nodePredictionAnalysis);
  const rapidGroup = getHoverAnalysisRapidGroup(nodePredictionAnalysis);

  if (predictionKind === 'TARGET_CATCHUP' || structureType === 'EXTERNAL_CONFIRMED_TARGET_WEAK') {
    if (/低位|修复|弱势|近端弱势|超跌/.test(rapidTitle)) {
      return 0.50;
    }

    if (/混合分歧/.test(rapidTitle)) {
      return 0.40;
    }

    if (rapidGroup === 'EXTEND_UP') {
      return 0.46;
    }

    return 0.39;
  }

  if (predictionKind === 'CHAIN_PREHEAT') {
    return rapidGroup === 'EXTEND_UP' ? 0.34 : 0.22;
  }

  if (predictionKind === 'RISK_WARNING') {
    return 0.36;
  }

  if (predictionKind === 'LOW_REPAIR') {
    return 0.45;
  }

  if (predictionKind === 'EXTEND_UP') {
    return 0.34;
  }

  return 0.30;
}

function getHoverBarPrice(bar, key) {
  const value = Number(bar && bar[key]);

  if (Number.isFinite(value) && value > 0) {
    return value;
  }

  const close = Number(bar && bar.close);

  return Number.isFinite(close) && close > 0 ? close : null;
}

function buildInteractivePreRiskMetricsForDate(date) {
  const state = interactiveCurveState;
  const cleanDate = normalizeTimelineDate(date);

  if (!state || !state.data || !Array.isArray(state.data.series) || !state.data.dateIndex.has(cleanDate)) {
    return null;
  }

  const series = state.data.series;
  const index = state.data.dateIndex.get(cleanDate);
  const currentBar = series[index];
  const currentClose = getHoverBarPrice(currentBar, 'close');

  if (!Number.isFinite(currentClose) || currentClose <= 0) {
    return null;
  }

  const calcWindow = (days) => {
    const start = Math.max(0, index - Number(days));
    const list = series.slice(start, index + 1).filter(Boolean);

    if (list.length < 2) {
      return {
        days,
        ok: false
      };
    }

    let maxHigh = null;
    let minLow = null;

    list.forEach((bar) => {
      const high = getHoverBarPrice(bar, 'high');
      const low = getHoverBarPrice(bar, 'low');

      if (Number.isFinite(high)) {
        maxHigh = maxHigh === null ? high : Math.max(maxHigh, high);
      }

      if (Number.isFinite(low)) {
        minLow = minLow === null ? low : Math.min(minLow, low);
      }
    });

    const rangePct = Number.isFinite(maxHigh) && Number.isFinite(minLow) && minLow > 0
      ? (maxHigh / minLow - 1) * 100
      : null;

    const drawdownFromHighPct = Number.isFinite(maxHigh) && maxHigh > 0
      ? (currentClose / maxHigh - 1) * 100
      : null;

    return {
      days,
      ok: true,
      rangePct,
      drawdownFromHighPct
    };
  };

  const w5 = calcWindow(5);
  const w10 = calcWindow(10);
  const w20 = calcWindow(20);
  const riskFlags = [];

  if (Number.isFinite(Number(w20.rangePct)) && Number(w20.rangePct) >= 35) {
    riskFlags.push('PRE20_RANGE_TOO_WIDE');
  }

  if (Number.isFinite(Number(w10.rangePct)) && Number(w10.rangePct) >= 25) {
    riskFlags.push('PRE10_RANGE_TOO_WIDE');
  }

  if (Number.isFinite(Number(w20.drawdownFromHighPct)) && Number(w20.drawdownFromHighPct) <= -15) {
    riskFlags.push('PRE20_DRAWDOWN_TOO_DEEP');
  }

  if (Number.isFinite(Number(w10.drawdownFromHighPct)) && Number(w10.drawdownFromHighPct) <= -12) {
    riskFlags.push('PRE10_DRAWDOWN_TOO_DEEP');
  }

  if (Number.isFinite(Number(w5.drawdownFromHighPct)) && Number(w5.drawdownFromHighPct) <= -8) {
    riskFlags.push('PRE5_FAST_FADE');
  }

  return {
    ok: true,
    w5,
    w10,
    w20,
    riskFlags,
    riskLevel: riskFlags.length >= 2 ? 'HIGH' : riskFlags.length === 1 ? 'MID' : 'LOW'
  };
}

function getActiveNodePredictionOffsetText(hoverDate) {
  const state = interactiveCurveState;
  const selectedDate = normalizeTimelineDate(activeNodePredictionDate || (activeNodePredictionAnalysis && activeNodePredictionAnalysis.clickedDate));
  const cleanHoverDate = normalizeTimelineDate(hoverDate);

  if (!state || !state.data || !selectedDate || !cleanHoverDate || !state.data.dateIndex.has(selectedDate) || !state.data.dateIndex.has(cleanHoverDate)) {
    return {
      offset: null,
      text: '-'
    };
  }

  const offset = state.data.dateIndex.get(cleanHoverDate) - state.data.dateIndex.get(selectedDate);

  if (offset === 0) {
