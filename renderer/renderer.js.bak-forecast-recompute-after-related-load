function setStructureCandidatePoolLog(text) {
  if (structureCandidatePoolLog) {
    structureCandidatePoolLog.textContent = text || '';
  }
}

function renderStructureCandidateLoading() {
  if (!structureCandidatePoolGrid) {
    return;
  }

  structureCandidatePoolGrid.innerHTML = `
    <div class="structure-candidate-loading">正在扫描 A股 / 港股全市场缓存候选池...</div>
  `;
}

function unwrapStructureCandidateResponse(response) {
  return response && response.result ? response.result : response;
}

function getStructureCandidateToneClass(type) {
  const value = String(type || '').toUpperCase();

  if (/BREAKDOWN|RISK/.test(value)) {
    return 'candidate-risk';
  }

  if (/REPAIR/.test(value)) {
    return 'candidate-repair';
  }

  if (/RESILIENT|MOMENTUM/.test(value)) {
    return 'candidate-good';
  }

  return 'candidate-neutral';
}

function renderStructureCandidateTable(group) {
  const items = Array.isArray(group && group.items) ? group.items : [];

  if (!items.length) {
    return `<div class="structure-candidate-empty">暂无 ${formatText(group && group.label || '')}</div>`;
  }

  const rows = items.map((item) => `
    <tr>
      <td><b>${formatText(item.symbol)}</b><span>${formatText(item.name || '-')}</span></td>
      <td>${formatNumber(item.score)}</td>
      <td class="${moneyClass(item.pctChange)}">${formatNumber(item.pctChange)}%</td>
      <td class="${moneyClass(item.return5Pct)}">${formatNumber(item.return5Pct)}%</td>
      <td class="${moneyClass(item.return20Pct)}">${formatNumber(item.return20Pct)}%</td>
      <td>${formatNumber(item.activeRatio, 2)}x</td>
      <td>${formatText(item.reason || '')}</td>
    </tr>
  `).join('');

  return `
    <div class="structure-candidate-table-wrap">
      <table class="structure-candidate-table">
        <thead>
          <tr>
            <th>代码 / 名称</th>
            <th>分</th>
            <th>日涨跌</th>
            <th>5日</th>
            <th>20日</th>
            <th>活跃</th>
            <th>理由</th>
          </tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>
    </div>
  `;
}

function renderStructureCandidateTopText(group) {
  const items = Array.isArray(group && group.items) ? group.items : [];

  if (!items.length) {
    return '';
  }

  const topSymbols = items
    .slice(0, 4)
    .map((item) => item && item.symbol ? String(item.symbol) : '')
    .filter(Boolean);

  if (!topSymbols.length) {
    return '';
  }

  return `｜Top ${topSymbols.join('、')}`;
}

function shouldOpenStructureCandidateGroup(group, index) {
  if (index === 0) {
    return true;
  }

  const type = String(group && group.type || '').toUpperCase();

  // 破位风险默认折叠，避免页面一打开像风险列表刷屏。
  if (/BREAKDOWN|RISK/.test(type)) {
    return false;
  }

  return false;
}

function renderStructureCandidateMarketBlock(marketLabel, response) {
  const payload = unwrapStructureCandidateResponse(response);

  if (!payload || !payload.ok) {
    const message = payload && (payload.reason || payload.error)
      ? String(payload.reason || payload.error)
      : (response && response.error ? String(response.error) : '候选池不可用');

    return `
      <div class="structure-candidate-market-block candidate-risk">
        <div class="structure-candidate-market-head">
          <div>
            <span>${formatText(marketLabel)}候选池</span>
            <b>不可用</b>
          </div>
          <em>${formatText(message)}</em>
        </div>
      </div>
    `;
  }

  const marketState = payload.marketState || {};
  const groups = Array.isArray(payload.groups) ? payload.groups : [];

  return `
    <div class="structure-candidate-market-block">
      <div class="structure-candidate-market-head">
        <div>
          <span>${formatText(marketLabel)}候选池</span>
          <b>${formatText(marketState.label || payload.marketMode || '-')}</b>
        </div>
        <em>${formatText(payload.marketMode || '')}｜样本 ${formatNumber(payload.sampleCount, 0)} / ${formatNumber(payload.universeCount, 0)}｜候选 ${formatNumber(payload.candidateCount, 0)}</em>
      </div>
      <div class="structure-candidate-market-sub">
        ${formatText(marketState.regime || '')}｜${formatText(payload.date || '')}｜${formatText(payload.sampleMode || '')}｜${formatText(payload.universeSource || '')}
      </div>
      <div class="structure-candidate-groups">
        ${groups.map((group, groupIndex) => {
          const openAttr = shouldOpenStructureCandidateGroup(group, groupIndex) ? ' open' : '';
          const itemCount = Array.isArray(group.items) ? group.items.length : 0;
          const topText = renderStructureCandidateTopText(group);

          return `
            <details class="structure-candidate-group ${getStructureCandidateToneClass(group.type)}"${openAttr}>
              <summary class="structure-candidate-group-head">
                <h3>${formatText(group.label || group.type)}</h3>
                <span>总数 ${formatNumber(group.count, 0)}｜显示 ${formatNumber(itemCount, 0)}${formatText(topText)}</span>
              </summary>
              <div class="structure-candidate-group-body">
                ${renderStructureCandidateTable(group)}
              </div>
            </details>
          `;
        }).join('')}
      </div>
    </div>
  `;
}

async function refreshStructureCandidatePool(dateOverride) {
  if (!structureCandidatePoolPanel || !structureCandidatePoolGrid) {
    return;
  }

  if (!window.xwbApi || typeof window.xwbApi.runStructureCandidates !== 'function') {
    structureCandidatePoolGrid.innerHTML = `
      <div class="structure-candidate-loading">structure-candidates:run 接口不可用</div>
    `;
    return;
  }

  const requestSeq = ++structureCandidatePoolRequestSeq;
  const date = String(dateOverride || getMarketStateOverviewDateValue() || '').trim();

  renderStructureCandidateLoading();
  setStructureCandidatePoolLog(date ? `正在扫描 ${date} 的结构候选池...` : '正在扫描最新缓存交易日的结构候选池...');
  setMarketGraphButtonBusy(structureCandidatePoolRefreshButton, true);

  try {
    const [aShareResponse, hkResponse] = await Promise.all([
      window.xwbApi.runStructureCandidates({
        market: 'CN_A',
        date,
        cacheOnly: true,
        sourceMode: 'sqlite_cache_only',
        sampleMode: 'cache_universe',
        perGroupLimit: 999999
      }),
      window.xwbApi.runStructureCandidates({
        market: 'HK',
        date,
        cacheOnly: true,
        sourceMode: 'sqlite_cache_only',
        sampleMode: 'cache_universe',
        perGroupLimit: 999999
      })
    ]);

    if (requestSeq !== structureCandidatePoolRequestSeq) {
      return;
    }

    structureCandidatePoolGrid.innerHTML = [
      renderStructureCandidateMarketBlock('A股', aShareResponse),
      renderStructureCandidateMarketBlock('港股', hkResponse)
    ].join('');

    const a = unwrapStructureCandidateResponse(aShareResponse);
    const h = unwrapStructureCandidateResponse(hkResponse);

    setStructureCandidatePoolLog([
      a && a.ok ? `A股：${a.summaryText}` : 'A股：不可用',
      h && h.ok ? `港股：${h.summaryText}` : '港股：不可用'
    ].join('；'));
  } catch (error) {
    if (requestSeq !== structureCandidatePoolRequestSeq) {
      return;
    }

    structureCandidatePoolGrid.innerHTML = `
      <div class="structure-candidate-loading">候选池扫描失败：${formatText(error && error.message ? error.message : String(error))}</div>
    `;
    setStructureCandidatePoolLog(`候选池扫描失败：${formatDisplayError(error && error.message ? error.message : error)}`);
  } finally {
    setMarketGraphButtonBusy(structureCandidatePoolRefreshButton, false);
  }
}

