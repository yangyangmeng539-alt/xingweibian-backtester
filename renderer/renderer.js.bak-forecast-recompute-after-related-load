function interpolateUiModelPredictionReturnPct(path, day) {
  const value = Number(day);
  const points = [
    { day: 0, value: 0 },
    { day: 3, value: Number(path && path.predictedReturnsPct && path.predictedReturnsPct.d3) },
    { day: 5, value: Number(path && path.predictedReturnsPct && path.predictedReturnsPct.d5) },
    { day: 10, value: Number(path && path.predictedReturnsPct && path.predictedReturnsPct.d10) },
    { day: 20, value: Number(path && path.predictedReturnsPct && path.predictedReturnsPct.d20) }
  ].filter((point) => Number.isFinite(point.value));

  if (!Number.isFinite(value) || points.length < 2) {
    return null;
  }

  if (value <= 0) {
    return 0;
  }

  for (let index = 1; index < points.length; index += 1) {
    const left = points[index - 1];
    const right = points[index];

    if (value <= right.day) {
      const span = right.day - left.day;
      const ratio = span <= 0 ? 1 : (value - left.day) / span;
      return roundUiForecastPathPct(left.value + (right.value - left.value) * ratio);
    }
  }

  return roundUiForecastPathPct(points[points.length - 1].value);
}

function getUiHkLiquidityBendExtraPct(nodePredictionAnalysis, day) {
  const dayNumber = Number(day);

  // 锚点绝对不动：T0 / T+3 / T+5 / T+10 / T+20
  if ([0, 3, 5, 10, 20].includes(dayNumber)) {
