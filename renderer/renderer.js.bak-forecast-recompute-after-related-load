function getObservationGraphActiveContext() {
  const context = observationContextState && observationContextState.active
    ? observationContextState.active
    : null;

  if (!context || !context.ok || !context.observationSummary) {
    return null;
  }

  return context;
}

function getObservationGraphLayerSummaryMap(context) {
  const frame = context && context.currentPlaybackFrame ? context.currentPlaybackFrame : null;
  const layers = frame && Array.isArray(frame.layers)
    ? frame.layers
    : (
      context && context.observationSummary && Array.isArray(context.observationSummary.layers)
        ? context.observationSummary.layers
        : []
    );
  const map = new Map();

  layers.forEach((layer) => {
    if (!layer || !layer.layerKey) {
      return;
    }

    map.set(String(layer.layerKey), {
      ...layer,
      t0StrongCount: layer.t0StrongCount !== undefined ? layer.t0StrongCount : layer.strongCount,
      preStrongCount: layer.preStrongCount !== undefined ? layer.preStrongCount : layer.strongCount,
      nearStrongCount: layer.nearStrongCount !== undefined ? layer.nearStrongCount : layer.strongCount
    });
  });

  return map;
}

function getObservationGraphStockSummaryMap(context) {
  const summary = context && context.observationSummary ? context.observationSummary : null;
  const matrix = context && context.related && Array.isArray(context.related.matrix)
    ? context.related.matrix
    : [];
  const frame = context && context.currentPlaybackFrame ? context.currentPlaybackFrame : null;
  const offset = frame ? Number(frame.offset || 0) : 0;
  const map = new Map();

  matrix.forEach((row) => {
    const code = normalizeObservationStockCode(row && row.code);

    if (!code || !Array.isArray(row.timeline)) {
      return;
    }

    const point = getObservationMatrixPointAtOffset(row.timeline, offset);
    const t0Point = getObservationMatrixPointAtOffset(row.timeline, 0);
    const firstPreStrongOffset = getObservationFirstStrongOffset(row.timeline, -20, -1);
    const firstNearStrongOffset = getObservationFirstStrongOffset(row.timeline, -5, 0);
    const firstStrongOffset = getObservationFirstStrongOffset(row.timeline, -20, 20);
    const layer = Array.isArray(row.layers) && row.layers[0] ? row.layers[0] : {};

    map.set(code, {
      code,
      name: row.name || '',
      layerKey: layer.layerKey || '',
      layerLabel: layer.layerLabel || '',
      t0Strong: isObservationStrongPoint(point),
      t0Opportunity: isObservationOpportunityPoint(point),
      firstPreStrongOffset,
      firstNearStrongOffset,
      firstStrongOffset,
      currentOffset: offset,
      currentStrong: isObservationStrongPoint(point),
      currentOpportunity: isObservationOpportunityPoint(point),
      currentStateCode: point ? point.stateCode || '' : '',
      currentStateName: point ? point.stateName || '' : '',
      originalT0Strong: isObservationStrongPoint(t0Point),
      sources: Array.isArray(row.sources) ? row.sources : []
    });
  });

  if (summary && summary.target && summary.target.code) {
    const targetCode = normalizeObservationStockCode(summary.target.code);
    const targetPoint = context && context.currentStock && Array.isArray(context.currentStock.timeline)
      ? getObservationMatrixPointAtOffset(context.currentStock.timeline, offset)
      : null;
    const existed = map.get(targetCode) || {};

    map.set(targetCode, {
      ...existed,
      code: targetCode,
      t0Strong: isObservationStrongPoint(targetPoint),
      t0Opportunity: isObservationOpportunityPoint(targetPoint),
      firstPreStrongOffset: summary.target.firstPreStrongOffset,
      firstStrongOffset: summary.target.firstStrongOffset,
      currentOffset: offset,
      currentStrong: isObservationStrongPoint(targetPoint),
      currentOpportunity: isObservationOpportunityPoint(targetPoint),
      currentStateCode: targetPoint ? targetPoint.stateCode || '' : '',
      currentStateName: targetPoint ? targetPoint.stateName || '' : '',
      isTarget: true
    });
  }

  return map;
}

function getObservationGraphLayerTone(layerSummary) {
  if (!layerSummary || !layerSummary.loadedCount) {
    return '';
  }

  const loaded = Number(layerSummary.loadedCount || 0);
  const t0Ratio = loaded > 0 ? Number(layerSummary.t0StrongCount || 0) / loaded : 0;
  const preRatio = loaded > 0 ? Number(layerSummary.preStrongCount || 0) / loaded : 0;
  const nearRatio = loaded > 0 ? Number(layerSummary.nearStrongCount || 0) / loaded : 0;
  const maxRatio = Math.max(t0Ratio, preRatio, nearRatio);

  if (maxRatio >= 0.6) {
    return ' is-observation-strong';
  }

  if (maxRatio >= 0.35) {
    return ' is-observation-middle';
  }

  if (loaded > 0) {
    return ' is-observation-weak';
  }

  return '';
}

function getObservationGraphLayerMeta(layerSummary, layer) {
  if (!layerSummary || !layerSummary.loadedCount) {
    return `${formatNumber(layer.stockCount || 0, 0)} 只股票`;
  }

  const loaded = Number(layerSummary.loadedCount || 0);
  const strong = Number(
    layerSummary.strongCount !== undefined
      ? layerSummary.strongCount
      : layerSummary.t0StrongCount || 0
  );
  const opportunity = Number(layerSummary.opportunityCount || layerSummary.t0OpportunityCount || 0);
  const strongRatio = loaded > 0 ? (strong / loaded) * 100 : 0;
  const opportunityRatio = loaded > 0 ? (opportunity / loaded) * 100 : 0;

  return `强 ${formatPercent(strongRatio, 0)}｜机会 ${formatPercent(opportunityRatio, 0)}`;
}

function formatObservationGraphOffset(offset) {
  if (offset === null || offset === undefined || offset === '') {
    return '';
  }

  const value = Number(offset);

  if (!Number.isFinite(value)) {
    return '';
  }

  if (value === 0) {
    return 'T0';
  }

  return `T${value > 0 ? '+' : ''}${formatNumber(value, 0)}`;
}

function getObservationGraphStockClass(stock, layerKey, stockSummaryMap, context) {
  const code = normalizeObservationStockCode(stock && stock.code);
  const summary = stockSummaryMap.get(code);
  const targetCode = normalizeObservationStockCode(context && context.code);
  const classes = [];

  if (code && code === targetCode) {
    classes.push('is-observation-target');
  }

  if (summary) {
    classes.push('is-observation-sample');

    if (summary.firstPreStrongOffset !== null && summary.firstPreStrongOffset !== undefined) {
      classes.push('is-observation-lead');
    }

    if (summary.firstNearStrongOffset !== null && summary.firstNearStrongOffset !== undefined) {
      classes.push('is-observation-near');
    }

    if (summary.t0Strong) {
      classes.push('is-observation-t0');
    }

    if (summary.t0Opportunity) {
      classes.push('is-observation-opportunity');
    }
  }

  const selfLayerKey = context && context.supplyChain && context.supplyChain.self
    ? context.supplyChain.self.layerKey
    : '';

  if (selfLayerKey && layerKey === selfLayerKey) {
    classes.push('is-observation-same-layer');
  }

  return classes.length ? ` ${classes.join(' ')}` : '';
}

function getObservationGraphStockSubText(stock, stockSummaryMap) {
  const code = normalizeObservationStockCode(stock && stock.code);
  const summary = stockSummaryMap.get(code);

  if (!summary) {
    return '';
  }

  if (summary.currentStrong) {
    return summary.currentOffset === 0
      ? 'T0强'
      : `T${Number(summary.currentOffset) >= 0 ? '+' : ''}${formatNumber(summary.currentOffset, 0)}强`;
  }

  if (summary.currentOpportunity) {
    return summary.currentOffset === 0
      ? 'T0机会'
      : `T${Number(summary.currentOffset) >= 0 ? '+' : ''}${formatNumber(summary.currentOffset, 0)}机会`;
  }

  if (summary.firstPreStrongOffset !== null && summary.firstPreStrongOffset !== undefined) {
    return `提前 ${formatObservationGraphOffset(summary.firstPreStrongOffset)}`;
  }

  if (summary.firstNearStrongOffset !== null && summary.firstNearStrongOffset !== undefined) {
    return `近端 ${formatObservationGraphOffset(summary.firstNearStrongOffset)}`;
  }

  return '';
}

function selectObservationGraphStocks(stocks, layerKey, maxCount, stockSummaryMap, context) {
  const source = Array.isArray(stocks) ? stocks : [];
  const targetCode = normalizeObservationStockCode(context && context.code);
  const picked = [];
  const pickedCodes = new Set();

  const pushStock = (stock) => {
    const code = normalizeObservationStockCode(stock && stock.code);

    if (!code || pickedCodes.has(code)) {
      return;
    }

    picked.push(stock);
    pickedCodes.add(code);
  };

  source.forEach((stock) => {
    const code = normalizeObservationStockCode(stock && stock.code);
    const summary = stockSummaryMap.get(code);

    if (code && code === targetCode) {
      pushStock(stock);
      return;
    }

    if (summary && (
      summary.firstPreStrongOffset !== null ||
      summary.firstNearStrongOffset !== null ||
      summary.t0Strong ||
      summary.t0Opportunity
    )) {
      pushStock(stock);
    }
  });

  source.forEach((stock) => {
    if (picked.length >= maxCount) {
      return;
    }

    pushStock(stock);
  });

  return picked.slice(0, maxCount);
}

function refreshSupplyChainGraphObservationPaint(context) {
  if (!context || !context.ok || !context.observationSummary) {
    return;
  }

  if (!supplyChainState.selectedChain || !supplyChainLayerBox) {
    return;
  }

  renderSupplyChainLayers(supplyChainState.selectedChain);

  if (context.supplyChain && context.supplyChain.self) {
    updateSupplyChainGraphDetail({
      type: 'stock',
      layerKey: context.supplyChain.self.layerKey,
      stock: context.supplyChain.self
    });
  }
}

function renderSupplyChainGraph(chain) {
  const flowDefs = SUPPLY_CHAIN_LAYER_DEFS.filter((def) => def.key !== 'service');
  const serviceDef = SUPPLY_CHAIN_LAYER_DEFS.find((def) => def.key === 'service');

  const observationContext = getSupplyChainFocusRenderContext(chain);
  const layerSummaryMap = new Map();
  const stockSummaryMap = new Map();

  const layerXs = {
    upstream: 130,
    midstream: 400,
    downstream: 670,
    terminal: 940
  };

  const layerY = 82;
  const layerWidth = 172;
  const layerHeight = 52;
  const stockStartY = 190;
  const stockGapY = 54;
  const maxStocksPerLayer = 8;

  const maxStockRows = Math.max(
    1,
    ...flowDefs.map((def) => {
      const layer = getSupplyChainLayer(chain, def.key);
      const selectedStocks = selectObservationGraphStocks(
        layer.stocks,
        def.key,
        maxStocksPerLayer,
        stockSummaryMap,
        observationContext
      );

      return Math.min(maxStocksPerLayer, selectedStocks.length);
    })
  );

  const serviceY = stockStartY + maxStockRows * stockGapY + 72;
  const height = Math.max(430, serviceY + 150);
  const width = 1120;

  const shortText = (value, max = 8) => {
    const text = String(value || '').trim();
    return text.length > max ? `${text.slice(0, max)}…` : text;
  };

  const renderLayerNode = (def) => {
    const layer = getSupplyChainLayer(chain, def.key);
    const x = layerXs[def.key] || 80;
    const y = layerY;
    const layerSummary = layerSummaryMap.get(def.key);
    const layerToneClass = getObservationGraphLayerTone(layerSummary);
    const selfLayerKey = observationContext && observationContext.supplyChain && observationContext.supplyChain.self
      ? observationContext.supplyChain.self.layerKey
      : '';
    const targetClass = selfLayerKey === def.key ? ' is-observation-target-layer' : '';
    const metaText = getObservationGraphLayerMeta(layerSummary, layer);

    return `
      <g class="supply-chain-svg-layer${layerToneClass}${targetClass}" data-graph-layer="${formatText(def.key)}" tabindex="0">
        <rect x="${x}" y="${y}" width="${layerWidth}" height="${layerHeight}" rx="12"></rect>
        <text class="supply-chain-svg-layer-title" x="${x + layerWidth / 2}" y="${y + 22}">${formatText(def.label)}</text>
        <text class="supply-chain-svg-layer-meta" x="${x + layerWidth / 2}" y="${y + 40}">${formatText(metaText)}</text>
      </g>
    `;
  };

  const renderStockNodes = (def) => {
    const layer = getSupplyChainLayer(chain, def.key);
    const stocks = selectObservationGraphStocks(
      Array.isArray(layer.stocks) ? layer.stocks : [],
      def.key,
      maxStocksPerLayer,
      stockSummaryMap,
      observationContext
    );
    const x = (layerXs[def.key] || 80) + layerWidth / 2;

    if (!stocks.length) {
      return `
        <g class="supply-chain-svg-empty-node">
          <circle cx="${x}" cy="${stockStartY}" r="18"></circle>
          <text x="${x}" y="${stockStartY + 5}">空</text>
        </g>
      `;
    }

    return `
      ${stocks.map((stock, index) => {
        const y = stockStartY + index * stockGapY;
        const inferredClass = stock.source === 'inferred' ? ' is-inferred' : '';
        const observationClass = getObservationGraphStockClass(stock, def.key, stockSummaryMap, observationContext);
        const confidenceText = formatSupplyChainConfidence(stock.confidence);
        const subText = getObservationGraphStockSubText(stock, stockSummaryMap);
        const codeText = subText
          ? `${stock.code} · ${subText}`
          : `${stock.code} · ${confidenceText}`;

        return `
          <g class="supply-chain-svg-stock${inferredClass}${observationClass}" data-graph-layer="${formatText(def.key)}" data-graph-stock="${formatText(stock.code)}" tabindex="0">
            <line class="supply-chain-svg-stock-link" x1="${x}" y1="${layerY + layerHeight}" x2="${x}" y2="${y - 22}"></line>
            <circle cx="${x}" cy="${y}" r="22"></circle>
            <text class="supply-chain-svg-stock-name" x="${x}" y="${y - 3}">${formatText(shortText(stock.name || stock.code, 7))}</text>
            <text class="supply-chain-svg-stock-code" x="${x}" y="${y + 12}">${formatText(codeText)}</text>
          </g>
        `;
      }).join('')}
    `;
  };

  const renderFlowEdges = () => {
    return flowDefs.slice(0, -1).map((def, index) => {
      const nextDef = flowDefs[index + 1];
      const fromX = (layerXs[def.key] || 80) + layerWidth;
      const toX = layerXs[nextDef.key] || 80;
      const y = layerY + layerHeight / 2;
      const midX = (fromX + toX) / 2;
      const sourceLayer = layerSummaryMap.get(def.key);
      const nextLayer = layerSummaryMap.get(nextDef.key);
      const isStrongEdge = Boolean(sourceLayer && nextLayer && (
        Number(sourceLayer.preStrongCount || 0) > 0 ||
        Number(sourceLayer.nearStrongCount || 0) > 0 ||
        Number(nextLayer.preStrongCount || 0) > 0 ||
        Number(nextLayer.nearStrongCount || 0) > 0
      ));
      const edgeClass = isStrongEdge ? ' is-observation-active' : '';

      return `
        <path class="supply-chain-svg-main-edge${edgeClass}" d="M ${fromX} ${y} C ${midX - 24} ${y}, ${midX + 24} ${y}, ${toX} ${y}"></path>
        <polygon class="supply-chain-svg-arrow-head${edgeClass}" points="${toX - 8},${y - 5} ${toX},${y} ${toX - 8},${y + 5}"></polygon>
      `;
    }).join('');
  };

  const renderServiceNode = () => {
    if (!serviceDef) {
      return '';
    }

    const layer = getSupplyChainLayer(chain, serviceDef.key);
    const layerSummary = layerSummaryMap.get(serviceDef.key);
    const layerToneClass = getObservationGraphLayerTone(layerSummary);
    const stocks = selectObservationGraphStocks(
      Array.isArray(layer.stocks) ? layer.stocks : [],
      serviceDef.key,
      6,
      stockSummaryMap,
      observationContext
    );

    const x = 430;
    const y = serviceY;
    const w = 260;
    const h = 54;
    const centerX = x + w / 2;
    const centerY = y + h / 2;

    const supportEdges = flowDefs.map((def) => {
      const targetX = (layerXs[def.key] || 80) + layerWidth / 2;
      const targetY = layerY + layerHeight + 12;
      const targetLayer = layerSummaryMap.get(def.key);
      const isActive = Boolean(layerSummary || targetLayer);
      const edgeClass = isActive ? ' is-observation-active' : '';

      return `
        <path class="supply-chain-svg-service-edge${edgeClass}" d="M ${centerX} ${centerY} C ${centerX} ${centerY - 80}, ${targetX} ${targetY + 80}, ${targetX} ${targetY}"></path>
      `;
    }).join('');

    const metaText = getObservationGraphLayerMeta(layerSummary, layer);

    return `
      ${supportEdges}

      <g class="supply-chain-svg-service${layerToneClass}" data-graph-layer="${formatText(serviceDef.key)}" tabindex="0">
        <rect x="${x}" y="${y}" width="${w}" height="${h}" rx="14"></rect>
        <text class="supply-chain-svg-layer-title" x="${centerX}" y="${y + 23}">${formatText(serviceDef.label)}</text>
        <text class="supply-chain-svg-layer-meta" x="${centerX}" y="${y + 42}">${formatText(metaText)}</text>
      </g>

      <g class="supply-chain-svg-service-stock-row">
        ${stocks.map((stock, index) => {
          const sx = 190 + index * 150;
          const sy = y + 92;
          const inferredClass = stock.source === 'inferred' ? ' is-inferred' : '';
          const observationClass = getObservationGraphStockClass(stock, serviceDef.key, stockSummaryMap, observationContext);
          const subText = getObservationGraphStockSubText(stock, stockSummaryMap);
          const codeText = subText ? `${stock.code} · ${subText}` : `${stock.code}`;

          return `
            <g class="supply-chain-svg-service-stock${inferredClass}${observationClass}" data-graph-layer="${formatText(serviceDef.key)}" data-graph-stock="${formatText(stock.code)}" tabindex="0">
              <circle cx="${sx}" cy="${sy}" r="19"></circle>
              <text class="supply-chain-svg-stock-name" x="${sx}" y="${sy - 2}">${formatText(shortText(stock.name || stock.code, 6))}</text>
              <text class="supply-chain-svg-stock-code" x="${sx}" y="${sy + 12}">${formatText(codeText)}</text>
            </g>
          `;
        }).join('')}
      </g>
    `;
  };

  const observationBanner = observationContext && observationContext.observationSummary
    ? `
      <div class="supply-chain-observation-banner">
        <strong>${formatText(observationContext.observationSummary.verdict.title)}</strong>
        <span>${formatText(observationContext.code)}｜T0=${formatText(observationContext.t0)}｜${formatText(observationContext.observationSummary.narrative)}</span>
      </div>
    `
    : '';

  return `
    <div class="supply-chain-graph-shell">
      <div class="supply-chain-graph-title-row">
        <div>
          <strong>产业链分层关系图</strong>
          <span>上游 → 中游 → 下游 → 终端应用；股票作为节点挂在各层下面。</span>
        </div>
        <em>${observationContext ? `焦点联动：${formatText(observationContext.code)}` : 'SVG 图谱模式'}</em>
      </div>

      ${observationBanner}

      <div class="supply-chain-svg-wrap">
        <svg class="supply-chain-graph-svg" viewBox="0 0 ${width} ${height}" role="img" aria-label="产业链关系图">
          <defs>
            <filter id="supplyChainGlow" x="-40%" y="-40%" width="180%" height="180%">
              <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
              <feMerge>
                <feMergeNode in="blur"></feMergeNode>
                <feMergeNode in="SourceGraphic"></feMergeNode>
              </feMerge>
            </filter>
          </defs>

          <g class="supply-chain-svg-grid">
            ${Array.from({ length: 12 }).map((_, index) => {
              const y = 34 + index * 42;
              return `<line x1="36" y1="${y}" x2="${width - 36}" y2="${y}"></line>`;
            }).join('')}
          </g>

          <g class="supply-chain-svg-flow-edges">
            ${renderFlowEdges()}
          </g>

          <g class="supply-chain-svg-layers">
            ${flowDefs.map(renderLayerNode).join('')}
          </g>

          <g class="supply-chain-svg-stocks">
            ${flowDefs.map(renderStockNodes).join('')}
          </g>

          <g class="supply-chain-svg-service-layer">
            ${renderServiceNode()}
          </g>
        </svg>
      </div>

      <div class="supply-chain-graph-detail" data-supply-chain-graph-detail>
        ${renderSupplyChainGraphDetail(null)}
      </div>
    </div>
  `;
}

