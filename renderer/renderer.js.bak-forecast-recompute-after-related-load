    return '通过';
  }

  if (status === 'failed') {
    return '失败';
  }

  if (status === 'checking') {
    return '检查中';
  }

  return '未检查';
}

function formatMarketGraphStartError(error) {
  const text = formatDisplayError(error);

  if (/Python\s*预检失败|No module named ['"]?adata|无法启动 Python/i.test(text)) {
    return MARKET_GRAPH_PYTHON_PREFLIGHT_HELP_TEXT;
  }

  return text;
}

function renderMarketGraphFetchStatus(status) {
  const data = status || {};
  const progress = data.progress || {};
  const seedSummary = data.seedSummary || {};
  const pythonPreflight = data.pythonPreflight || {};
  const running = Boolean(data.running);

  if (marketGraphFetchRunningText) marketGraphFetchRunningText.textContent = running ? '采集中' : '空闲';
  if (marketGraphFetchPidText) marketGraphFetchPidText.textContent = data.pid ? String(data.pid) : '-';
  if (marketGraphFetchTotalText) marketGraphFetchTotalText.textContent = formatNumber(progress.total || 0, 0);
  if (marketGraphFetchDoneText) marketGraphFetchDoneText.textContent = formatNumber(progress.done || 0, 0);
  if (marketGraphFetchFailedText) marketGraphFetchFailedText.textContent = formatNumber(progress.failed || 0, 0);
  if (marketGraphFetchSkippedText) marketGraphFetchSkippedText.textContent = formatNumber(progress.skipped || 0, 0);
  if (marketGraphFetchCurrentText) marketGraphFetchCurrentText.textContent = progress.current || '-';
  if (marketGraphFetchUpdatedAtText) marketGraphFetchUpdatedAtText.textContent = progress.updatedAt || '-';
  if (marketGraphFetchSeedDoneText) marketGraphFetchSeedDoneText.textContent = formatNumber(seedSummary.done || 0, 0);
  if (marketGraphFetchSeedFailedText) marketGraphFetchSeedFailedText.textContent = formatNumber(seedSummary.failed || 0, 0);
  if (marketGraphFetchPythonText) {
    marketGraphFetchPythonText.textContent = data.selectedPython || pythonPreflight.selectedPython || pythonPreflight.executable || '-';
  }
  if (marketGraphFetchPreflightText) {
    marketGraphFetchPreflightText.textContent = formatMarketGraphPreflightStatus(pythonPreflight);
  }

  renderMarketGraphFetchLogs(data.logs);
  updateMarketGraphFetchControls(running);

  if (!running && !data.seedExists && !marketGraphState.graph) {
    if (marketGraphSvgBox) {
      marketGraphSvgBox.textContent = MARKET_GRAPH_NO_SEED_TEXT;
    }

    setMarketGraphLog(MARKET_GRAPH_NO_SEED_TEXT);
