  if (marketGraphSearchInput) {
    marketGraphSearchInput.value = normalizedCode;
  }

  if (supplyChainStockSearchInput) {
    supplyChainStockSearchInput.value = normalizedCode;
  }

  return normalizedCode;
}

function getSupplyChainFocusSelfForChain(chain, code) {
  const normalizedCode = normalizeObservationStockCode(code);

  if (!normalizedCode || !chain || !chain.layers) {
    return null;
  }

  for (const def of SUPPLY_CHAIN_LAYER_DEFS) {
    const layer = getSupplyChainLayer(chain, def.key);
    const stocks = Array.isArray(layer.stocks) ? layer.stocks : [];
    const matched = stocks.find((stock) => normalizeObservationStockCode(stock && stock.code) === normalizedCode);

    if (matched) {
      return {
        ...matched,
        code: normalizedCode,
        name: matched.name || matched.label || normalizedCode,
        layerKey: def.key,
        layerLabel: def.label,
        chainId: chain.id || supplyChainState.selectedChainId || '',
        chainName: chain.name || ''
      };
    }
  }

  return null;
}

function getSupplyChainFocusRenderContext(chain) {
  const focusCode = getUnifiedStockFocusCode();

  if (!focusCode) {
    return null;
  }

  const self = getSupplyChainFocusSelfForChain(chain, focusCode);

  return {
    ok: true,
    uiFocusOnly: true,
    code: focusCode,
    supplyChain: {
      self: self || {
        code: focusCode,
        layerKey: supplyChainState.stockResult && Array.isArray(supplyChainState.stockResult.assignments) && supplyChainState.stockResult.assignments[0]
