async function loadMarketGraphRawRelations(code) {
  const normalizedCode = normalizeObservationStockCode(code);

  if (!isSupportedObservationStockCode(normalizedCode) || !window.xwbApi || typeof window.xwbApi.getMarketGraphRaw !== 'function') {
    return;
  }

  marketGraphState.rawRelationCache[normalizedCode] = { loading: true };
  renderMarketGraphDetail(marketGraphState.selectedNodeId || marketGraphState.hoverNodeId);

  try {
    const response = await window.xwbApi.getMarketGraphRaw({ code: normalizedCode });

    if (!response.ok) {
      marketGraphState.rawRelationCache[normalizedCode] = { error: formatDisplayError(response.error) };
    } else if (!response.raw || !response.raw.exists) {
      marketGraphState.rawRelationCache[normalizedCode] = { error: 'seed 中未找到该股票。' };
    } else {
      marketGraphState.rawRelationCache[normalizedCode] = { item: response.raw.item || {} };
    }
  } catch (error) {
    marketGraphState.rawRelationCache[normalizedCode] = {
      error: formatDisplayError(error && error.message ? error.message : error)
    };
  }

  renderMarketGraphDetail(marketGraphState.selectedNodeId || marketGraphState.hoverNodeId);
}

function getMarketGraphHighlightSets(nodeId) {
  const graph = marketGraphState.visibleGraph || { nodes: [], edges: [] };
  const relatedNodeIds = new Set();
  const relatedEdgeKeys = new Set();

  if (!nodeId) {
    return { relatedNodeIds, relatedEdgeKeys };
  }

  relatedNodeIds.add(nodeId);
  (graph.edges || []).forEach((edge) => {
    if (edge.source !== nodeId && edge.target !== nodeId) {
      return;
    }

    relatedNodeIds.add(edge.source);
    relatedNodeIds.add(edge.target);
    relatedEdgeKeys.add(`${edge.source}->${edge.target}`);
  });

  return { relatedNodeIds, relatedEdgeKeys };
}

function applyMarketGraphHighlight(nodeId) {
  if (!marketGraphSvgBox) {
    return;
  }

  const activeNodeId = nodeId || '';
  const { relatedNodeIds, relatedEdgeKeys } = getMarketGraphHighlightSets(activeNodeId);

  marketGraphSvgBox.querySelectorAll('.market-graph-node').forEach((nodeElement) => {
    const elementNodeId = nodeElement.getAttribute('data-node-id') || '';
    const isRelated = !activeNodeId || relatedNodeIds.has(elementNodeId);

    nodeElement.classList.toggle('is-selected', elementNodeId === marketGraphState.selectedNodeId);
    nodeElement.classList.toggle('is-highlighted', Boolean(activeNodeId && isRelated));
    nodeElement.classList.toggle('is-dimmed', Boolean(activeNodeId && !isRelated));
  });

  marketGraphSvgBox.querySelectorAll('.market-graph-edge').forEach((edgeElement) => {
    const source = edgeElement.getAttribute('data-edge-source') || '';
    const target = edgeElement.getAttribute('data-edge-target') || '';
    const isRelated = relatedEdgeKeys.has(`${source}->${target}`);

    edgeElement.classList.toggle('is-highlighted', Boolean(activeNodeId && isRelated));
    edgeElement.classList.toggle('is-dimmed', Boolean(activeNodeId && !isRelated));
  });
}

