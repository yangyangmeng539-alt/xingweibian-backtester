function buildUiForecastDailyBiasByDayPct(nodePredictionAnalysis, options = {}) {
  const signalCurve = options.signalCurve || {};
  const confidenceScale = Number.isFinite(Number(options.confidenceScale))
    ? Number(options.confidenceScale)
    : 1;
  const baselineWeight = Number.isFinite(Number(options.baselineWeight))
    ? Number(options.baselineWeight)
    : 0.1;
  const forecastDays = Math.max(1, Math.floor(Number(options.forecastDays) || FORECAST_ZOOM_DAYS));
  const result = {};

  for (let day = 1; day <= forecastDays; day += 1) {
    const milestone = getUiForecastPathMilestone(nodePredictionAnalysis, day);
    const dailyMedianBase = Number(milestone && milestone.median);
    const dailySignal = interpolateUiForecastReturnMap(signalCurve, day);

    if (!Number.isFinite(dailyMedianBase) || !Number.isFinite(Number(dailySignal))) {
      continue;
    }

    const dailyPrediction = roundUiForecastPathPct(
      dailyMedianBase * baselineWeight + Number(dailySignal) * confidenceScale
    );

    if (!Number.isFinite(Number(dailyPrediction))) {
      continue;
    }

    result[day] = roundUiForecastPathPct(Number(dailyPrediction) - dailyMedianBase);
  }

  return result;
