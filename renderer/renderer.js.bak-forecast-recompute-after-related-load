      return element;
    }

    element = element.parentNode;
  }

  return null;
}

function stopForecastBoxDrag() {
  const positions = activeForecastBoxDrag && interactiveCurveState
    ? interactiveCurveState.forecastBoxPositions
    : null;

  if (activeForecastBoxDrag && activeForecastBoxDrag.group) {
    activeForecastBoxDrag.group.classList.remove('dragging');
  }

  activeForecastBoxDrag = null;
  window.removeEventListener('pointermove', handleForecastBoxPointerMove);
  window.removeEventListener('pointerup', stopForecastBoxDrag);
  window.removeEventListener('pointercancel', stopForecastBoxDrag);

  if (positions) {
    saveForecastBoxPositions(positions);
  }
}

function handleForecastBoxPointerMove(event) {
  const state = interactiveCurveState;

  if (!activeForecastBoxDrag || !state) {
    return;
  }

  const point = getSvgPointFromPointer(event);

  if (!point) {
    return;
  }

  setForecastBoxPosition(
    activeForecastBoxDrag.type,
    activeForecastBoxDrag.originX + point.x - activeForecastBoxDrag.startX,
    activeForecastBoxDrag.originY + point.y - activeForecastBoxDrag.startY
  );
  applyForecastBoxTransform(activeForecastBoxDrag.group, activeForecastBoxDrag.type);
  event.preventDefault();
}

function handleForecastBoxPointerDown(event) {
  const group = getForecastDraggableBox(event.target);

  if (!group) {
    return;
  }

  const point = getSvgPointFromPointer(event);

  if (!point) {
    return;
  }

  const type = group.dataset.forecastBox;
  const position = getForecastBoxPosition(type);
  activeForecastBoxDrag = {
    group,
    type,
    startX: point.x,
    startY: point.y,
    originX: position.x,
    originY: position.y
  };
  group.classList.add('dragging');
  window.addEventListener('pointermove', handleForecastBoxPointerMove);
  window.addEventListener('pointerup', stopForecastBoxDrag);
  window.addEventListener('pointercancel', stopForecastBoxDrag);
  event.preventDefault();
  event.stopPropagation();
}

function getNodeForecastMilestone(nodePredictionAnalysis, day) {
  const key = `d${Number(day)}`;
  const milestones = nodePredictionAnalysis && nodePredictionAnalysis.forecastMilestones
    ? nodePredictionAnalysis.forecastMilestones
    : {};

  if (milestones[key]) {
    return milestones[key];
  }

  const stats = Array.isArray(nodePredictionAnalysis && nodePredictionAnalysis.futurePathStats)
    ? nodePredictionAnalysis.futurePathStats
    : [];

  return stats.find((item) => Number(item && item.day) === Number(day)) || {};
}

function getNodeActualMilestone(nodePredictionAnalysis, day) {
  const key = `d${Number(day)}`;
  const summary = nodePredictionAnalysis && nodePredictionAnalysis.actualPathSummary
    ? nodePredictionAnalysis.actualPathSummary
    : {};
  const milestones = summary && summary.milestones ? summary.milestones : {};

  if (milestones[key]) {
    return milestones[key];
  }

  const comparison = nodePredictionAnalysis && nodePredictionAnalysis.actualComparison
    ? nodePredictionAnalysis.actualComparison
    : {};
  const legacy = comparison[key];

  if (legacy && legacy.hasActual) {
    return {
      day: Number(day),
      returnPct: legacy.actualReturnPct
    };
  }

  const rapid = getRapidChangeAnalysis(nodePredictionAnalysis);
  const targetDay = Number(day);

  if (rapid) {
    const rapidReturnMap = {
      3: rapid.d3ReturnPct,
      5: rapid.d5ReturnPct,
      10: rapid.d10ReturnPct,
      20: rapid.d20ReturnPct
    };

    const rapidReturnPct = rapidReturnMap[targetDay];

    if (Number.isFinite(Number(rapidReturnPct))) {
      return {
        day: targetDay,
        returnPct: Number(rapidReturnPct)
      };
    }
  }

  return {
    day: targetDay,
    returnPct: null
  };
}

function getNodeStructureMilestonePct(nodePredictionAnalysis, day) {
  const stat = getNodeForecastMilestone(nodePredictionAnalysis, day);
  const rawReturnPct = Number(stat && stat.medianReturnPct);

  if (!Number.isFinite(rawReturnPct)) {
    return null;
  }

  return getStructureAdjustedForecastReturnPct(
    nodePredictionAnalysis,
    Number(day),
    rawReturnPct,
    'median'
  );
}

