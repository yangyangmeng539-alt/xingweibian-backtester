function schedulePendingForecastActualOverlayRender(delay = 160) {
  clearPendingForecastActualRenderTimer();

  if (!pendingForecastActualOverlay) {
    return;
  }

  if (pendingForecastActualRenderAttempts >= 16) {
    clearPendingForecastActualRenderTimer();
    return;
  }

  pendingForecastActualRenderAttempts += 1;

  pendingForecastActualRenderTimer = setTimeout(() => {
    pendingForecastActualRenderTimer = null;
    renderPendingForecastActualOverlayNow();
  }, delay);
}

