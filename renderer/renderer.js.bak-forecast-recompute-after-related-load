function compactForecastOverlayText(text, maxLength = 28) {
  const value = String(text || '').replace(/\s+/g, ' ').trim();

  if (value.length <= maxLength) {
    return value;
  }

  return `${value.slice(0, Math.max(0, maxLength - 1))}…`;
}

function wrapForecastOverlayTextLine(line, maxChars = 34) {
  const text = String(line || '').replace(/\s+/g, ' ').trim();

  if (!text) {
    return [];
  }

  if (text.length <= maxChars) {
    return [text];
  }

  const result = [];
  let rest = text;

  while (rest.length > maxChars) {
    const candidates = ['｜', '；', '，', '/', ' '];
    let cutIndex = -1;

    for (const token of candidates) {
      const index = rest.lastIndexOf(token, maxChars);

      if (index >= Math.floor(maxChars * 0.45)) {
        cutIndex = index + token.length;
        break;
      }
    }

    if (cutIndex <= 0) {
      cutIndex = maxChars;
    }

    result.push(rest.slice(0, cutIndex).trim());
    rest = rest.slice(cutIndex).trim();
  }

  if (rest) {
    result.push(rest);
  }

  return result;
}

function buildForecastOverlayAutoLines(lines, options = {}) {
  const maxChars = Number(options.maxChars) || 34;
  const maxLines = Number(options.maxLines) || 12;
  const result = [];

  (Array.isArray(lines) ? lines : []).forEach((line) => {
    wrapForecastOverlayTextLine(line, maxChars).forEach((part) => {
      if (result.length < maxLines) {
        result.push(part);
      }
    });
  });

  if (result.length >= maxLines) {
    const last = result[result.length - 1] || '';
    result[result.length - 1] = last.endsWith('…')
      ? last
      : `${last.slice(0, Math.max(0, maxChars - 1))}…`;
  }

  return result.length ? result : ['暂无节点预判。'];
}

function getForecastOverlayLabelLayout(rawLines, state, clickedPoint) {
  const chartWidth = Math.max(260, Number(state.layout.right) - Number(state.layout.left));
  const maxWidth = clamp(chartWidth * 0.46, 330, 520);
  const maxChars = maxWidth >= 470 ? 46 : (maxWidth >= 400 ? 39 : 33);
  const lines = buildForecastOverlayAutoLines(rawLines, {
    maxChars,
    maxLines: 12
  });

  const maxLineLength = Math.max(1, ...lines.map((line) => String(line || '').length));
  const width = clamp(maxLineLength * 7.4 + 24, 320, maxWidth);
  const lineHeight = 15;
  const paddingTop = 18;
  const paddingBottom = 12;
  const height = clamp(lines.length * lineHeight + paddingTop + paddingBottom, 70, 238);

  const left = Number(state.layout.left) + 8;
  const right = Number(state.layout.right) - width - 8;
  const priceTop = Number(state.pricePanel.top) + 8;
  const priceBottom = Number(state.pricePanel.bottom) - height - 8;
  const equityTop = Number(state.equityPanel.top) + 8;
  const equityBottom = Number(state.equityPanel.bottom) - height - 8;

  const preferEquity = Number.isFinite(equityTop) && Number.isFinite(equityBottom) && equityBottom >= equityTop;
  const clickedX = Number(clickedPoint && clickedPoint.x);
  const sideX = Number.isFinite(clickedX) && clickedX < (Number(state.layout.left) + Number(state.layout.right)) / 2
    ? right
    : left;

  const x = clamp(sideX, Number(state.layout.left) + 8, Number(state.layout.right) - width - 8);
  const y = preferEquity
    ? clamp(equityTop, equityTop, equityBottom)
    : clamp(priceTop, priceTop, priceBottom);

  return {
    x,
    y,
    width,
    height,
    lines,
    lineHeight,
    textX: x + 10,
    textY: y + 18
  };
}

function rectForecastOverlayOverlap(a, b, padding = 8) {
  if (!a || !b) {
    return false;
  }

  return !(
    a.x + a.width + padding < b.x ||
    b.x + b.width + padding < a.x ||
    a.y + a.height + padding < b.y ||
    b.y + b.height + padding < a.y
  );
}

function rememberForecastOverlayRect(type, rect) {
  const state = interactiveCurveState;

  if (!state) {
    return;
  }

  if (!state.forecastOverlayRects) {
    state.forecastOverlayRects = {};
  }

  state.forecastOverlayRects[type] = {
    x: Number(rect.x) || 0,
    y: Number(rect.y) || 0,
    width: Number(rect.width) || 0,
    height: Number(rect.height) || 0
  };
}

function getRememberedForecastOverlayRect(type) {
  const state = interactiveCurveState;

  if (!state || !state.forecastOverlayRects) {
    return null;
  }

  return state.forecastOverlayRects[type] || null;
}

function getForecastZoomAutoLayout(state, width, height) {
  const insetWidth = clamp(Math.min(330, Number(state.layout.right) - Number(state.layout.left) - 18), 260, 330);
  const insetHeight = 188;
  const mainLabelRect = getRememberedForecastOverlayRect('label');

  let x = clamp(
    Number(state.layout.right) - insetWidth - 14,
    Number(state.layout.left) + 8,
    Number(state.layout.right) - insetWidth - 8
  );

  let y = clamp(
    Number(state.pricePanel.bottom) - insetHeight - 12,
    Number(state.pricePanel.top) + 8,
    Number(state.pricePanel.bottom) - insetHeight - 8
  );

  const rect = {
    x,
    y,
    width: insetWidth,
    height: insetHeight
  };

  if (rectForecastOverlayOverlap(rect, mainLabelRect, 10)) {
    y = clamp(
      Number(state.pricePanel.top) + 12,
      Number(state.pricePanel.top) + 8,
      Number(state.pricePanel.bottom) - insetHeight - 8
    );

    rect.y = y;
  }

  rememberForecastOverlayRect('zoom', rect);
  return rect;
}

function getForecastOverlayVisualMode(nodePredictionAnalysis) {
