function getForecastPointSortKey(point, index = 0) {
  const day = Number(point && point.day);

  if (Number.isFinite(day)) {
    return day;
  }

  const x = Number(point && point.x);

  if (Number.isFinite(x)) {
    return x;
  }

  return index;
}

function normalizeForecastLinePoints(points) {
  const list = (Array.isArray(points) ? points : [])
    .map((point, index) => {
      if (!point || !Number.isFinite(Number(point.x)) || !Number.isFinite(Number(point.y))) {
        return null;
      }

      return {
        ...point,
        x: Number(point.x),
        y: Number(point.y),
        _sortKey: getForecastPointSortKey(point, index)
      };
    })
    .filter(Boolean)
    .sort((left, right) => {
      const keyDiff = Number(left._sortKey) - Number(right._sortKey);

      if (Math.abs(keyDiff) > 0.000001) {
        return keyDiff;
      }

      return Number(left.x) - Number(right.x);
    });

  const deduped = [];

  list.forEach((point) => {
    const last = deduped[deduped.length - 1];

    if (
      last
      && Math.abs(Number(last._sortKey) - Number(point._sortKey)) < 0.000001
      && Math.abs(Number(last.x) - Number(point.x)) < 0.000001
    ) {
      deduped[deduped.length - 1] = point;
      return;
    }

    deduped.push(point);
  });

  return deduped;
}

function buildSvgPath(points) {
  const validPoints = normalizeForecastLinePoints(points);

  if (!validPoints.length) {
    return '';
  }

  return validPoints.map((point, index) => {
    return `${index === 0 ? 'M' : 'L'} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`;
  }).join(' ');
}

function buildForecastBandPath(q1Points, q3Points) {
  const lowerPoints = normalizeForecastLinePoints(q1Points);
  const upperPoints = normalizeForecastLinePoints(q3Points);

  if (lowerPoints.length < 2 || upperPoints.length < 2) {
    return '';
  }

  return `${buildSvgPath(upperPoints)} L ${lowerPoints.slice().reverse().map((point) => {
    return `${point.x.toFixed(2)} ${point.y.toFixed(2)}`;
  }).join(' L ')} Z`;
}

