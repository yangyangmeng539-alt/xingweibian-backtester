async function requestNodePrediction(clickedDate) {
  const cleanDate = normalizeTimelineDate(clickedDate);

  markPendingForecastActualOverlay(cleanDate);

  if (!cleanDate) {
    clearPendingForecastActualOverlay();
    clearForecastOverlay();
    clearForecastZoomInset();
    renderNodePredictionStatusBar(null, { error: '未识别出有效节点日期。' });
    return;
  }

  const symbol = symbolInput.value.trim();
  const startDate = startDateInput.value.trim();
  const endDate = endDateInput.value.trim();

  if (!isSupportedInputSymbol(symbol)) {
    clearPendingForecastActualOverlay();
    clearForecastOverlay();
    clearForecastZoomInset();
    renderNodePredictionStatusBar(null, { error: getSupportedInputSymbolHint() });
    return;
  }

  const parsedParams = readBacktestParams();

  if (parsedParams.error) {
    clearPendingForecastActualOverlay();
    clearForecastOverlay();
    clearForecastZoomInset();
    renderNodePredictionStatusBar(null, { error: parsedParams.error });
    return;
  }

  if (!window.xwbApi || typeof window.xwbApi.runNodePrediction !== 'function') {
    clearPendingForecastActualOverlay();
    clearForecastOverlay();
    clearForecastZoomInset();
    renderNodePredictionStatusBar(null, { error: '当前版本未暴露节点预判接口。' });
    return;
  }

  const requestSeq = nodePredictionRequestSeq + 1;
  nodePredictionRequestSeq = requestSeq;
  activeNodePredictionDate = cleanDate;
  activeNodePredictionAnalysis = null;
  renderNodePredictionStatusBar(null, {
    loading: true,
    clickedDate: cleanDate
  });

  try {
      const response = await window.xwbApi.runNodePrediction({
        symbol,
        startDate,
        endDate,
        clickedDate: cleanDate,
        refresh: false,
        cacheOnly: true,
        sourceMode: 'sqlite_cache_only',
        params: parsedParams.params
      });

    if (requestSeq !== nodePredictionRequestSeq) {
      return;
    }

    if (!response || !response.ok) {
      clearPendingForecastActualOverlay();
      clearForecastOverlay();
      clearForecastZoomInset();
      renderNodePredictionStatusBar(null, {
        error: `节点预判失败：${formatDisplayError(response && response.error)}`
      });
      return;
    }

    activeNodePredictionDate = response.selectedNodeDate || cleanDate;
    activeNodePredictionAnalysis = response.nodePredictionAnalysis || null;

    activeNodePredictionAnalysis = enrichNodePredictionWithObservationContext(
      activeNodePredictionAnalysis,
      observationContextState && observationContextState.active
        ? observationContextState.active
        : null
    );

    if (!activeNodePredictionAnalysis || !activeNodePredictionAnalysis.ok) {
      const errorText = activeNodePredictionAnalysis && activeNodePredictionAnalysis.error
        ? activeNodePredictionAnalysis.error
        : '未返回有效节点预判数据。';

    activeNodePredictionAnalysis = null;
    clearPendingForecastActualOverlay();
    clearForecastOverlay();
    clearForecastZoomInset();
    renderNodePredictionStatusBar(null, { error: errorText });
    return;
    }

    renderForecastOverlay(activeNodePredictionAnalysis);
    renderForecastZoomInset(activeNodePredictionAnalysis);
    renderNodePredictionStatusBar(activeNodePredictionAnalysis);

    if (hasForecastActualFuturePath(activeNodePredictionAnalysis)) {
      schedulePendingForecastActualOverlayRender(80);
    }

    if (lastInteractiveHoverPayload) {
      updateInteractiveInfoPanel(lastInteractiveHoverPayload);
    }
  } catch (error) {
    if (requestSeq !== nodePredictionRequestSeq) {
      return;
    }

    clearPendingForecastActualOverlay();
    clearForecastOverlay();
    clearForecastZoomInset();
    renderNodePredictionStatusBar(null, {
      error: `节点预判失败：${formatDisplayError(error && error.message ? error.message : error)}`
    });
  }
}

