  if (!window.xwbApi || typeof window.xwbApi.listSupplyChainSecondaryChains !== 'function') {
    setSupplyChainStatus('产业链 API 不可用。');
    return false;
  }

  const response = await window.xwbApi.listSupplyChainSecondaryChains({
    primaryChainId,
    maxChains: SUPPLY_CHAIN_MAX_CHAINS
  });

  if (!response.ok) {
    setSupplyChainStatus(`二级细分链读取失败：${formatDisplayError(response.error)}`);
    return false;
  }

  const result = response.result || {};
  let chains = Array.isArray(result.chains) ? result.chains : [];

  supplyChainState.secondaryChains = chains;

  if (!supplyChainState.secondaryChains.length) {
    supplyChainState.selectedChainId = '';
    supplyChainState.selectedChain = null;
    renderSupplyChainSecondaryList();
    renderSupplyChainDetail(null);
    return true;
  }

  const currentStillVisible = supplyChainState.secondaryChains.some((chain) => {
    return chain.id === supplyChainState.selectedChainId;
  });

  if (currentStillVisible) {
    renderSupplyChainSecondaryList();
    return true;
  }

  const firstSecondary = supplyChainState.secondaryChains[0] || null;
  const firstSecondaryId = firstSecondary ? String(firstSecondary.id || '').trim() : '';

  renderSupplyChainSecondaryList();

  if (firstSecondaryId) {
    await selectSupplyChainChain(firstSecondaryId);
  }

  return true;
