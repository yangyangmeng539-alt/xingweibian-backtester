  }

  observationContextState.active = context;
  observationContextState.lastError = '';

  renderObservationMatrixSummaryCard(context);
  renderStructureRhythmMap(context);

  const layerText = context.supplyChain && context.supplyChain.self
    ? `${context.supplyChain.self.chainName || '-'} / ${context.supplyChain.self.layerLabel || context.supplyChain.self.layerKey || '-'}`
    : '当前产业链未定位';

