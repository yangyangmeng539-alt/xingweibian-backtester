  }

  if (finalKind === 'RISK_REVERSAL') {
    return '黄线为系统退潮风险倾向，不代表必跌，但不应按普通预热线理解。';
  }

  if (finalKind === 'RISK_WARNING' || finalKind === 'SHORT_WINDOW_RISK') {
    return '黄线为风险观察倾向，优先看风险是否兑现。';
  }

  const confidenceBand = marketProjection && marketProjection.ok
    ? marketProjection.confidenceBand
    : nodePredictionAnalysis && nodePredictionAnalysis.confidenceBand;

  if (String(confidenceBand || '').toUpperCase() === 'LOW') {
    return '黄线是历史结构历史中位，LOW 置信只看方向，不看幅度。';
  }

  return '黄线是结构倾向线，不是未来价格拟合线。';
}

function getUiForecastOverlayNote(nodePredictionAnalysis, marketProjection) {
  const note = getUiForecastLineNote(nodePredictionAnalysis, marketProjection);

  return compactForecastOverlayText(note, 34);
}

function isUiHighPositionDivergence(nodePredictionAnalysis) {
  const refinement = nodePredictionAnalysis && nodePredictionAnalysis.observationRefinement
    ? nodePredictionAnalysis.observationRefinement
    : null;

  const diagnostics = refinement && refinement.diagnostics ? refinement.diagnostics : {};
  const target = refinement && refinement.target ? refinement.target : {};
  const positionText = [
    target.positionType,
    target.positionName,
    diagnostics.positionBucket,
    diagnostics.positionHigh ? 'HIGH' : '',
    refinement && refinement.methodChain ? refinement.methodChain.positionVerdict : ''
  ].join(' / ').toUpperCase();

  return diagnostics.positionHigh === true
    || /HIGH|TOP|高位|顶部/.test(positionText)
    || String(refinement && refinement.type || '') === 'STRUCTURE_OVERHEATED'
    || String(refinement && refinement.type || '') === 'LATE_CONFIRMATION';
}

function deriveUiRawPredictionKind(nodePredictionAnalysis) {
  const refinement = nodePredictionAnalysis && nodePredictionAnalysis.observationRefinement
    ? nodePredictionAnalysis.observationRefinement
    : null;

  const type = String(refinement && refinement.type || '');
  const rapidPrediction = getRapidTypePrediction(nodePredictionAnalysis);
  const rapid = getRapidChangeAnalysis(nodePredictionAnalysis);

  const rapidGroup = String(
    rapidPrediction && rapidPrediction.predictedRapidGroup
    || rapid && (rapid.rapidGroup || rapid.group || rapid.typeGroup)
    || ''
  );

  if (type === 'EXTERNAL_CONFIRMED_TARGET_WEAK') {
    return 'TARGET_CATCHUP';
  }

  if (
    type === 'SUPPLY_CHAIN_PREHEAT'
    || type === 'RELATION_PREHEAT'
    || type === 'STRUCTURE_WARMING'
  ) {
    return 'CHAIN_PREHEAT';
  }

  if (
    type === 'SHAPE_POSITION_RISK'
    || type === 'STRUCTURE_OVERHEATED'
    || type === 'PREHEAT_DECAY'
    || type === 'LATE_CONFIRMATION'
    || type === 'ISOLATED_NODE'
  ) {
    return 'RISK_WARNING';
  }

  if (type === 'LOW_LEVEL_CONFIRMATION') {
    return 'LOW_REPAIR';
  }

  if (
    type === 'TREND_CONTINUATION'
    || type === 'STRUCTURE_CONFIRMED'
    || rapidGroup === 'EXTEND_UP'
  ) {
    return 'EXTEND_UP';
  }

  return rapidGroup || 'MIXED';
}

function getUiBaseConfidence(nodePredictionAnalysis, rawPredictionKind) {
  const explicit = Number(
    nodePredictionAnalysis && (
      nodePredictionAnalysis.confidence
      || nodePredictionAnalysis.validationConfidence
      || nodePredictionAnalysis.nodePredictionConfidence
    )
  );

  if (Number.isFinite(explicit)) {
    return Math.max(0, Math.min(1, explicit));
  }

  const rapidPrediction = getRapidTypePrediction(nodePredictionAnalysis);
  const rapid = getRapidChangeAnalysis(nodePredictionAnalysis);
  const rapidTitle = String(
    rapidPrediction && rapidPrediction.predictedRapidTitle
    || rapid && (rapid.rapidTitle || rapid.title || rapid.typeTitle)
    || ''
  );

  const rapidGroup = String(
    rapidPrediction && rapidPrediction.predictedRapidGroup
    || rapid && (rapid.rapidGroup || rapid.group || rapid.typeGroup)
    || ''
  );

  if (rawPredictionKind === 'TARGET_CATCHUP') {
    if (/低位|修复|弱势|近端弱势|超跌/.test(rapidTitle)) {
      return 0.50;
    }

    if (/混合分歧/.test(rapidTitle)) {
      return 0.40;
    }

    return rapidGroup === 'EXTEND_UP' ? 0.46 : 0.39;
  }

  if (rawPredictionKind === 'CHAIN_PREHEAT') {
    return rapidGroup === 'EXTEND_UP' ? 0.32 : 0.12;
  }

  if (rawPredictionKind === 'EXTEND_UP') {
    return 0.34;
  }

  if (/RISK/.test(rawPredictionKind)) {
    return 0.32;
  }

  return 0.30;
}

function getUiConfidenceBand(confidence) {
  const value = Number(confidence);

  if (!Number.isFinite(value)) {
    return 'LOW';
  }

  if (value >= 0.68) {
    return 'HIGH';
  }

  if (value >= 0.40) {
    return 'MID';
  }

  return 'LOW';
}

function buildFallbackNodeMarketProjection(nodePredictionAnalysis) {
  const rawPredictionKind = deriveUiRawPredictionKind(nodePredictionAnalysis);
  let predictionKind = rawPredictionKind;
  let confidence = getUiBaseConfidence(nodePredictionAnalysis, rawPredictionKind);

  if (isUiMarketReady(nodePredictionAnalysis)) {
    const regime = getUiMarketRegime(nodePredictionAnalysis);
    const hostile = isUiHostileMarket(nodePredictionAnalysis);

    if (rawPredictionKind === 'CHAIN_PREHEAT' && hostile) {
      predictionKind = regime === 'BEAR' ? 'RISK_REVERSAL' : 'RISK_PULLBACK';
    }

    if (rawPredictionKind === 'EXTEND_UP') {
      if (regime === 'BEAR') {
        predictionKind = 'RISK_REVERSAL';
      } else if (regime === 'TOP_CROWDING') {
        predictionKind = 'RISK_PULLBACK';
      } else if (hostile && isUiHighPositionDivergence(nodePredictionAnalysis)) {
        predictionKind = 'RISK_PULLBACK';
      }
    }

    if (predictionKind === 'RISK_PULLBACK') {
      confidence = Math.min(confidence, 0.36);
    }

    if (predictionKind === 'RISK_REVERSAL') {
      confidence = Math.min(confidence, 0.32);
    }

    if (rawPredictionKind === 'TARGET_CATCHUP') {
      if (regime === 'STRONG' || regime === 'WARM') {
        confidence += 0.03;
      }

      if (hostile) {
        confidence -= 0.02;
      }

      if (regime === 'TOP_CROWDING') {
        confidence = Math.min(confidence, 0.39);
      }
    }
  }

  confidence = Math.max(0, Math.min(1, confidence));

  return {
    ok: true,
    rawPredictionKind,
    predictionKind,
    confidence: Math.round(confidence * 1000) / 1000,
    confidenceBand: getUiConfidenceBand(confidence)
  };
}

function buildNodePredictionMarketProjection(nodePredictionAnalysis) {
  if (!nodePredictionAnalysis || !nodePredictionAnalysis.ok) {
    return {
      ok: false,
      error: '节点预判无效。'
    };
  }

  if (window.xwbApi && typeof window.xwbApi.buildNodeMarketProjection === 'function') {
    const projection = window.xwbApi.buildNodeMarketProjection({
      nodePredictionAnalysis
    });

    if (projection && projection.ok) {
      return projection;
    }
  }

  return buildFallbackNodeMarketProjection(nodePredictionAnalysis);
}

function getNodePredictionMarketProjection(nodePredictionAnalysis) {
  if (!nodePredictionAnalysis || !nodePredictionAnalysis.ok) {
    return null;
  }

  if (nodePredictionAnalysis.marketProjection && nodePredictionAnalysis.marketProjection.ok) {
    return nodePredictionAnalysis.marketProjection;
  }

  return buildNodePredictionMarketProjection(nodePredictionAnalysis);
}

function cloneJsonSafe(value) {
  try {
    return JSON.parse(JSON.stringify(value || null));
  } catch (_error) {
    return value;
  }
}

function getPredictionSafeNodePredictionAnalysis(nodePredictionAnalysis) {
  const source = nodePredictionAnalysis && typeof nodePredictionAnalysis === 'object'
    ? { ...nodePredictionAnalysis }
    : {};

  [
    'actualComparison',
    'actualComparisonSummary',
    'actualPathSummary',
    'actualFuturePath',
    'actualPath',
    'validation',
    'forecastValidation',
    'typeValidation',
    'horizons',
    'validationStatus',
    'validationSuccess',
    'validationReason',
    'rapidChangeAnalysis'
  ].forEach((key) => {
    if (Object.prototype.hasOwnProperty.call(source, key)) {
      delete source[key];
    }
  });

  return source;
}

function getPredictionSafeObservationContext(context) {
  const safe = cloneJsonSafe(context);

  if (!safe || !safe.ok) {
    return safe;
  }

  if (safe.window && Array.isArray(safe.window.dates)) {
    safe.window.dates = safe.window.dates.filter((point) => Number(point && point.offset) <= 0);
  }

  if (safe.currentStock && Array.isArray(safe.currentStock.timeline)) {
    safe.currentStock.timeline = safe.currentStock.timeline.filter((point) => Number(point && point.offset) <= 0);
  }

  if (safe.related && Array.isArray(safe.related.matrix)) {
    safe.related.matrix = safe.related.matrix.map((row) => ({
      ...row,
      timeline: Array.isArray(row && row.timeline)
        ? row.timeline.filter((point) => Number(point && point.offset) <= 0)
        : []
    }));
  }

  safe.playbackFrames = [];
  safe.currentPlaybackFrame = null;
  safe.currentPlaybackOffset = 0;
  safe.predictionInputMode = 'T0_AND_BEFORE_ONLY';

  try {
    safe.observationSummary = summarizeObservationMatrix(safe);
  } catch (_error) {
    safe.observationSummary = null;
  }

  return safe;
}

function getPredictionSafeContextAudit(context) {
  const rows = context && context.related && Array.isArray(context.related.matrix)
    ? context.related.matrix
    : [];

  let futurePointCount = 0;
  let totalPointCount = 0;

  rows.forEach((row) => {
    const timeline = Array.isArray(row && row.timeline) ? row.timeline : [];

    timeline.forEach((point) => {
      totalPointCount += 1;

      if (Number(point && point.offset) > 0) {
        futurePointCount += 1;
      }
    });
  });

  return {
    mode: context && context.predictionInputMode || '',
    matrixRows: rows.length,
    totalPointCount,
    futurePointCount
  };
}

function enrichNodePredictionWithObservationContext(nodePredictionAnalysis, context) {
  if (!nodePredictionAnalysis || !nodePredictionAnalysis.ok || !context || !context.ok) {
    return nodePredictionAnalysis;
  }

  const predictionDate = normalizeTimelineDate(nodePredictionAnalysis.clickedDate);
  const contextDate = normalizeTimelineDate(context.t0);
  const predictionCode = normalizeObservationStockCode(symbolInput && symbolInput.value);
  const contextCode = normalizeObservationStockCode(context.code);

  if (!predictionDate || !contextDate || predictionDate !== contextDate || predictionCode !== contextCode) {
    return nodePredictionAnalysis;
  }

  const predictionSafeContext = getPredictionSafeObservationContext(context);
  const predictionSafeNode = getPredictionSafeNodePredictionAnalysis(nodePredictionAnalysis);
  const observationRefinement = buildNodePredictionObservationRefinement(predictionSafeContext);
  const marketEnvironment = buildMarketEnvironmentContextForUi(predictionSafeContext);
  const observationMatrixStatus = context && context.related && context.related.matrixStatus
    ? { ...context.related.matrixStatus }
    : null;

  console.log('[PREDICTION_NO_FUTURE_GUARD]', getPredictionSafeContextAudit(predictionSafeContext));

  const projectionInput = {
    ...predictionSafeNode,
    observationMatrixStatus,
    observationRefinement,
    marketEnvironment
  };

  const marketProjection = buildNodePredictionMarketProjection(projectionInput);

  const adjustmentInput = {
    ...projectionInput,
    marketProjection
  };

  const observationForecastAdjustment = getUiObservationForecastAdjustment(adjustmentInput);
  const observationPredictionSafeAudit = getPredictionSafeContextAudit(predictionSafeContext);

  return {
    ...nodePredictionAnalysis,
    observationMatrixStatus,
    observationRefinement,
    marketEnvironment,
    marketProjection,
    observationForecastAdjustment,
    observationPredictionInputMode: 'T0_AND_BEFORE_ONLY',
    observationPredictionSafeAudit
  };
}

