function getObservationPlaybackPoint(row, offset) {
  const timeline = Array.isArray(row && row.timeline) ? row.timeline : [];
  return getObservationMatrixPointAtOffset(timeline, offset);
}

function getObservationPlaybackTargetPoint(context, offset) {
  const timeline = context && context.currentStock && Array.isArray(context.currentStock.timeline)
    ? context.currentStock.timeline
    : [];

  return getObservationMatrixPointAtOffset(timeline, offset);
}

function getObservationPlaybackLayerBase(row) {
  const layers = Array.isArray(row && row.layers) ? row.layers : [];
  const firstLayer = layers[0] || {};

  return {
    layerKey: String(firstLayer.layerKey || 'unknown'),
    layerLabel: String(firstLayer.layerLabel || firstLayer.layerKey || '未知层级')
  };
}

function isObservationPlaybackRelationRow(row) {
  const sources = Array.isArray(row && row.sources) ? row.sources : [];
  return sources.some((source) => String(source || '').includes('relation'));
}

function isObservationPlaybackSupplyChainRow(row) {
  const sources = Array.isArray(row && row.sources) ? row.sources : [];
  const layers = Array.isArray(row && row.layers) ? row.layers : [];
  return sources.some((source) => String(source || '').includes('supply_chain')) || layers.length > 0;
}

function createObservationPlaybackLayerItem(layerKey, layerLabel) {
  return {
    layerKey,
    layerLabel,
    loadedCount: 0,
    strongCount: 0,
    opportunityCount: 0,
    relationCount: 0,
    supplyChainCount: 0,
    strongSamples: [],
    opportunitySamples: [],
    strongRatio: 0,
    opportunityRatio: 0
  };
}

function getObservationPlaybackFrameVerdict(frame) {
  const loadedCount = Number(frame && frame.matrix && frame.matrix.loadedCount || 0);
  const strongCount = Number(frame && frame.matrix && frame.matrix.strongCount || 0);
  const opportunityCount = Number(frame && frame.matrix && frame.matrix.opportunityCount || 0);
  const targetStrong = Boolean(frame && frame.target && frame.target.strong);
  const strongRatio = loadedCount > 0 ? strongCount / loadedCount : 0;
  const opportunityRatio = loadedCount > 0 ? opportunityCount / loadedCount : 0;

  if (loadedCount <= 0) {
    return {
      type: 'NO_DATA',
      title: '无数据',
      text: '这一帧没有可用相关股票状态。'
    };
  }

  if (strongRatio >= 0.6) {
    return {
      type: 'STRONG_RESONANCE',
      title: '强共振',
      text: '这一帧相关股票强状态占比很高，结构共振明显。'
    };
  }

  if (strongRatio >= 0.35) {
    return {
      type: 'RESONANCE',
      title: '共振',
      text: '这一帧相关股票已形成一定比例的强状态。'
    };
  }

  if (strongRatio >= 0.15 || opportunityRatio >= 0.15) {
    return {
      type: 'WARMING',
      title: '预热',
      text: '这一帧已有少量相关股票转强或出现机会状态。'
    };
  }

  if (targetStrong) {
    return {
      type: 'TARGET_ONLY',
      title: '目标股独动',
      text: '当前股自身较强，但相关股票矩阵响应不足。'
    };
  }

  return {
    type: 'WEAK',
    title: '弱结构',
    text: '这一帧相关股票矩阵没有明显共振。'
  };
}

function getObservationPlaybackDominantLayer(frame) {
  const layers = Array.isArray(frame && frame.layers) ? frame.layers : [];

  if (!layers.length) {
    return null;
  }

  return layers
    .slice()
    .sort((left, right) => {
      const leftScore = Number(left.strongRatio || 0) * 1000 + Number(left.strongCount || 0);
      const rightScore = Number(right.strongRatio || 0) * 1000 + Number(right.strongCount || 0);
      return rightScore - leftScore;
    })[0] || null;
}

function getObservationPlaybackTargetRole(frame, context, dominantLayer) {
  const targetStrong = Boolean(frame && frame.target && frame.target.strong);
  const targetOpportunity = Boolean(frame && frame.target && frame.target.opportunity);
  const matrixRatio = Number(frame && frame.matrix && frame.matrix.strongRatio || 0);
  const offset = Number(frame && frame.offset || 0);
  const selfLayerKey = context && context.supplyChain && context.supplyChain.self
    ? context.supplyChain.self.layerKey
    : '';
  const dominantLayerKey = dominantLayer ? dominantLayer.layerKey : '';

  if (targetStrong && matrixRatio >= 0.45 && selfLayerKey && dominantLayerKey && selfLayerKey === dominantLayerKey) {
    return '同层核心共振节点';
  }

  if (targetStrong && matrixRatio >= 0.35) {
    return '链内共振确认节点';
  }

  if (targetStrong && matrixRatio < 0.15) {
    return '目标股独动';
  }

  if (!targetStrong && offset < 0 && matrixRatio >= 0.35) {
    return '相关链提前预热，目标股尚未确认';
  }

  if (!targetStrong && offset === 0 && matrixRatio >= 0.35) {
    return '链内已共振，目标股确认不足';
  }

  if (targetOpportunity) {
    return '机会状态观察节点';
  }

  if (offset > 0 && matrixRatio >= 0.35) {
    return '后续扩散观察节点';
  }

  return '弱跟随观察节点';
}

function buildObservationPlaybackFrameExplain(frame, context) {
  if (!frame) {
    return {
      stage: '无数据',
      dominantLayer: '',
      targetRole: '',
      sentence: '当前没有可解释的动态帧。'
    };
  }

  const dominantLayer = getObservationPlaybackDominantLayer(frame);
  const dominantLayerLabel = dominantLayer
    ? dominantLayer.layerLabel || dominantLayer.layerKey || '未知层级'
    : '暂无主导层';
  const dominantStrongRatio = dominantLayer && dominantLayer.loadedCount
    ? Number(dominantLayer.strongCount || 0) / Number(dominantLayer.loadedCount || 1)
    : 0;
  const targetRole = getObservationPlaybackTargetRole(frame, context, dominantLayer);
  const offsetText = frame.offset === 0
    ? 'T0'
    : `T${Number(frame.offset) > 0 ? '+' : ''}${formatNumber(frame.offset, 0)}`;
  const matrixStrongText = `${formatNumber(frame.matrix.strongCount, 0)} / ${formatNumber(frame.matrix.loadedCount, 0)}（${formatPercent(frame.matrix.strongRatio * 100, 1)}）`;
  const dominantText = dominantLayer
    ? `${dominantLayerLabel} 强状态 ${formatNumber(dominantLayer.strongCount || 0, 0)} / ${formatNumber(dominantLayer.loadedCount || 0, 0)}（${formatPercent(dominantStrongRatio * 100, 1)}）`
    : '没有形成主导层级';

  let sentence = '';

  if (frame.verdict.type === 'STRONG_RESONANCE') {
    sentence = `${offsetText}：结构强共振。${dominantText}；当前股角色：${targetRole}。`;
  } else if (frame.verdict.type === 'RESONANCE') {
    sentence = `${offsetText}：链内共振形成。矩阵强状态 ${matrixStrongText}；主导层：${dominantLayerLabel}；当前股角色：${targetRole}。`;
  } else if (frame.verdict.type === 'WARMING') {
    sentence = `${offsetText}：结构预热。已有少量相关股票转强，主导层暂为 ${dominantLayerLabel}；当前股角色：${targetRole}。`;
  } else if (frame.verdict.type === 'TARGET_ONLY') {
    sentence = `${offsetText}：目标股独动。当前股较强，但相关股票矩阵响应不足，暂不能视为链内共振。`;
  } else if (frame.verdict.type === 'NO_DATA') {
    sentence = `${offsetText}：这一帧没有足够相关股票状态，无法判断传导。`;
  } else {
    sentence = `${offsetText}：弱结构。矩阵强状态 ${matrixStrongText}；当前股角色：${targetRole}。`;
  }

  return {
    stage: frame.verdict.title,
    dominantLayer: dominantLayerLabel,
    dominantLayerKey: dominantLayer ? dominantLayer.layerKey : '',
    dominantStrongRatio,
    targetRole,
    sentence
  };
}

function buildObservationPlaybackFrame(context, datePoint) {
  const offset = Number(datePoint && datePoint.offset);
  const date = normalizeTimelineDate(datePoint && datePoint.date);
  const matrix = context && context.related && Array.isArray(context.related.matrix)
    ? context.related.matrix
    : [];
  const targetPoint = getObservationPlaybackTargetPoint(context, offset);
  const layerMap = new Map();
  const strongSamples = [];
  const opportunitySamples = [];

  let loadedCount = 0;
  let strongCount = 0;
  let opportunityCount = 0;
  let relationLoadedCount = 0;
  let relationStrongCount = 0;
  let supplyChainLoadedCount = 0;
  let supplyChainStrongCount = 0;

  matrix.forEach((row) => {
    const point = getObservationPlaybackPoint(row, offset);

    if (!isObservationMatrixPointLoaded(point)) {
      return;
    }

    const rowCode = normalizeObservationStockCode(row.code);
    const rowName = row.name || '';
    const strong = isObservationStrongPoint(point);
    const opportunity = isObservationOpportunityPoint(point);
    const isRelation = isObservationPlaybackRelationRow(row);
    const isSupplyChain = isObservationPlaybackSupplyChainRow(row);
    const layerBase = getObservationPlaybackLayerBase(row);
    const layerKey = layerBase.layerKey;
    const layerLabel = layerBase.layerLabel;
    const layerItem = layerMap.get(layerKey) || createObservationPlaybackLayerItem(layerKey, layerLabel);

    loadedCount += 1;

    if (strong) {
      strongCount += 1;
    }

    if (opportunity) {
      opportunityCount += 1;
    }

    if (isRelation) {
      relationLoadedCount += 1;

      if (strong) {
        relationStrongCount += 1;
      }
    }

    if (isSupplyChain) {
      supplyChainLoadedCount += 1;

      if (strong) {
        supplyChainStrongCount += 1;
      }
    }

    layerItem.loadedCount += 1;

    if (strong) {
      layerItem.strongCount += 1;

      if (layerItem.strongSamples.length < 8) {
        layerItem.strongSamples.push({
          code: rowCode,
          name: rowName,
          stateCode: point.stateCode || '',
          stateName: point.stateName || '',
          opportunityGrade: point.opportunityGrade || ''
        });
      }

      if (strongSamples.length < 12) {
        strongSamples.push({
          code: rowCode,
          name: rowName,
          layerKey,
          layerLabel,
          stateCode: point.stateCode || '',
          stateName: point.stateName || '',
          opportunityGrade: point.opportunityGrade || ''
        });
      }
    }

    if (opportunity) {
      layerItem.opportunityCount += 1;

      if (layerItem.opportunitySamples.length < 8) {
        layerItem.opportunitySamples.push({
          code: rowCode,
          name: rowName,
          opportunityGrade: point.opportunityGrade || '',
          opportunityScore: point.opportunityScore
        });
      }

      if (opportunitySamples.length < 12) {
        opportunitySamples.push({
          code: rowCode,
          name: rowName,
          layerKey,
          layerLabel,
          opportunityGrade: point.opportunityGrade || '',
          opportunityScore: point.opportunityScore
        });
      }
    }

    if (isRelation) {
      layerItem.relationCount += 1;
    }

    if (isSupplyChain) {
      layerItem.supplyChainCount += 1;
    }

    layerMap.set(layerKey, layerItem);
  });

  const layerOrder = new Map(SUPPLY_CHAIN_LAYER_DEFS.map((def, index) => [def.key, index]));
  const layers = Array.from(layerMap.values()).map((layer) => {
    return {
      ...layer,
      strongRatio: layer.loadedCount > 0 ? layer.strongCount / layer.loadedCount : 0,
      opportunityRatio: layer.loadedCount > 0 ? layer.opportunityCount / layer.loadedCount : 0
    };
  }).sort((left, right) => {
    const leftOrder = layerOrder.has(left.layerKey) ? layerOrder.get(left.layerKey) : 99;
    const rightOrder = layerOrder.has(right.layerKey) ? layerOrder.get(right.layerKey) : 99;

    if (leftOrder !== rightOrder) {
      return leftOrder - rightOrder;
    }

    return String(left.layerLabel).localeCompare(String(right.layerLabel), 'zh-Hans-CN');
  });

  const frame = {
    offset,
    date,
    target: {
      code: context && context.code || '',
      loaded: Boolean(targetPoint),
      strong: isObservationStrongPoint(targetPoint),
      opportunity: isObservationOpportunityPoint(targetPoint),
      close: targetPoint && Number.isFinite(Number(targetPoint.close)) ? Number(targetPoint.close) : null,
      stateCode: targetPoint ? targetPoint.stateCode || '' : '',
      stateName: targetPoint ? targetPoint.stateName || '' : '',
      opportunityGrade: targetPoint ? targetPoint.opportunityGrade || '' : '',
      opportunityScore: targetPoint ? targetPoint.opportunityScore || null : null
    },
    matrix: {
      loadedCount,
      strongCount,
      opportunityCount,
      strongRatio: loadedCount > 0 ? strongCount / loadedCount : 0,
      opportunityRatio: loadedCount > 0 ? opportunityCount / loadedCount : 0,
      strongSamples,
      opportunitySamples
    },
    relation: {
      loadedCount: relationLoadedCount,
      strongCount: relationStrongCount,
      strongRatio: relationLoadedCount > 0 ? relationStrongCount / relationLoadedCount : 0
    },
    supplyChain: {
      loadedCount: supplyChainLoadedCount,
      strongCount: supplyChainStrongCount,
      strongRatio: supplyChainLoadedCount > 0 ? supplyChainStrongCount / supplyChainLoadedCount : 0
    },
    layers
  };

  frame.verdict = getObservationPlaybackFrameVerdict(frame);
  frame.explain = buildObservationPlaybackFrameExplain(frame, context);

  frame.narrative = [
    `${frame.date} / T${frame.offset >= 0 ? '+' : ''}${formatNumber(frame.offset, 0)}`,
    `强状态 ${formatNumber(frame.matrix.strongCount, 0)} / ${formatNumber(frame.matrix.loadedCount, 0)}（${formatPercent(frame.matrix.strongRatio * 100, 1)}）`,
    `产业链强度 ${formatPercent(frame.supplyChain.strongRatio * 100, 1)}`,
    `关系强度 ${formatPercent(frame.relation.strongRatio * 100, 1)}`,
    `结论：${frame.verdict.title}`
  ].join('｜');

  return frame;
}

function buildObservationPlaybackFrames(context) {
  const dateWindow = context && context.window && Array.isArray(context.window.dates)
    ? context.window.dates
    : [];

  if (!context || !context.ok || !dateWindow.length) {
    return [];
  }

  return dateWindow
    .map((point) => buildObservationPlaybackFrame(context, point))
    .filter((frame) => frame.date && Number.isFinite(Number(frame.offset)))
    .sort((left, right) => Number(left.offset) - Number(right.offset));
}

function getObservationPlaybackFrameByOffset(context, offset) {
  const frames = Array.isArray(context && context.playbackFrames) ? context.playbackFrames : [];
  const targetOffset = Number(offset);

  return frames.find((frame) => Number(frame.offset) === targetOffset) || null;
}

function mergeObservationRelatedStocks(relationStocks, supplyChainStocks) {
  const merged = new Map();

  relationStocks.forEach((stock) => {
    addObservationStock(merged, stock, 'relation_context', {
      relationTypes: stock.relationTypes || [],
      relationLabels: stock.relationLabels || [],
      relationScore: stock.relationScore || 0,
      relationStrength: stock.relationStrength || ''
    });
  });

  supplyChainStocks.forEach((stock) => {
    const layer = stock.layers && stock.layers[0] ? stock.layers[0] : {};
    addObservationStock(merged, stock, 'supply_chain_context', {
      layerKey: layer.layerKey || '',
      layerLabel: layer.layerLabel || '',
      chainId: layer.chainId || '',
      chainName: layer.chainName || ''
    });
  });

  return Array.from(merged.values());
}

async function buildObservationContext(clickedDate) {
  const code = normalizeObservationStockCode(symbolInput && symbolInput.value);
  const cleanDate = normalizeTimelineDate(clickedDate);
  const dateWindow = getObservationDateWindow(cleanDate);

  if (!code || !cleanDate || !dateWindow.length) {
    return {
      ok: false,
      error: '无法生成观察上下文：缺少股票代码、观察日期或观察图时间序列。'
    };
  }

  const relationDebugBefore = debugObservationRelationGraph(code, 'before-ensure');

  await ensureObservationMarketGraphForStock(code);

  const relationDebugAfter = debugObservationRelationGraph(code, 'after-ensure');

  const supplyReady = await ensureObservationSupplyChainForStock(code);

  const relationStocks = getObservationMarketGraphCandidates(code);
  const supplyContext = supplyReady.ok
    ? getObservationSupplyChainCandidates(code)
    : { stocks: [], self: null };

  const relatedStocks = mergeObservationRelatedStocks(relationStocks, supplyContext.stocks);

  const context = {
    ok: true,
    code,
    t0: cleanDate,
    window: {
      before: OBSERVATION_CONTEXT_LOOKBACK_DAYS,
      after: OBSERVATION_CONTEXT_FORWARD_DAYS,
      dates: dateWindow
    },
    currentStock: {
      code,
      timeline: buildCurrentStockTimelineForObservation(dateWindow)
    },
    relation: {
      count: relationStocks.length,
      stocks: relationStocks,
      debug: {
        before: relationDebugBefore,
        after: relationDebugAfter
      }
    },
    supplyChain: {
      self: supplyContext.self,
      count: supplyContext.stocks.length,
      stocks: supplyContext.stocks
    },
    related: {
      count: relatedStocks.length,
      stocks: relatedStocks,
      matrix: relatedStocks.map((stock) => ({
      code: stock.code,
      name: stock.name,
      sources: stock.sources,
      relationTypes: stock.relationTypes,
      relationLabels: stock.relationLabels || [],
      relationScore: stock.relationScore || 0,
      relationStrength: stock.relationStrength || '',
      layers: stock.layers,
      timeline: buildPendingRelatedStockTimeline(stock, dateWindow)
    }))
    },
    createdAt: new Date().toISOString()
  };

  console.log('[OBSERVATION_CONTEXT_RELATION_DEBUG]', context.relation.debug);

  return await hydrateObservationRelatedStockMatrix(context);
}

function formatObservationMatrixCardRatio(count, total) {
  const value = Number(count);
  const base = Number(total);

  if (!Number.isFinite(value) || !Number.isFinite(base) || base <= 0) {
    return {
      text: '0 / 0',
      percent: '0.0%',
      ratio: 0
    };
  }

  const ratio = value / base;

  return {
    text: `${formatNumber(value, 0)} / ${formatNumber(base, 0)}`,
    percent: formatPercent(ratio * 100, 1),
    ratio
  };
}

function getObservationMatrixCardTone(ratio) {
  const value = Number(ratio);

  if (value >= 0.6) {
    return 'strong';
  }

  if (value >= 0.35) {
    return 'middle';
  }

  return 'weak';
}

function renderObservationMatrixMetric(label, count, total, hint) {
  const data = formatObservationMatrixCardRatio(count, total);
  const tone = getObservationMatrixCardTone(data.ratio);

  return `
    <div class="observation-matrix-metric ${tone}">
      <span>${formatText(label)}</span>
      <b>${formatText(data.percent)}</b>
      <em>${formatText(data.text)}</em>
      ${hint ? `<i>${formatText(hint)}</i>` : ''}
    </div>
  `;
}

