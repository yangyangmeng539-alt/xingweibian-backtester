function getUiTradingDayBendExtraPct(nodePredictionAnalysis, path, day, band = 'median') {
  const targetDay = Number(day);

  if (!Number.isFinite(targetDay) || targetDay <= 0 || targetDay > FORECAST_ZOOM_DAYS) {
    return 0;
  }

  // T+3 / T+5 / T+10 / T+20 是摘要锚点，不在这里额外改终点。
  // 交易日折度主要处理 T+1、T+2、T+4、T+6...这些中间交易日。
  if ([3, 5, 10, 20].includes(targetDay)) {
    return 0;
  }

  const rawTradingDayReturn = getUiTradingDayRawForecastReturnPct(
    nodePredictionAnalysis,
    targetDay,
    band
  );

  const rawMilestoneSmoothReturn = interpolateUiForecastReturnMap(
    path && path.baselineMedianReturnsPct,
    targetDay
  );

  if (!Number.isFinite(Number(rawTradingDayReturn)) || !Number.isFinite(Number(rawMilestoneSmoothReturn))) {
    return 0;
  }

  const rawBend = Number(rawTradingDayReturn) - Number(rawMilestoneSmoothReturn);
  const amplifiedBend = clamp(
    rawBend * FORECAST_TRADING_DAY_BEND_AMPLIFY,
    -FORECAST_TRADING_DAY_BEND_MAX_EXTRA_PCT,
    FORECAST_TRADING_DAY_BEND_MAX_EXTRA_PCT
  );

  return roundUiForecastPathPct(amplifiedBend);
