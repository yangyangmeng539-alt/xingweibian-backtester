    focusCode: marketGraphState.focusCode || '',
    focusThemeId: marketGraphState.focusThemeId || '',
    expandStockCode: marketGraphState.expandStockCode || '',
    maxThemeOverviewNodes: 80,
    maxThemeOverviewEdges: 120,
    minSharedStockCount: 2,
    maxThemeFocusStocks: 80,
    maxThemeFocusRelatedThemes: 20,
    maxThemeFocusEdges: 120
  };
}

function isMarketGraphBoardType(type) {
  return type === 'region_board' || type === 'style_board' || type === 'other_board';
}

function isMarketGraphThemeType(type) {
  return type === 'theme' || type === 'industry' || type === 'concept';
}

function getMarketGraphAggregateRadius(node, totalNodes) {
  const memberStockCount = Number(node && node.memberStockCount) || 0;
  const base = node && node.type === 'industry' ? 8.5 : (node && node.type === 'theme' ? 9.5 : 7.2);
  const scaled = base + Math.sqrt(Math.max(0, memberStockCount)) * 0.42;
  const maxRadius = totalNodes > 70 ? 20 : 23;

  return Math.max(base, Math.min(maxRadius, scaled));
}

function getMarketGraphNodeRadius(type, totalNodes) {
  if (type && typeof type === 'object') {
    const node = type;

    if (isMarketGraphThemeType(node.type) && (marketGraphState.viewPreset === 'themeOverview' || marketGraphState.viewPreset === 'themeFocus')) {
      return getMarketGraphAggregateRadius(node, totalNodes);
    }

    return getMarketGraphNodeRadius(node.type, totalNodes);
  }

  if (type === 'theme') return totalNodes > 80 ? 8 : 10;
  if (type === 'industry') return totalNodes > 800 ? 7.5 : 9;
  if (type === 'concept') return totalNodes > 800 ? 5.8 : 7;
  if (type === 'region_board') return 6;
  if (type === 'style_board') return 5.6;
  if (type === 'other_board') return 5.6;
  return totalNodes > 800 ? 3.8 : (totalNodes > 260 ? 4.6 : 5.6);
}

function compareMarketGraphNodes(left, right) {
  const priorityDiff = (Number(right.labelPriority) || 0) - (Number(left.labelPriority) || 0);

  if (priorityDiff !== 0) {
    return priorityDiff;
  }

  return String(left.label || left.code || left.id || '').localeCompare(
    String(right.label || right.code || right.id || ''),
    'zh-Hans-CN'
  );
}

function placeMarketGraphColumn(positions, nodes, config) {
  const list = nodes.slice().sort(compareMarketGraphNodes);
  const top = config.top;
  const bottom = config.bottom;
  const minGap = config.minGap || 24;
  const rowCapacity = Math.max(1, Math.floor((bottom - top) / minGap));
  const columnCount = Math.max(1, Math.ceil(list.length / rowCapacity));
  const rowsPerColumn = Math.max(1, Math.ceil(list.length / columnCount));
  const xGap = config.xGap || 42;
  const startX = config.x - ((columnCount - 1) * xGap / 2);

  list.forEach((node, index) => {
    const columnIndex = Math.floor(index / rowsPerColumn);
    const rowIndex = index % rowsPerColumn;
    const rows = Math.min(rowsPerColumn, list.length - columnIndex * rowsPerColumn);
    const gap = rows <= 1 ? 0 : (bottom - top) / (rows - 1);
    const y = rows <= 1 ? (top + bottom) / 2 : top + rowIndex * gap;

    positions.set(node.id, {
      x: startX + columnIndex * xGap,
      y,
      column: config.column,
      labelAnchor: config.labelAnchor
    });
  });
}

function placeMarketGraphCircle(positions, nodes, config) {
  const list = nodes.slice().sort(compareMarketGraphNodes);
  const count = list.length;

  if (!count) {
    return;
  }

  if (count === 1) {
    positions.set(list[0].id, {
      x: config.centerX,
      y: config.centerY,
      labelAnchor: config.labelAnchor || 'middle',
      labelDirection: 'down'
    });
    return;
  }

  list.forEach((node, index) => {
    const angle = (Math.PI * 2 * index / count) + (config.offset || -Math.PI / 2);
    const x = config.centerX + Math.cos(angle) * config.radiusX;
    const y = config.centerY + Math.sin(angle) * config.radiusY;
    let labelAnchor = config.labelAnchor || 'middle';

    if (config.radialLabelAnchor) {
      const cos = Math.cos(angle);

      if (cos > 0.28) {
        labelAnchor = 'start';
      } else if (cos < -0.28) {
        labelAnchor = 'end';
      } else {
        labelAnchor = 'middle';
      }
    }

    positions.set(node.id, {
      x,
      y,
      column: config.column || '',
      labelAnchor,
      labelDirection: Math.sin(angle) < -0.2 ? 'up' : 'down'
    });
  });
}

