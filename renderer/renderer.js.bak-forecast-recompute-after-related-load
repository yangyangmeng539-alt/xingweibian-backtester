      <span><i class="legend-line forecast-node"></i>选中节点</span>
    </div>
  `;

  const svg = interactiveCurveSvg.querySelector('#interactiveCurveSvgNode');
  interactiveCurveState = {
    result: filteredResult,
    rawResult: result,
    data,
    svg,
    width,
    baseWidth: width,
    forecastFuturePad: 0,
    forecastBoxPositions: loadForecastBoxPositions(),
    forecastBoxBasePositions: {},
    height,
    layout,
    pricePanel,
    equityPanel,
    priceMin,
    priceMax
  };

  svg.addEventListener('mousemove', handleInteractiveCurveMove);
  svg.addEventListener('pointerdown', handleForecastBoxPointerDown);
  svg.addEventListener('click', handleInteractiveNodeClick);
  svg.addEventListener('mouseleave', clearInteractiveHover);
  updateInteractiveInfoPanel(null);

  if (activeNodePredictionAnalysis) {
    renderForecastOverlay(activeNodePredictionAnalysis);
    renderForecastZoomInset(activeNodePredictionAnalysis);

    if (pendingForecastActualOverlay) {
      schedulePendingForecastActualOverlayRender(80);
