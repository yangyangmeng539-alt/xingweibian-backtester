}

function getUiForecastMilestoneLabel(nodePredictionAnalysis, marketProjection) {
  const finalKind = marketProjection && marketProjection.ok
    ? marketProjection.predictionKind
    : '';

  if (isUiRiskPredictionKind(finalKind)) {
    return '风险倾向';
  }

  const marketEnvironment = getUiMarketEnvironment(nodePredictionAnalysis);

  if (marketEnvironment && marketEnvironment.ok) {
    return 'C层倾向';
  }

  return '结构倾向';
}

function getUiForecastLineTitle(nodePredictionAnalysis, marketProjection) {
  const finalKind = marketProjection && marketProjection.ok
    ? marketProjection.predictionKind
    : '';

  if (finalKind === 'RISK_PULLBACK') {
    return '回撤风险倾向线';
  }

  if (finalKind === 'RISK_REVERSAL') {
    return '系统退潮风险倾向线';
  }

  if (finalKind === 'RISK_WARNING' || finalKind === 'SHORT_WINDOW_RISK') {
    return '风险观察倾向线';
  }

  const marketEnvironment = getUiMarketEnvironment(nodePredictionAnalysis);

  if (marketEnvironment && marketEnvironment.ok) {
    return 'C层市场修正后的结构倾向线';
  }

  return '结构倾向线';
}

function getUiConfidenceExplain(confidenceBand) {
  const band = String(confidenceBand || 'LOW').toUpperCase();

  if (band === 'HIGH') {
    return 'HIGH：暂不开放，样本不足时不作为强结论。';
  }

  if (band === 'MID') {
    return 'MID：可重点观察方向与结构，但不按精确涨跌幅使用。';
  }

  return 'LOW：只看方向/风险提示，不看幅度，不作为强机会。';
}

function getUiForecastLineNote(nodePredictionAnalysis, marketProjection) {
  const finalKind = marketProjection && marketProjection.ok
    ? String(marketProjection.predictionKind || '')
    : '';

  if (finalKind === 'RISK_PULLBACK') {
