    const userBadge = getSupplyChainUserBadgeHtml(chain);

    return `
      <button class="${itemClass}" type="button" data-chain-id="${formatText(chain.id)}">
        <span>${formatText(chain.name)}${userBadge}</span>
        <small>${formatText(chain.parentName)}</small>
        <b>${formatNumber(chain.stockCount || 0, 0)} 只</b>
      </button>
    `;
  }).join('');

