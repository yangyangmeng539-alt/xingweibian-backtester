  if (context.currentPlaybackFrame) {
    return context.currentPlaybackFrame;
  }

  return getObservationPlaybackFrameByOffset(context, 0) || context.playbackFrames[0] || null;
}

function scheduleObservationPlaybackGraphPaint(context) {
  if (observationPlaybackPaintRaf) {
    cancelAnimationFrame(observationPlaybackPaintRaf);
  }

  observationPlaybackPaintRaf = requestAnimationFrame(() => {
    observationPlaybackPaintRaf = null;
    renderStructureRhythmMap(context);
  });
}

function renderObservationPlaybackStatusLine(context) {
