function normalizeMarketInputText(value) {
  return String(value || '').trim().toUpperCase();
}

function isAshareInputSymbol(value) {
  return /^\d{6}$/.test(normalizeMarketInputText(value));
}

function isHongKongInputSymbol(value) {
  const text = normalizeMarketInputText(value);

  return /^HK:\d{1,5}$/.test(text)
    || /^HK\d{1,5}$/.test(text)
    || /^\d{1,5}\.HK$/.test(text)
    || /^\d{5}$/.test(text);
}

function isSupportedInputSymbol(value) {
  return isAshareInputSymbol(value) || isHongKongInputSymbol(value);
}

function getSupportedInputSymbolHint() {
  return '请输入股票代码，例如 600519 / HK:00700 / 09866.HK。';
}

function escapeHtml(value) {
  return String(value ?? '').replace(/[&<>"']/g, (char) => {
    return {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;'
    }[char];
  });
}

function formatNumber(value, digits = 2) {
  if (value === null || value === undefined || value === '') {
    return '-';
  }

  const num = Number(value);
  if (!Number.isFinite(num)) {
    return '-';
  }
  return num.toFixed(digits);
}

function formatPercent(value, digits = 2) {
  if (value === null || value === undefined || value === '') {
    return '-';
  }

  const num = Number(value);
  if (!Number.isFinite(num)) {
    return '-';
  }
  return `${num.toFixed(digits)}%`;
}

function moneyClass(value) {
  const num = Number(value);
  if (num > 0) return 'positive';
  if (num < 0) return 'negative';
  return '';
}

function clamp(value, min, max) {
  return Math.min(max, Math.max(min, value));
}

function getFiniteNumber(value, fallback = 0) {
  const num = Number(value);
  return Number.isFinite(num) ? num : fallback;
}

function getBarWidth(value, scale) {
  const num = Math.abs(getFiniteNumber(value));
  const base = Math.abs(getFiniteNumber(scale));

  if (base <= 0) {
    return 0;
  }

  return clamp((num / base) * 100, 0, 100);
}

function signedMetricText(value, formatter) {
  const num = Number(value);

  if (!Number.isFinite(num)) {
    return '-';
  }

  if (num > 0) {
    return `正收益 ${formatter(num)}`;
  }

  if (num < 0) {
    return `负收益 ${formatter(num)}`;
  }

  return `持平 ${formatter(num)}`;
}

function formatText(value) {
  if (value === undefined || value === null || value === '') {
    return '-';
  }

  return escapeHtml(value);
}

function formatStateCode(value, labels) {
  if (!value) {
    return '-';
  }

  return labels && labels[value] ? `${labels[value]} / ${value}` : value;
}

function formatOpportunityGrade(value) {
  if (!value) {
    return '-';
  }

  return OPPORTUNITY_GRADE_LABELS[value] ? `${value} / ${OPPORTUNITY_GRADE_LABELS[value]}` : value;
}

function formatOpportunityRisk(value) {
  return OPPORTUNITY_RISK_LABELS[value] || value || '-';
}

function formatOpportunityAction(value) {
  return OPPORTUNITY_ACTION_LABELS[value] || value || '-';
}

function getOpportunityGradeClass(grade) {
  if (grade === 'A') {
    return 'opportunity-grade-a';
  }

  if (grade === 'B') {
    return 'opportunity-grade-b';
  }

  if (grade === 'D') {
    return 'opportunity-grade-d';
  }

  return 'opportunity-grade-c';
}

function getOpportunityRiskClass(riskLevel) {
  if (riskLevel === 'LOW') {
    return 'opportunity-risk-low';
  }

  if (riskLevel === 'HIGH') {
    return 'opportunity-risk-high';
  }

  return 'opportunity-risk-mid';
}

function formatRangePercent(value) {
  const num = Number(value);

  if (!Number.isFinite(num)) {
    return '-';
  }

  return formatPercent(num * 100);
}

function formatBooleanMark(value) {
  if (value === true) {
    return '是';
  }

  if (value === false) {
    return '否';
  }

  return '-';
