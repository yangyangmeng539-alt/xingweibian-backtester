function updateObservationPlaybackInline(context) {
  const roots = getObservationPlaybackControlRoots();

  if (!roots.length) {
    return;
  }

  const currentFrame = getObservationPlaybackCurrentFrame(context);

  if (!currentFrame) {
    return;
  }

  roots.forEach((root) => {
    root.querySelectorAll('[data-observation-playback-current]').forEach((currentText) => {
      currentText.textContent = currentFrame.narrative || '';
    });

    root.querySelectorAll('[data-observation-playback-current-meta]').forEach((currentMeta) => {
      currentMeta.textContent = `当前 T${Number(currentFrame.offset) >= 0 ? '+' : ''}${formatNumber(currentFrame.offset, 0)}｜${currentFrame.date || '-'}`;
    });

    root.querySelectorAll('[data-observation-frame-title]').forEach((frameTitle) => {
      frameTitle.textContent = `当前帧：${currentFrame.verdict ? currentFrame.verdict.title : '-'}`;
    });

    root.querySelectorAll('[data-observation-frame-sentence]').forEach((frameSentence) => {
      frameSentence.textContent = currentFrame.explain
        ? currentFrame.explain.sentence
        : `${currentFrame.narrative || ''}｜${currentFrame.verdict ? currentFrame.verdict.text : ''}`;
    });

    root.querySelectorAll('[data-observation-playback-range]').forEach((range) => {
      if (document.activeElement !== range) {
        range.value = String(currentFrame.offset);
      }
    });
  });
}

function setObservationPlaybackOffset(offset, options = {}) {
  const context = observationContextState.active;
  const shouldRenderCard = options.renderCard !== false;
  const shouldPaintGraph = options.paintGraph !== false;

  if (!context || !Array.isArray(context.playbackFrames) || !context.playbackFrames.length) {
    return;
  }

  const targetOffset = Number(offset);
  const frame = context.playbackFrames.find((item) => Number(item.offset) === targetOffset);

  if (!frame) {
    return;
  }

  context.currentPlaybackOffset = Number(frame.offset);
  context.currentPlaybackFrame = frame;

  if (shouldPaintGraph) {
    if (shouldRenderCard) {
      renderStructureRhythmMap(context);
    } else {
      scheduleObservationPlaybackGraphPaint(context);
    }
  }

  if (shouldRenderCard) {
    renderObservationContextStatus(context);
  } else {
    updateObservationPlaybackInline(context);
    renderObservationPlaybackStatusLine(context);
  }
}

function stepObservationPlayback(delta, options = {}) {
  const context = observationContextState.active;

  if (!context || !Array.isArray(context.playbackFrames) || !context.playbackFrames.length) {
    return;
  }

  const currentFrame = getObservationPlaybackCurrentFrame(context);
  const currentOffset = currentFrame ? Number(currentFrame.offset) : 0;
  const offsets = context.playbackFrames.map((frame) => Number(frame.offset));
  const currentIndex = Math.max(0, offsets.indexOf(currentOffset));
  const nextIndex = clamp(currentIndex + Number(delta || 0), 0, context.playbackFrames.length - 1);
  const nextFrame = context.playbackFrames[nextIndex];

  if (nextFrame) {
    setObservationPlaybackOffset(nextFrame.offset, options);
  }
}

function stopObservationPlayback() {
  if (observationPlaybackTimer) {
    clearInterval(observationPlaybackTimer);
    observationPlaybackTimer = null;
  }
}

function toggleObservationPlayback() {
  const context = observationContextState.active;

  if (!context || !Array.isArray(context.playbackFrames) || !context.playbackFrames.length) {
    return;
  }

  if (observationPlaybackTimer) {
    stopObservationPlayback();
    renderObservationContextStatus(context);
    return;
  }

  observationPlaybackTimer = setInterval(() => {
    const activeContext = observationContextState.active;

    if (!activeContext || !Array.isArray(activeContext.playbackFrames) || !activeContext.playbackFrames.length) {
      stopObservationPlayback();
      return;
    }

    const currentFrame = getObservationPlaybackCurrentFrame(activeContext);
    const currentOffset = currentFrame ? Number(currentFrame.offset) : 0;
    const lastOffset = Number(activeContext.playbackFrames[activeContext.playbackFrames.length - 1].offset);

    if (currentOffset >= lastOffset) {
      const firstFrame = activeContext.playbackFrames[0];

      if (firstFrame) {
        setObservationPlaybackOffset(firstFrame.offset, {
          renderCard: false,
          paintGraph: true
        });
      }

      return;
    }

    stepObservationPlayback(1, {
      renderCard: false,
      paintGraph: true
    });
  }, 650);

  renderObservationContextStatus(context);
}

