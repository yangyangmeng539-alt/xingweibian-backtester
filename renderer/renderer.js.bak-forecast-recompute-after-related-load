function normalizeObservationStockCode(code) {
  const raw = String(code || '').trim().toUpperCase().replace(/^STOCK:/, '');

  if (!raw) {
    return '';
  }

  if (raw.startsWith('HK:')) {
    const digits = raw.slice(3).replace(/\D/g, '');
    return /^\d{1,5}$/.test(digits) ? `HK:${digits.padStart(5, '0')}` : '';
  }

  if (/^HK\d{1,5}$/.test(raw)) {
    return `HK:${raw.slice(2).padStart(5, '0')}`;
  }

  if (/^\d{1,5}\.HK$/.test(raw)) {
    return `HK:${raw.replace(/\.HK$/, '').padStart(5, '0')}`;
  }

  if (/^\d{5}$/.test(raw)) {
    return `HK:${raw}`;
  }

  const digits = raw.replace(/\D/g, '');

  if (!digits) {
    return '';
  }

  return digits.length >= 6 ? digits.slice(-6) : '';
}

function isSupportedObservationStockCode(code) {
  const normalized = normalizeObservationStockCode(code);
  return /^\d{6}$/.test(normalized) || /^HK:\d{5}$/.test(normalized);
}

function getObservationStockName(stock) {
  if (!stock) {
    return '';
  }

  return String(stock.name || stock.label || stock.stockName || stock.code || '').trim();
}

function addObservationStock(stockMap, stock, source, extra = {}) {
  const code = normalizeObservationStockCode(stock && stock.code);

  if (!code) {
    return;
  }

  const existed = stockMap.get(code) || {
    code,
    name: getObservationStockName(stock),
    sources: [],
    relationTypes: [],
    relationLabels: [],
    relationScore: 0,
    relationStrength: '',
    layers: [],
    raw: []
  };

  if (!existed.name) {
    existed.name = getObservationStockName(stock);
  }

  if (source && !existed.sources.includes(source)) {
    existed.sources.push(source);
  }

  const relationTypes = [
    ...(extra.relationType ? [extra.relationType] : []),
    ...(Array.isArray(extra.relationTypes) ? extra.relationTypes : [])
  ];

  relationTypes.forEach((type) => {
    const cleanType = String(type || '').trim();

    if (cleanType && !existed.relationTypes.includes(cleanType)) {
      existed.relationTypes.push(cleanType);
    }
  });

  const relationLabels = [
    ...(extra.relationLabel ? [extra.relationLabel] : []),
    ...(Array.isArray(extra.relationLabels) ? extra.relationLabels : [])
  ];

  relationLabels.forEach((label) => {
    const cleanLabel = String(label || '').trim();

    if (cleanLabel && !existed.relationLabels.includes(cleanLabel)) {
      existed.relationLabels.push(cleanLabel);
    }
  });

  const relationScore = Number(extra.relationScore);

  if (Number.isFinite(relationScore) && relationScore > 0) {
    existed.relationScore += relationScore;
  }

  if (extra.relationStrength) {
    existed.relationStrength = String(extra.relationStrength);
  }

  if (extra.layerKey) {
    const layerItem = {
      layerKey: extra.layerKey,
      layerLabel: extra.layerLabel || extra.layerKey,
      chainId: extra.chainId || '',
      chainName: extra.chainName || ''
    };

    const existsLayer = existed.layers.some((item) => {
      return item.layerKey === layerItem.layerKey && item.chainId === layerItem.chainId;
    });

    if (!existsLayer) {
      existed.layers.push(layerItem);
    }
  }

  existed.raw.push({
    source,
    extra,
    stock
  });

  stockMap.set(code, existed);
}

function findObservationMarketGraphStockNode(graph, code) {
  const normalizedCode = normalizeObservationStockCode(code);
  const nodes = Array.isArray(graph && graph.nodes) ? graph.nodes : [];

  if (!normalizedCode) {
    return null;
  }

  return nodes.find((node) => {
    if (!node) {
      return false;
    }

    const nodeCode = normalizeObservationStockCode(node.code || node.stockCode || node.symbol || node.id);

    return node.type === 'stock' && nodeCode === normalizedCode;
  }) || null;
}

function debugObservationRelationGraph(code, phase = 'debug') {
  const normalizedCode = normalizeObservationStockCode(code);
  const graph = marketGraphState.visibleGraph || marketGraphState.graph || {};
  const nodes = Array.isArray(graph.nodes) ? graph.nodes : [];
  const edges = Array.isArray(graph.edges) ? graph.edges : [];
  const currentNode = findObservationMarketGraphStockNode(graph, normalizedCode);
  const nodeById = new Map(nodes.map((node) => [node.id, node]));

  const getMemberStocks = (node) => {
    if (!node || typeof node !== 'object') {
      return [];
    }

    return [
      ...(Array.isArray(node.memberStocks) ? node.memberStocks : []),
      ...(Array.isArray(node.memberStocksPreview) ? node.memberStocksPreview : []),
      ...(Array.isArray(node.sharedStocksPreview) ? node.sharedStocksPreview : []),
      ...(Array.isArray(node.stocks) ? node.stocks : []),
      ...(Array.isArray(node.stockMembers) ? node.stockMembers : [])
    ];
  };

  const getMemberCode = (stock) => {
    if (!stock) {
      return '';
    }

    if (typeof stock === 'string') {
      return normalizeObservationStockCode(stock);
    }

    return normalizeObservationStockCode(stock.code || stock.stockCode || stock.symbol || stock.id);
  };

  const connectedEdges = currentNode
    ? edges.filter((edge) => edge && (edge.source === currentNode.id || edge.target === currentNode.id))
    : [];

  const directStockNeighbors = [];
  const connectedRelationNodes = [];

  connectedEdges.forEach((edge) => {
    const otherId = edge.source === (currentNode && currentNode.id) ? edge.target : edge.source;
    const other = nodeById.get(otherId);

    if (!other) {
      return;
    }

    if (other.type === 'stock') {
      directStockNeighbors.push(other);
    } else {
      connectedRelationNodes.push(other);
    }
  });

  const memberRelationNodes = nodes.filter((node) => {
    if (!node || node.type === 'stock') {
      return false;
    }

    return getMemberStocks(node).some((stock) => getMemberCode(stock) === normalizedCode);
  });

  const connectedMemberStocks = connectedRelationNodes.flatMap(getMemberStocks);
  const memberRelationStocks = memberRelationNodes.flatMap(getMemberStocks);

  const diagnostic = {
    phase,
    code: normalizedCode,
    viewPreset: marketGraphState.viewPreset,
    focusCode: marketGraphState.focusCode || '',
    graphMode: marketGraphState.mode || '',
    visibleGraphNodes: nodes.length,
    visibleGraphEdges: edges.length,
    currentStockNodeFound: Boolean(currentNode),
    currentNodeId: currentNode ? currentNode.id : '',
    connectedEdges: connectedEdges.length,
    directStockNeighbors: directStockNeighbors.length,
    connectedRelationNodes: connectedRelationNodes.length,
    connectedMemberStocks: connectedMemberStocks.length,
    memberRelationNodes: memberRelationNodes.length,
    memberRelationStocks: memberRelationStocks.length,
    directStockNeighborSample: directStockNeighbors.slice(0, 8).map((node) => ({
      id: node.id,
      code: node.code,
      label: node.label || node.name || ''
    })),
    connectedRelationNodeSample: connectedRelationNodes.slice(0, 8).map((node) => ({
      id: node.id,
      type: node.type,
      label: node.label || node.name || '',
      memberCount: getMemberStocks(node).length
    })),
    memberRelationNodeSample: memberRelationNodes.slice(0, 8).map((node) => ({
      id: node.id,
      type: node.type,
      label: node.label || node.name || '',
      memberCount: getMemberStocks(node).length
    }))
  };

  if (OBSERVATION_CONTEXT_RELATION_DEBUG_ENABLED) {
    console.log('[OBSERVATION_RELATION_DEBUG]', diagnostic);
  }

  return diagnostic;
}

async function ensureObservationMarketGraphForStock(code) {
  const normalizedCode = normalizeObservationStockCode(code);

  if (!normalizedCode) {
    return false;
  }

  debugObservationRelationGraph(normalizedCode, 'before-load');

  const alreadyFocused =
    marketGraphState.viewPreset === 'stockFocus' &&
    normalizeObservationStockCode(marketGraphState.focusCode) === normalizedCode &&
    findObservationMarketGraphStockNode(marketGraphState.visibleGraph, normalizedCode);

  if (alreadyFocused) {
    debugObservationRelationGraph(normalizedCode, 'already-focused');
    return true;
  }

  marketGraphState.viewPreset = 'stockFocus';
  marketGraphState.focusCode = normalizedCode;
  marketGraphState.focusThemeId = '';
  marketGraphState.expandStockCode = '';
  marketGraphState.search = '';
  marketGraphState.hideWeak = false;
  marketGraphState.showBoards = true;
  marketGraphState.showStyleRegion = true;
  marketGraphState.labelMode = 'important';
  marketGraphState.selectedNodeId = `stock:${normalizedCode}`;
  marketGraphState.hoverNodeId = '';

