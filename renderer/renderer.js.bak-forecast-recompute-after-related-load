}

function renderSupplyChainSecondaryList() {
  if (!supplyChainSecondaryList) {
    return;
  }

  if (!supplyChainState.secondaryChains.length) {
    supplyChainSecondaryList.textContent = supplyChainState.selectedPrimaryId ? '该一级链暂无二级细分链。' : '暂无二级细分链。';
