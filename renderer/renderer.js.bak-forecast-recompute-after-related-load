function applyUiRiskPullbackWithReboundShape(predicted, reboundMode) {
  const source = predicted && typeof predicted === 'object' ? predicted : {};

  const fallback = {
    d3: roundUiForecastPathPct(source.d3),
    d5: roundUiForecastPathPct(source.d5),
    d10: roundUiForecastPathPct(source.d10),
    d20: roundUiForecastPathPct(source.d20)
  };

  if (!reboundMode || !reboundMode.ok) {
    return fallback;
  }

  const d3 = Number(source.d3);
  const d5 = Number(source.d5);
  const d10 = Number(source.d10);
  const d20 = Number(source.d20);

  if (!Number.isFinite(d20) || d20 >= 0) {
    return fallback;
  }

  const depth = Math.abs(d20);
  const reboundLift = clamp(
    depth * 0.16,
    0.18,
    FORECAST_RISK_REBOUND_MAX_PCT
  );

  const safeD3 = Number.isFinite(d3) ? d3 : 0;
  const safeD5 = Number.isFinite(d5) ? d5 : 0;
  const safeD10 = Number.isFinite(d10) ? d10 : d20 * 0.45;

  // 反抽不是强行上涨：T+3 只轻微抬，不强制转正。
  const shapedD3 = clamp(
    safeD3 + reboundLift * FORECAST_RISK_REBOUND_D3_LIFT_PCT,
    Math.min(safeD3, d20 * 0.22),
    FORECAST_RISK_REBOUND_MAX_UP_PCT
  );

  // T+5 允许出现弱反抽，但上限很低，不能像启动浪。
  const shapedD5 = clamp(
    safeD5 + reboundLift * FORECAST_RISK_REBOUND_D5_LIFT_PCT,
    Math.min(safeD5, d20 * 0.28),
    FORECAST_RISK_REBOUND_MAX_UP_PCT
  );

  // T+10 必须重新回到风险路径，不能因为反抽把中段也抬太高。
  const shapedD10 = Math.min(
    safeD10,
    d20 * 0.36
  );

  return {
    d3: roundUiForecastPathPct(shapedD3),
    d5: roundUiForecastPathPct(shapedD5),
    d10: roundUiForecastPathPct(shapedD10),
    d20: roundUiForecastPathPct(d20)
  };
}

