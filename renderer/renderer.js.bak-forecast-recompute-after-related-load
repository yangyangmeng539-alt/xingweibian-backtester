function getActualFutureVisibilityGuard(nodePredictionAnalysis) {
  const state = interactiveCurveState;
  const clickedDate = normalizeTimelineDate(nodePredictionAnalysis && nodePredictionAnalysis.clickedDate);

  if (!state || !state.data || !Array.isArray(state.data.series) || !state.data.dateIndex || !clickedDate) {
    return {
      canShowAny: false,
      visibleDays: new Set()
    };
  }

  const clickedIndex = state.data.dateIndex.has(clickedDate)
    ? state.data.dateIndex.get(clickedDate)
    : -1;

  if (!Number.isInteger(clickedIndex) || clickedIndex < 0) {
    return {
      canShowAny: false,
      visibleDays: new Set()
    };
  }

  const actualFuturePath = Array.isArray(nodePredictionAnalysis && nodePredictionAnalysis.actualFuturePath)
    ? nodePredictionAnalysis.actualFuturePath
    : [];

  const visibleDays = new Set();

  actualFuturePath.forEach((item) => {
    if (!item || !item.exists) {
      return;
    }

    const day = Number(item.day);
    const close = Number(item.close);
    const date = normalizeTimelineDate(item.date);

    if (!Number.isFinite(day) || day <= 0 || !Number.isFinite(close) || close <= 0 || !date) {
      return;
    }

    if (!state.data.dateIndex.has(date)) {
      return;
    }

    const actualIndex = state.data.dateIndex.get(date);

    if (Number.isInteger(actualIndex) && actualIndex > clickedIndex) {
      visibleDays.add(day);
    }
  });

  return {
    canShowAny: visibleDays.size > 0,
    visibleDays
  };
}

function shouldAllowForecastFutureExtension(clickedDate) {
  const state = interactiveCurveState;
  const cleanDate = normalizeTimelineDate(clickedDate);

  if (!state || !state.data || !Array.isArray(state.data.series) || !state.data.dateIndex || !cleanDate) {
    return false;
  }

  if (!state.data.dateIndex.has(cleanDate)) {
    return false;
  }

  const series = state.data.series;
  const clickedIndex = state.data.dateIndex.get(cleanDate);

  if (!Number.isInteger(clickedIndex) || clickedIndex < 0 || series.length === 0) {
    return false;
  }

  // 只有当所选节点已经靠近当前可见窗口最右侧时，才允许向右扩展虚拟未来。
  // 历史节点在“最近一月/三月/半年/一年”窗口里，不允许为了 T+20 拉宽整张图。
  return clickedIndex >= series.length - 3;
}

function renderForecastOverlay(nodePredictionAnalysis) {
  const state = interactiveCurveState;

  if (!state || !state.svg) {
    return;
  }

  const layer = state.svg.querySelector('#forecastOverlayLayer');

  if (!layer) {
    return;
  }

  layer.innerHTML = '';

  if (!nodePredictionAnalysis || !nodePredictionAnalysis.ok) {
    clearForecastOverlay();
    return;
  }

  const clickedDate = normalizeTimelineDate(nodePredictionAnalysis.clickedDate);
  const currentNode = nodePredictionAnalysis.currentNode || {};
  const clickedClose = Number(currentNode.close);
  const clickedPointBase = findCurvePointByDate(clickedDate);
  const clickedY = getForecastOverlayY(clickedClose);

  if (!clickedPointBase || clickedY === null || !Number.isFinite(clickedClose) || clickedClose <= 0) {
    setInteractiveForecastViewPad(0);
    return;
  }

  const clickedPoint = {
    day: 0,
    date: clickedDate,
    x: clickedPointBase.x,
    y: clickedY,
    price: clickedClose
  };
  const forecastDays = getForecastDays(nodePredictionAnalysis);
  const statsByDay = new Map((nodePredictionAnalysis.futurePathStats || []).map((item) => [Number(item.day), item]));
  const actualByDay = new Map((nodePredictionAnalysis.actualFuturePath || []).map((item) => [Number(item.day), item]));
  const actualFutureGuard = getActualFutureVisibilityGuard(nodePredictionAnalysis);
  const realFuturePointByDay = new Map();
  const medianPoints = [clickedPoint];
  const q1Points = [clickedPoint];
  const q3Points = [clickedPoint];
  const actualPoints = [clickedPoint];

  const series = state.data && Array.isArray(state.data.series)
    ? state.data.series
    : [];
  const seriesCount = series.length;

  const visibleChartWidth = Math.max(
    1,
    Number(state.layout.right) - Number(state.layout.left)
  );

  const rawTimelineStepX = seriesCount > 1
    ? visibleChartWidth / (seriesCount - 1)
    : FORECAST_MIN_VIRTUAL_WIDTH / forecastDays;

  const timelineStepX = Math.max(
    rawTimelineStepX,
    FORECAST_MIN_VIRTUAL_WIDTH / forecastDays
  );

  const clickedVisibleIndex = state.data && state.data.dateIndex && state.data.dateIndex.has(clickedDate)
    ? state.data.dateIndex.get(clickedDate)
    : null;

  const allowFutureExtension = shouldAllowForecastFutureExtension(clickedDate);

  const getStrictForecastX = (day, actualDate) => {
    const cleanDate = normalizeTimelineDate(actualDate);
    const visibleFuturePoint = cleanDate ? findCurvePointByDate(cleanDate) : null;

    if (visibleFuturePoint && Number.isFinite(Number(visibleFuturePoint.x))) {
      return {
        x: Number(visibleFuturePoint.x),
        date: cleanDate,
        source: 'visible-real-date'
      };
    }

    // 历史节点的快捷窗口里，超出当前窗口的 T+N 不画，也不扩展画布。
    // 否则“最近一个月”会被未来虚拟区挤窄，K 线无法铺满图。
    if (!allowFutureExtension) {
      return null;
    }

    if (Number.isInteger(clickedVisibleIndex) && seriesCount > 1) {
      const virtualIndex = clickedVisibleIndex + Number(day);

      if (virtualIndex < seriesCount) {
        return {
          x: getInteractiveXByCount(virtualIndex, seriesCount, state.layout),
          date: cleanDate || `T+${day}`,
          source: 'virtual-visible-date'
        };
      }

      return {
        x: clickedPoint.x + Number(day) * timelineStepX,
        date: cleanDate || `T+${day}`,
        source: 'virtual-future-extension'
      };
    }

    return {
      x: clickedPoint.x + Number(day) * timelineStepX,
      date: cleanDate || `T+${day}`,
      source: 'virtual-future-fallback'
    };
  };

  const forecastTimelineRows = [];

  for (let day = 1; day <= forecastDays; day += 1) {
    const actual = actualByDay.get(day);
    const actualDate = actual && actual.exists ? normalizeTimelineDate(actual.date) : '';
    const strictPoint = getStrictForecastX(day, actualDate);

    if (!strictPoint) {
      continue;
    }

    const x = Number(strictPoint.x);

    if (!Number.isFinite(x)) {
      continue;
    }

    forecastTimelineRows.push({
      day,
      date: strictPoint.date || actualDate || `T+${day}`,
      x,
      source: strictPoint.source,
      actual,
      actualClose: actual && actual.exists && Number.isFinite(Number(actual.close))
        ? Number(actual.close)
        : null
    });
  }

  const maxForecastX = Math.max(
    clickedPoint.x,
    ...forecastTimelineRows.map((row) => Number(row.x)).filter(Number.isFinite)
  );

  const baseWidth = Number(state.baseWidth || state.width || 0);
  const baseRight = baseWidth - FORECAST_RIGHT_MARGIN;
  const overflowRight = maxForecastX - baseRight;
  const neededPad = overflowRight > 0
    ? clamp(overflowRight + FORECAST_RIGHT_MARGIN, 0, FORECAST_FUTURE_PAD)
    : 0;

  setInteractiveForecastViewPad(neededPad);

  for (const row of forecastTimelineRows) {
    const day = Number(row.day);
    const x = Number(row.x);
    const stat = statsByDay.get(day) || {};
    const pointDate = row.date || `T+${day}`;

    const medianPrice = returnPctToPrice(
      clickedClose,
      getStructureAdjustedForecastReturnPct(nodePredictionAnalysis, day, stat.medianReturnPct, 'median')
    );
    const q1Price = returnPctToPrice(
      clickedClose,
      getStructureAdjustedForecastReturnPct(nodePredictionAnalysis, day, stat.lowerQuartileReturnPct, 'q1')
    );
    const q3Price = returnPctToPrice(
      clickedClose,
      getStructureAdjustedForecastReturnPct(nodePredictionAnalysis, day, stat.upperQuartileReturnPct, 'q3')
    );

    const medianPoint = buildForecastOverlayPointAtX(x, pointDate, medianPrice, { day });
    const q1Point = buildForecastOverlayPointAtX(x, pointDate, q1Price, { day });
    const q3Point = buildForecastOverlayPointAtX(x, pointDate, q3Price, { day });

    if (medianPoint) {
      medianPoints.push(medianPoint);
    }

    if (q1Point && q3Point) {
      q1Points.push(q1Point);
      q3Points.push(q3Point);
    }

    if (actualFutureGuard.visibleDays.has(day) && Number.isFinite(row.actualClose)) {
      const actualPoint = buildForecastOverlayPointAtX(x, pointDate, row.actualClose, { day });

      if (actualPoint) {
        actualPoints.push(actualPoint);
      }
    }
  }

  const safeMedianPoints = normalizeForecastLinePoints(medianPoints);
