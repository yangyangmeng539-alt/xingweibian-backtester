function setUnifiedStockFocus(code, options = {}) {
  const normalizedCode = normalizeObservationStockCode(code);

  if (!isSupportedObservationStockCode(normalizedCode)) {
    return '';
  }

  stockFocusLinkState.code = normalizedCode;
  stockFocusLinkState.name = String(options.name || stockFocusLinkState.name || '').trim();
  stockFocusLinkState.source = String(options.source || stockFocusLinkState.source || 'manual').trim();
