async function loadMarketGraph(mode) {
  const isFull = mode === 'full';
  const apiName = isFull ? 'getMarketGraph' : 'getMarketGraphSample';
  const button = isFull ? marketGraphLoadFullButton : marketGraphLoadSampleButton;
  const requestOptions = getMarketGraphRequestOptions();

  if (!window.xwbApi || typeof window.xwbApi[apiName] !== 'function') {
    setMarketGraphLog('市场态星图 API 不可用。');
    return;
  }

  setMarketGraphButtonBusy(button, true);
  setMarketGraphLog(isFull ? '正在加载全量星图...' : '正在加载样本星图...');

  try {
    const response = await window.xwbApi[apiName](isFull ? requestOptions : { ...requestOptions, limit: 50 });

    if (!response.ok) {
      setMarketGraphLog(`星图加载失败：${formatDisplayError(response.error)}`);
      return;
    }

    marketGraphState.graph = response.graph || { nodes: [], edges: [], stats: {} };
    marketGraphState.mode = isFull ? 'full' : 'sample';
    marketGraphState.selectedNodeId = '';
    marketGraphState.hoverNodeId = '';
    marketGraphState.rawRelationCache = {};
    renderMarketGraphSummary(marketGraphState.graph.stats);
    updateMarketGraphControls();
    setMarketGraphModeBadge(`${isFull ? 'FULL GRAPH' : 'SAMPLE 50'} · ${MARKET_GRAPH_PRESET_LABELS[marketGraphState.viewPreset] || marketGraphState.viewPreset}`);
    renderMarketGraphSvg();

    const stats = marketGraphState.graph.stats || {};
    setMarketGraphLog(`星图已加载：当前图节点 ${formatNumber(stats.currentGraphNodeCount || stats.nodeCount || marketGraphState.graph.nodes.length, 0)}，当前图边 ${formatNumber(stats.currentGraphEdgeCount || stats.edgeCount || marketGraphState.graph.edges.length, 0)}，主题节点 ${formatNumber(stats.currentThemeNodeCount || 0, 0)}，隐藏股票 ${formatNumber(stats.hiddenStockCount || 0, 0)}，隐藏弱关系 ${formatNumber(stats.hiddenWeakRelationCount || 0, 0)}。`);
  } catch (error) {
    setMarketGraphLog(`星图加载失败：${formatDisplayError(error && error.message ? error.message : error)}`);
  } finally {
    setMarketGraphButtonBusy(button, false);
  }
}

