  }

  const raw = Number(
    hkLiquidity.bendByDayPct[dayNumber]
    ?? hkLiquidity.bendByDayPct[String(dayNumber)]
    ?? 0
  );

  if (!Number.isFinite(raw)) {
    return 0;
  }

  // 港股折度先轻一点，避免黄线太夸张
  return clamp(raw, -1.8, 1.8);
